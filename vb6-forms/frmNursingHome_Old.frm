    With grdReport
        .Col = .ActiveCol
        .Row = .ActiveRow
        If .CellTag <> vbNullString Then
            If .CellTag = "ALCOHOL" Then
                strRow = "What type of Alcohol do you drink?"
            ElseIf .CellTag = "DRUG" Then
                strRow = "What Drugs do you or have you used?"
            End If
        End If
    End With
    If Trim(strRow) <> vbNullString And Trim(strCollection) <> vbNullString Then
