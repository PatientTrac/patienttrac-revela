            & "INNER JOIN ENCOUNTER ON ENCOUNTER.PATIENT_ID = INPATIENT_APPOINTMENTS.PATIENT_ID " _
            & "WHERE INPATIENT_APPOINTMENTS.Facility_ID = " & piFacilityID & " And INPATIENT_APPOINTMENTS.Active = 0 " _
            & "AND PATIENT.STATUS = 'Active' AND (INPATIENT_APPOINTMENTS.STATUS <> 'Postpone' AND INPATIENT_APPOINTMENTS.STATUS <> 'Active') AND " _
            & "(ENCOUNTER.ENCNTR_END_DATE IS NULL OR CONVERT(DATETIME, ENCOUNTER.ENCNTR_END_DATE, 101) = '01/01/1900' OR " _
            & "CONVERT(DATETIME, ENCOUNTER.ENCNTR_END_DATE, 101) > '" & Format(mstrRangeDate, "mm/dd/yyyy") & "' AND " _
            & "CONVERT(DATETIME, ENCOUNTER.ENCNTR_END_DATE, 101) < '" & Format(mstrUpperRange, "mm/dd/yyyy") & "') AND " _
            & "(CONVERT(VARCHAR(10), INPATIENT_APPOINTMENTS.APPT_DATE, 101) > '" & Format(mstrRangeDate, "mm/dd/yyyy") & "' AND " _
            & "CONVERT(VARCHAR(10), INPATIENT_APPOINTMENTS.APPT_DATE, 101) < '" & Format(mstrUpperRange, "mm/dd/yyyy") & "') " _
            & "AND CONVERT(DATETIME, ENCOUNTER.ENCNTR_START_DATE, 101) > '" & Format(mstrRangeDate, "mm/dd/yyyy") & "' AND " _
            & "CONVERT(DATETIME, ENCOUNTER.ENCNTR_START_DATE, 101) < '" & Format(mstrUpperRange, "mm/dd/yyyy") & "' " _
            & "ORDER BY PATIENT.LAST_NAME, PATIENT.FIRST_NAME, PATIENT.MIDDLE_NAME, ENCOUNTER.ENCNTR_START_DATE DESC, " _
            & "INPATIENT_APPOINTMENTS.APPT_DATE DESC"
        Set rsReadAppt = cnReadAppt.Execute(strSQL)
    'End If
    With rsReadAppt
        Do Until .EOF
            Clear_InSched
            Clear_Appt
            lngPatID = 0
            udtInPatSched.Appointment_ID = 0
            lngApptID = 0
            udtInPatSched.SchedType = vbNullString
            strReAdmit = vbNullString
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) > vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "SUFFIX"
                                udtInPatSched.Suffix = Trim(Fld.Value)
                            Case "LAST_NAME"
                                udtInPatSched.LastName = IsProperCase(Fld.Value)
                            Case "MIDDLE_NAME"
                                udtInPatSched.MiddleInitial = IsProperCase(Fld.Value)
                            Case "FIRST_NAME"
                                udtInPatSched.FirstName = Fld.Value
                            Case "PREF_CONTACT"
                                udtInPatSched.RoomTelephone = Trim(Fld.Value)
                            Case "PATIENT_ID"
                                udtInPatSched.IntId = Fld.Value
                            Case "PURPOSE_VISIT"
                                udtInPatSched.VisitType = Fld.Value
                            Case "APPT_TYPE"
                                udtInPatSched.SchedType = Trim(Fld.Value)
                            Case "STATUS"
                                udtInPatSched.Status = Trim(Fld.Value)
                            Case "STATUS_NOTES"
                                udtInPatSched.ApptComment = Fld.Value
                                udtInPatSched.ApptComment = Replace(udtInPatSched.ApptComment, "''", "'")
                            Case "PROVIDER_ID"
                                udtInPatSched.Provider_ID = Fld.Value
                            Case "APPT_DATE"
                                udtInPatSched.Appt_Date = Fld.Value
                                clsShedGrid.ApptDate = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
                            Case "ENCOUNTER_ID"
                                lngEnctr = Fld.Value
                            Case "RESOURCE_TYPE"
                                udtInPatSched.ResourceType = Fld.Value
                            Case "ROOM_NUMBER"
                                udtInPatSched.RoomNumber = Fld.Value
                            Case "TELEPHONE"
                                udtInPatSched.RoomTelephone = Fld.Value
                            Case "DURATION"
                                udtInPatSched.Duration = Fld.Value
                            Case "PATIENT_TYPE"
                                udtInPatSched.PatientType = Fld.Value
                            Case "CURRENT_LOCATION"
                                strReAdmit = Fld.Value
                            Case "INPATIENT_APPT_ID"
                                lngApptID = Fld.Value
                            Case "ENCNTR_START_DATE"
                                strRange = Fld.Value
                            Case "ENCNTR_END_DATE"
                                strEnd = Fld.Value
                        End Select
                    End If
                End If
            Next
            .MoveNext
            If lngDup <> Val(udtInPatSched.IntId) Then
                udtInPatSched.Appointment_ID = lngApptID
                mlngPatCnt = mlngPatCnt + 1
                udtInPatSched.Title = Fix_Title(udtInPatSched.Title)
                udtInPatSched.Suffix = Fix_Suffix(udtInPatSched.Suffix)
                udtInPatSched.LastName = Fix_Name(udtInPatSched.LastName)
                udtInPatSched.FirstName = Fix_Name(udtInPatSched.FirstName)
                If udtInPatSched.FirstName <> vbNullString Then
                    udtInPatSched.Collection = Trim(udtInPatSched.LastName) & ", " & Trim(udtInPatSched.FirstName)
                End If
                If Trim(udtInPatSched.Suffix) <> vbNullString Then
                    udtInPatSched.Name = udtInPatSched.FirstName & " " & udtInPatSched.LastName & ", " & udtInPatSched.Suffix
                Else
                    udtInPatSched.Name = udtInPatSched.FirstName & " " & udtInPatSched.LastName
                End If
                If udtInPatSched.PatientType <> vbNullString Then
                    If strReAdmit = "Re-Admission" Then
                        udtInPatSched.PatientType = "Re-Admission"
                    ElseIf udtInPatSched.PatientType = "Subsequent Care" Then
                        udtInPatSched.PatientType = "Follow-Up"
                    ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                        udtInPatSched.PatientType = "Initial"
                    End If
                End If
                lngRow = grdRoster.MaxRows + 1
                grdRoster.MaxRows = lngRow
                grdRoster.SetRowItemData lngRow, Val(udtInPatSched.IntId)
                Get_Room_Number Val(udtInPatSched.IntId)
                udtInPatSched.Name = Replace(udtInPatSched.Name, "''", "'")
                Format_CellTypeEdit grdRoster, lngRow, 1, "1", udtInPatSched.RoomNumber, "TypeHAlignLeft", udtInPatSched.Appt_Date
                grdRoster.SetCellBorder 1, lngRow, 1, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                Format_CellTypeEdit grdRoster, lngRow, 2, "1", udtInPatSched.LastName & ", " & udtInPatSched.FirstName _
                & " " & Left(udtInPatSched.MiddleName, 1) & " " & udtInPatSched.Suffix, "TypeHAlignLeft", "", False, 0, CStr(lngEnctr)
                grdRoster.SetCellBorder 2, lngRow, 2, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                If strEnd <> vbNullString Then
                    If DateDiff("d", strEnd, strRange) = 0 Then
                         grdRoster.BlockMode = True
                           grdRoster.Col = 1
                           grdRoster.Col2 = grdRoster.MaxCols
                           grdRoster.Row = lngRow
                           grdRoster.Row2 = lngRow
                           grdRoster.BackColor = DataColor
                        grdRoster.BlockMode = False
                    ElseIf udtInPatSched.Status = "Present" Then
                        grdRoster.BlockMode = True
                           grdRoster.Col = 1
                           grdRoster.Col2 = grdRoster.MaxCols
                           grdRoster.Row = lngRow
                           grdRoster.Row2 = lngRow
                           grdRoster.BackColor = grdCurItem
                        grdRoster.BlockMode = False
                    End If
                ElseIf udtInPatSched.Status = "Present" Then
                    grdRoster.BlockMode = True
                       grdRoster.Col = 1
                       grdRoster.Col2 = grdRoster.MaxCols
                       grdRoster.Row = lngRow
                       grdRoster.Row2 = lngRow
                       grdRoster.BackColor = grdCurItem
                    grdRoster.BlockMode = False
                
                End If
            End If
            lngDup = Val(udtInPatSched.IntId)
        Loop
    End With
    If cnReadAppt.State = adStateOpen Then
        cnReadAppt.Close
        Set cnReadAppt = Nothing
        Set rsReadAppt = Nothing
        Set Flds = Nothing
    End If
    udtInPatSched.Appt_Date = clsShedGrid.ApptDate
    mbooByPass = False
    mbooByPass = False
    udtInPatSched.SchedType = "Patient"
    Get_Changes clsShedGrid.ApptDate
    Clear_InSched
    udtInPatSched.IntId = vbNullString
    lblCurScheAppt.Caption = vbNullString
    lblCurScheAppt.Visible = True
    lblCurScheAppt.Caption = "Active Patient Roster:" & "    " & mlngPatCnt
    mbooByPass = True
    mbooByPass = True
    Screen.MousePointer = vbDefault
    Exit Sub
Error_ReadData:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "ReadData", Me.Name
    Exit Sub
    Resume Next
End Sub
Private Function Update_InPatient_Status()
Dim cnReadAppt As New ADODB.Connection
Dim rsReadAppt  As New ADODB.Recordset
Dim strSQL As String
Dim lngRow As Long
Dim lngCol As Long
Dim varCellValue
Dim lngPurge As Double
Dim lngAdmit_ID As Long
Dim lngPatient As Long

    On Error GoTo Error_Update_InPatient_Status
    If cnReadAppt.State = adStateClosed Then cnReadAppt.open psConnect(0)
    mbooLoad = True
    udtInPatSched.Appointment_ID = 0
    strSQL = "SELECT * FROM INPATIENT_APPOINTMENTS WHERE PATIENT_ID = " & piPatientID & " AND PROVIDER_ID = " & mlngLogonUser & " AND STATUS <> 'PRESENT'  ORDER BY INSERT_DATE DESC"
    Set rsReadAppt = cnReadAppt.Execute(strSQL)
    With rsReadAppt
        If Not .EOF Then
            udtInPatSched.Appointment_ID = (!INPATIENT_APPT_ID)
        End If
    End With
    If udtInPatSched.Appointment_ID > 0 Then
        If cnReadAppt.State = adStateClosed Then cnReadAppt.open psConnect(0)
        strSQL = "Update_InPatient_Status_Appt_ID  " & udtInPatSched.Appointment_ID & ", '" & udtInPatSched.Status & "'"
        Set rsReadAppt = cnReadAppt.Execute(strSQL)
    End If
    If cnReadAppt.State = adStateOpen Then
        cnReadAppt.Close
        Set cnReadAppt = Nothing
        Set rsReadAppt = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Update_InPatient_Status:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Update_InPatient_Status", App.EXEName & "." & Me.Name
    Exit Function
    Resume
End Function
Private Function Write_New_Patient_Schedule(Optional vstrReAdmit As String)
Dim cnReadAppt As New ADODB.Connection
Dim rsReadAppt  As New ADODB.Recordset
Dim strSQL As String
Dim lngRow As Long
Dim lngCol As Long
Dim varCellValue
Dim lngPurge As Double
Dim lngAdmit_ID As Long
Dim strReAdmit As String
Dim lngCnt As Long
Dim lngWrite As Long
Dim lngPatient As Long
Dim boReAdmit As Boolean

    On Error GoTo Error_Write_New_Patient_Schedule
    If cnReadAppt.State = adStateClosed Then cnReadAppt.open psConnect(0)
    If vstrReAdmit <> vbNullString Then boReAdmit = True
    If clsEDI_Client.Site_ID = "1999" Then
         udtInPatSched.Provider_ID = 1000
    End If
    With grdAppt
        .GetText 4, .ActiveRow, varCellValue
        If Trim(varCellValue) <> vbNullString Then
            udtInPatSched.RoomNumber = varCellValue
        End If
    End With
    mbooLoad = True
    udtInPatSched.Status = "Active"
    udtInPatSched.Appointment_ID = 0
    udtInPatSched.Appt_Date = vbNullString
    If cnReadAppt.State = adStateClosed Then cnReadAppt.open psConnect(0)
    strSQL = "SELECT * FROM INPATIENT_APPOINTMENTS  " _
     & "WHERE PATIENT_ID =  " & piPatientID & " AND " _
     & "FACILITY_ID = " & piFacilityID & " AND STATUS <> 'Present' ORDER BY APPT_DATE DESC"
    Set rsReadAppt = cnReadAppt.Execute(strSQL)
    With rsReadAppt
        If Not .EOF Then
            If Not IsNull((!Appt_Date)) Then
                If Trim((!Appt_Date)) <> vbNullString Then
                    udtInPatSched.Appt_Date = Format((!Appt_Date), "mm/dd/yyyy")
                End If
               udtInPatSched.Appointment_ID = (!INPATIENT_APPT_ID)
               udtInPatSched.ApptComment = (!Notes)
            End If
        End If
    End With
    If udtInPatSched.Appt_Date = vbNullString Then
        udtInPatSched.Appt_Date = Format(ccdPrevDate.Value, "mm/dd/yyyy")
    Else
        udtInPatSched.Appt_Date = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
    End If
    If DateDiff("d", udtInPatSched.Appt_Date, Format(Now, "mm/dd/yyyy")) > 30 Then
       udtInPatSched.Appt_Date = Format(ccdPrevDate.Value, "mm/dd/yyyy")
       udtInPatSched.Appointment_ID = 0
    End If
    If udtInPatSched.Appointment_ID > 0 Then
        lngPurge = 0
        strSQL = "Update_InPatient_Appt '" & udtInPatSched.Appt_Date & "','" & udtInPatSched.RoomNumber & "','" _
            & udtInPatSched.VisitType & "','" & udtInPatSched.PatientType & "','" _
            & IsProperCase(udtPatientName.CurrentStatus) & "', " & lngPurge & ", '" & udtInPatSched.ApptComment & "', '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," _
            & udtInPatSched.Appointment_ID
        Set rsReadAppt = cnReadAppt.Execute(strSQL)
        If boReAdmit Then
            strSQL = "UPDATE INPATIENT_APPOINTMENTS SET CURRENT_LOCATION = 'Re-Admission' WHERE INPATIENT_APPT_ID = " & udtInPatSched.Appointment_ID
            Set rsReadAppt = cnReadAppt.Execute(strSQL)
        End If
        If udtInPatSched.Appointment_ID > 0 Then
             strSQL = "UPDATE INPATIENT_APPOINTMENTS SET ACTIVE = '0' WHERE INPATIENT_APPT_ID = " & udtInPatSched.Appointment_ID
            Set rsReadAppt = cnReadAppt.Execute(strSQL)
        End If
        '
    Else
        strSQL = "Insert_InPatient_Appt " & piPatientID & ", " _
            & udtInPatSched.Provider_ID & "," & piFacilityID & ",'" & udtInPatSched.RoomNumber & "','" _
            & udtInPatSched.Appt_Date & "', '" & udtInPatSched.VisitType & "', '" & udtInPatSched.PatientType & "','" & IsProperCase(udtInPatSched.Status) & "','" _
            & udtInPatSched.ApptComment & "'," & mlngLogonUser
        Set rsReadAppt = cnReadAppt.Execute(strSQL)
        With rsReadAppt
            If Not .EOF Then
                udtInPatSched.Appointment_ID = (!INPATIENT_APPT_ID)
            End If
        End With
        If udtInPatSched.Appointment_ID > 0 Then
             strSQL = "UPDATE INPATIENT_APPOINTMENTS SET ACTIVE = '0' WHERE INPATIENT_APPT_ID = " & udtInPatSched.Appointment_ID
            Set rsReadAppt = cnReadAppt.Execute(strSQL)
        End If
        If boReAdmit And udtInPatSched.Appointment_ID > 0 Then
            strSQL = "UPDATE INPATIENT_APPOINTMENTS SET CURRENT_LOCATION = 'Re-Admission' WHERE INPATIENT_APPT_ID = " & udtInPatSched.Appointment_ID
            Set rsReadAppt = cnReadAppt.Execute(strSQL)
        End If
    End If
    If cnReadAppt.State = adStateOpen Then
        cnReadAppt.Close
        Set cnReadAppt = Nothing
        Set rsReadAppt = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Write_New_Patient_Schedule:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Write_New_Patient_Schedule", App.EXEName & "." & Me.Name
    Exit Function
    Resume Next
End Function

Private Function Get_CurrentEnctr_MD(Optional vstrDate As String)
Dim strSQL As String
Dim cnStatus As New ADODB.Connection
Dim rsStatus As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim lngDateDiff As Long
Dim strEnctTime As String
Dim lngEnctrID As Long
Dim iAnswer As Integer
Dim strDate As String
Dim lngTestProvider As Long
Dim i%
Dim strInsert As String
Dim Idx%
Dim strReadAdmit As String
Dim lngAppt As Long


    On Error GoTo Error_Get_CurrentEnctr_MD
    Screen.MousePointer = vbHourglass
    Get_Patient piPatientID
    strDate = vstrDate
    Clear_Appt
    If piEncounterID > 0 Then
        Get_Encounter piEncounterID
    Else
        Dump_EncounterStrData
    End If
    If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
    Get_Providers mlngLogonUser
    udtInPatSched.Appt_Date = Format(ccdPrevDate, "mm/dd/yyyy")
    strDate = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
    With grdFacility
        .Col = 1
        .Row = .ActiveRow
        piFacilityID = .GetRowItemData(.ActiveRow)
    End With
    If udtInPatSched.Provider_ID = 0 Then udtInPatSched.Provider_ID = mlngLogonUser
    udtTime.StartDate = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy 00:00:00 AM/PM")
    udtTime.EndDate = DateAdd("h", 23, udtTime.StartDate)
    udtTime.EndDate = Format(udtTime.EndDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    udtTime.StartDate = Format(Get_Last_MD_Completed, "mm/dd/yyyy")
    If piEncounterID = 0 Then
        If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
        strSQL = "SELECT * FROM ENCOUNTER WHERE PATIENT_ID = " & piPatientID & " AND PROVIDER_ID = " & mlngLogonUser & " AND " _
            & "FACILITY_ID  = " & piFacilityID & " AND  PURGE = 0 AND EXT_ENCOUNTER_ID IS NULL AND " _
            & "(CURRENT_STATE IS NOT NULL OR (ENCNTR_START_DATE BETWEEN '" & Format(udtTime.StartDate, "mm/dd/yyyy") & "' AND '" & Format(udtInPatSched.Appt_Date, "mm/dd/yyyy") & "') ORDER BY ENCNTR_START_DATE DESC, CURRENT_STATE"
        Set rsStatus = cnStatus.Execute(strSQL)
        With rsStatus
            Do Until .EOF
                Dump_EncounterStrData
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case Fld.Name
                                Case "CURRENT_STATE"
                                    clsEncounter.Encounter_State = Fld.Value
                                Case "ENCNTR_START_DATE"
                                    clsEncounter.StartDate = Fld.Value
                                Case "RENDERING_PROVIDER"
                                    clsEncounter.RendProv = Fld.Value
                                Case "FACILITY_ID"
                                    clsEncounter.FacilityID = Fld.Value
                                Case "ENCOUNTER_ID"
                                    clsEncounter.EncounterID = Fld.Value
                                Case "VISIT_TYPE"
                                    clsEncounter.VisitType = Fld.Value
                                Case "ENCNTR_TYPE"
                                    clsEncounter.VisitType = Fld.Value
                                Case "INSERT_DATE"
                                    strInsert = Fld.Value
                            End Select
                        End If
                    End If
                Next
                .MoveNext
                If clsEncounter.StartDate = vbNullString Then
                    clsEncounter.EncounterID = 0
                    Dump_EncounterStrData
                Else
                    lngDateDiff = DateDiff("d", Format(udtInPatSched.Appt_Date, "mm/dd/yyyy"), Format(clsEncounter.StartDate, "mm/dd/yyyy"))
                    If lngDateDiff > 30 Then
                        clsEncounter.EncounterID = 0
                        Dump_EncounterStrData
                    ElseIf lngDateDiff >= -1 And lngDateDiff < 0 Then
                        Exit Do
                    End If
                End If
            Loop
        End With
    Else
        clsEncounter.EncounterID = piEncounterID
    End If
    If lngAppt > 0 Then
        Get_Pat_Appt_Data lngAppt
    Else
        Get_InPatient_Appt_Data
    End If
    Get_Facilities piFacilityID
    clsEncounter.FacilityID = piFacilityID
     If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
    If clsEncounter.EncounterID > 0 Then
        piEncounterID = clsEncounter.EncounterID
        If udtInPatSched.ApptComment <> vbNullString Then
            cctComments = vbNullString
            Get_Insurance piPatientID, Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
            If clsInsurance.Prim_Insurer <> vbNullString Then
                If Trim(udtInPatSched.ApptComment) <> vbNullString Then
                    cctComments = clsInsurance.Prim_Insurer & vbNewLine & Trim(udtInPatSched.ApptComment)
                Else
                    cctComments = Trim(udtInPatSched.ApptComment)
                End If
            Else
                cctComments = Trim(udtInPatSched.ApptComment)
            End If
        End If
        If udtInPatSched.ApptComment <> vbNullString Then
            fraStat.Visible = True
            fraStat.ZOrder 0
        End If
        If PsUserID = vbNullString Then
            PsUserID = Get_PsUserID(psConnect(0))
        End If
        If clsEncounter.EncounterType <> vbNullString Then udtInPatSched.VisitType = clsEncounter.EncounterType
        Select Case udtInPatSched.VisitType
            Case "Follow-Up", "Subsequent Care", "Subsequent Visit", "Subsequent care, nursing facility E&M, limited", "Follow-Up visit, asst living facility, limited"
                udtInPatSched.PatientType = "Subsequent Care"
                For Idx = 0 To cboPurpose.listcount - 1
                    mbooByPass = True
                    If cboPurpose.List(Idx) = "Follow-Up" Then
                        cboPurpose.Text = cboPurpose.List(Idx)
                        Exit For
                    End If
                Next Idx
                mbooByPass = False
            Case "Initial InPatient", "New Patient", "Initial Visit", "Initial E&M Care, Detailed Visit", "Initial E&M Care, Brief Visit", _
                "Initial E&M Care, Extended Visit", "Initial E&M Care, Complex Visit", "Diagnostic Interview Exam", "Psychiatric Diagnostic Exam", "Initial InPatient"
                udtInPatSched.PatientType = "Initial InPatient"
                strReadAdmit = Is_ReAdmit_Patient
                mbooByPass = True
                If strReadAdmit = "Re-Admission" Then
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Re-Admission" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                Else
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Initial InPatient" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                End If
                mbooByPass = False
        End Select
        If Trim(udtInPatSched.PatientType) <> vbNullString Then
            clsEncounter.EncounterType = udtInPatSched.PatientType
        End If
        If clsEncounter.FacilityID > 0 Then
            Get_Facilities clsEncounter.FacilityID
        End If
        If clsFacility.FacType <> vbNullString Then
            clsEncounter.ServicePlace = clsFacility.FacType
        End If
        If clsFacility.pos <> 0 Then
            clsEncounter.ServicePlaceCode = clsFacility.pos
        End If
        If clsEncounter.ServicePlaceCode = "31" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99307"
                clsEncounter.VisitType = "Subsequent care, nursing facility E&M, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = "99304"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        ElseIf clsEncounter.ServicePlaceCode = "13" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99334"
                clsEncounter.VisitType = "Follow-Up visit, asst living facility, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = " 99325"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        End If
        If clsEncounter.VisitType <> vbNullString Then
            strSQL = "UPDATE ENCOUNTER SET ENCOUNT_CPT_INTRVN = '" & clsEncounter.Intrvn_CD & "', " _
                & "VISIT_TYPE = '" & clsEncounter.VisitType & "'," _
                & "ENCNTR_START_DATE = '" & Format(udtInPatSched.Appt_Date, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," _
                & "UPDATE_DATE = '" & Format(udtInPatSched.Appt_Date, "mm/dd/yyyy hh:mm:ss AM/PM") & "'   WHERE ENCOUNTER_ID = " & clsEncounter.EncounterID
            Set rsStatus = cnStatus.Execute(strSQL)
        End If
    ElseIf clsEncounter.EncounterID = 0 Then
        If udtInPatSched.ApptComment <> vbNullString Then
            cctComments = vbNullString
            Get_Insurance piPatientID, Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
            If clsInsurance.Prim_Insurer <> vbNullString Then
                If Trim(udtInPatSched.ApptComment) <> vbNullString Then
                    cctComments = clsInsurance.Prim_Insurer & vbNewLine & Trim(udtInPatSched.ApptComment)
                Else
                    cctComments = Trim(udtInPatSched.ApptComment)
                End If
            Else
                cctComments = Trim(udtInPatSched.ApptComment)
            End If
        End If
        If udtInPatSched.ApptComment <> vbNullString Then
            fraStat.Visible = True
            fraStat.ZOrder 0
        End If
        If PsUserID = vbNullString Then
            PsUserID = Get_PsUserID(psConnect(0))
        End If
        Select Case udtInPatSched.VisitType
            Case "Follow-Up", "Subsequent Care", "Subsequent Visit", "Subsequent care, nursing facility E&M, limited", "Follow-Up visit, asst living facility, limited"
                udtInPatSched.PatientType = "Subsequent Care"
                For Idx = 0 To cboPurpose.listcount - 1
                    mbooByPass = True
                    If cboPurpose.List(Idx) = "Follow-Up" Then
                        cboPurpose.Text = cboPurpose.List(Idx)
                        Exit For
                    End If
                Next Idx
                mbooByPass = False
            Case "Initial InPatient", "New Patient", "Initial Visit", "Initial E&M Care, Detailed Visit", "Initial E&M Care, Brief Visit", _
                "Initial E&M Care, Extended Visit", "Initial E&M Care, Complex Visit", "Diagnostic Interview Exam"
                udtInPatSched.PatientType = "Initial InPatient"
                strReadAdmit = Is_ReAdmit_Patient
                mbooByPass = True
                If strReadAdmit = "Re-Admission" Then
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Re-Admission" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                Else
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Initial InPatient" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                End If
                mbooByPass = False
        End Select
        If Trim(udtInPatSched.PatientType) <> vbNullString Then
            clsEncounter.EncounterType = udtInPatSched.PatientType
        End If
        If clsEncounter.FacilityID > 0 Then
            Get_Facilities clsEncounter.FacilityID
        End If
        If clsFacility.FacType <> vbNullString Then
            clsEncounter.ServicePlace = clsFacility.FacType
        End If
        If clsFacility.pos <> 0 Then
            clsEncounter.ServicePlaceCode = clsFacility.pos
        End If
        If clsEncounter.ServicePlaceCode = "31" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99307"
                clsEncounter.VisitType = "Subsequent care, nursing facility E&M, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = "99304"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        ElseIf clsEncounter.ServicePlaceCode = "13" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99334"
                clsEncounter.VisitType = "Follow-Up visit, asst living facility, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = " 99325"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        End If
        If udtAppointment.VisitType = vbNullString Then udtAppointment.VisitType = clsEncounter.VisitType
        strSQL = "Write_Encounter_Extender " & piPatientID & "," & mlngLogonUser & "," & piFacilityID & ",'" _
            & Format(udtTime.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & clsEncounter.Intrvn_CD & "','" & clsEncounter.VisitType & "','" _
            & clsEncounter.EncounterType & "','" & clsEncounter.ServicePlace & "'," & clsEncounter.ServicePlaceCode & ",'" & PsUserID & "','" _
            & Format(udtTime.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & mlngLogonUser & ",'" & udtAppointment.VisitType & "','MD COMPLETED'"
            Set rsStatus = cnStatus.Execute(strSQL)
            With rsStatus
                If Not .EOF Then
                    clsEncounter.EncounterID = (!Encounter_ID)
                End If
            End With
    End If
    If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
    piEncounterID = clsEncounter.EncounterID
'    If mstrNewPat Then
'        strSQL = "UPDATE ENCOUNTER SET ENCOUNT_CPT_INTRVN = '90801', VISIT_TYPE = 'Psychiatric Diagnostic Exam', " _
'            & "NOTE_TYPE = 'SHORT_CONSULT' WHERE ENCOUNTER_ID = " & clsEncounter.EncounterID
'        Set rsStatus = cnStatus.Execute(strSQL)
'    ElseIf mstrFollowPat Then
'        strSQL = "UPDATE ENCOUNTER SET  NOTE_TYPE = 'UNSCHED CONSULT' WHERE ENCOUNTER_ID = " & clsEncounter.EncounterID
'        Set rsStatus = cnStatus.Execute(strSQL)
'    End If
    Get_Encounter piEncounterID
    modSpecific.piEncounterID = piEncounterID
    Write_SuperBill
    If cnStatus.State = adStateOpen Then
        cnStatus.Close
        Set cnStatus = Nothing
        Set rsStatus = Nothing
        Set Flds = Nothing
    End If
    If clsEncounter.Note_Type = "SHORT_CONSULT" Then
        Add_New_Consult_Grid
    ElseIf clsEncounter.Note_Type = "UNSCHED CONSULT" Then
        Add_Emergency_Follow_Grid
    ElseIf clsEncounter.EncounterType = "Initial InPatient" Or clsEncounter.EncounterType = "Re-Admission" Then
        mbooByPass = True
        If strReadAdmit = "Re-Admission" Then
            For Idx = 0 To cboPurpose.listcount - 1
                If cboPurpose.List(Idx) = strReadAdmit Then
                    mbooByPass = True
                    cboPurpose.Text = cboPurpose.List(Idx)
                    Exit For
                End If
            Next Idx
        Else
            For Idx = 0 To cboPurpose.listcount - 1
                If cboPurpose.List(Idx) = clsEncounter.EncounterType Then
                    mbooByPass = True
                    cboPurpose.Text = cboPurpose.List(Idx)
                    Exit For
                End If
            Next Idx
        End If
        If grdReport.SheetCount = 2 Then
            clsGridFormat.SheetNumber = 2
        ElseIf grdReport.SheetCount > 2 Then
            clsGridFormat.SheetNumber = clsGridFormat.SheetNumber + 1
        End If
        clsGridFormat.SheetNumber = 1
        grdReport.SheetCount = 2
        grdReport.sheet = clsGridFormat.SheetNumber
        Format_Headers
        Get_Values
        clsGridFormat.SheetNumber = 2
        grdReport.SheetCount = clsGridFormat.SheetNumber
        grdReport.sheet = clsGridFormat.SheetNumber
        clsGridFormat.SheetName = "PAST AND SOCIAL"
        Add_Initial_Grid
    Else
        mbooByPass = True
        For Idx = 0 To cboPurpose.listcount - 1
            If cboPurpose.List(Idx) = clsEncounter.EncounterType Then
                cboPurpose.Text = cboPurpose.List(Idx)
                Exit For
            End If
        Next Idx
        grdReport.SheetCount = 2
        Format_Headers
        Get_Values
        clsGridFormat.SheetNumber = 2
        grdReport.SheetCount = clsGridFormat.SheetNumber
        grdReport.sheet = clsGridFormat.SheetNumber
        clsGridFormat.SheetName = "MMSE"
        grdReport.SheetName = clsGridFormat.SheetName
        Format_MMMSE
    End If
    mbooByPass = False
    Get_Patient piPatientID
    udtInPatSched.Status = "Present"
    Update_InPatient_Status
    Get_Psychiatry
    grdReport.sheet = 1
    grdReport.ActiveSheet = 1
    clsGridFormat.SheetNumber = 1
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_CurrentEnctr_MD:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Get_CurrentEnctr_MD", Me.Name
    Exit Function
