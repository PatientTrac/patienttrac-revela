    Screen.MousePointer = vbHourglass
    mbooLoad = True
    clsOpNote.Preop_Diagnosis = vbNullString
    Arr = Split(clsOpNote.Procedure_Name, vbNewLine)
    If UBound(Arr) > 0 Then
        For i = LBound(Arr) To UBound(Arr)
            strProcedure = Arr(i)
                If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
                strSQL = "SELECT PREOP_DIAGNOSIS, PREOP_CODE FROM SURG_PROCEDURE_CODES  WHERE PROCEDURE_NAME like '" & strProcedure & "%'"
                Set rsTerms = cnTerms.Execute(strSQL)
                With rsTerms
                    Do Until .EOF
                        If (!Preop_Diagnosis) <> vbNullString Then
                            'if textfound(
                            If clsOpNote.Preop_Diagnosis = vbNullString Then
                                clsOpNote.Preop_Diagnosis = (!Preop_Diagnosis) & " - " & (!Preop_Code)
                            ElseIf Not TextFound((!Preop_Diagnosis), Trim(clsOpNote.Preop_Diagnosis), Len(clsOpNote.Preop_Diagnosis), True) Then
                                clsOpNote.Preop_Diagnosis = clsOpNote.Preop_Diagnosis & vbNewLine & (!Preop_Diagnosis) & " - " & (!Preop_Code)
                            End If
                        End If
                        .MoveNext
                    Loop
                End With
        Next i
    Else
        strProcedure = Trim(clsOpNote.Procedure_Name)
                If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
                strSQL = "SELECT PREOP_DIAGNOSIS, PREOP_CODE FROM SURG_PROCEDURE_CODES WHERE PROCEDURE_NAME like '%" & strProcedure & "%'"
                Set rsTerms = cnTerms.Execute(strSQL)
                With rsTerms
                    If Not .EOF Then
                        If (!Preop_Diagnosis) <> vbNullString Then
                            If clsOpNote.Preop_Diagnosis = vbNullString Then
                                clsOpNote.Preop_Diagnosis = (!Preop_Diagnosis) & " - " & (!Preop_Code)
                            End If
                        End If
                    End If
                End With
    End If
    If cnTerms.State = adStateOpen Then
        cnTerms.Close
        Set cnTerms = Nothing
        Set rsTerms = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Sub
