Private Function Read_AIMS_Scale()
Dim strSQL As String
Dim cnDevelop As New ADODB.Connection
Dim rsDevelop As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim strBullet As String
Dim lngDateDiff As Long
Dim strData As String
Dim strEnctrDate As String
Dim bData As Boolean
Dim lngRow As Long
Dim lngCol As Long


    On Error GoTo Error_Read_Checkbox_Scales
    If cnDevelop.State = adStateClosed Then cnDevelop.open psConnect(0)
    strSQL = "Get_Patient_Scale_PT_Enct_Form_Name " & piPatientID & "," & piEncounterID & ",'" & clsGridFormat.FormName & "'"
    Set rsDevelop = cnDevelop.Execute(strSQL)
    With rsDevelop
        Do Until .EOF
            clsGridFormat.CellTag = vbNullString
            clsGridFormat.RowName = vbNullString
            clsGridFormat.Text = vbNullString
            clsGridFormat.TextNote = vbNullString
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "DEVELOPMENT_GROUP"
                                clsGridFormat.CellTag = Fld.Value
                            Case "ROW_NAME"
                                clsGridFormat.RowName = Fld.Value
                            Case "CLINICAL_VALUE"
                                clsGridFormat.Text = Fld.Value
                            Case "CLINICAL_NOTE"
                                clsGridFormat.TextNote = Fld.Value
                        End Select
                    End If
                End If
            Next
            .MoveNext
            If clsGridFormat.RowName = "DOES PATIENT WEAR DENTURES" Then clsGridFormat.RowName = "DENTURES"
            If clsGridFormat.RowName = "MUSCLES OF FACIAL EXPRESSION" Then clsGridFormat.RowName = "FACIAL"
            If clsGridFormat.RowName = "INCAPACITIES DUE TO ABNORMAL MOVEMENT" Then clsGridFormat.RowName = "INCAPACITIES"
            If clsGridFormat.RowName = "JAW" Then clsGridFormat.RowName = "JAW"
            If clsGridFormat.RowName = "LIPS AND PERIORAL AREA" Then clsGridFormat.RowName = "LIPS"
            If clsGridFormat.RowName = "LOWER EXTREMITY" Then clsGridFormat.RowName = "LOWER_EXTREMITY"
            If clsGridFormat.RowName = "SEVERITY OF MOVEMENT" Then clsGridFormat.RowName = "MOVEMENT"
            If clsGridFormat.RowName = "NECK, SHOULDERS AND HIPS" Then clsGridFormat.RowName = "NECK, SHOULDERS"
            If clsGridFormat.RowName = "PATIENT'S AWARENESS OF ABNORMAL MOVEMENT" Then clsGridFormat.RowName = "PATIENT_AWARENESS"
            If clsGridFormat.RowName = "DENTAL" Then clsGridFormat.RowName = "DENTAL"
            If clsGridFormat.RowName = "TONGUE" Then clsGridFormat.RowName = "TONGUE"
            If clsGridFormat.RowName = "TRUNK" Then clsGridFormat.RowName = "TRUNK"
            If clsGridFormat.RowName = "PROBLEM WITH TEETH AND/OR DENTURES" Then clsGridFormat.RowName = "TEETH"
            With grdReport
                .sheet = clsGridFormat.SheetNumber
                For lngRow = 1 To .MaxRows
                    For lngCol = 1 To .MaxCols
                        .Col = lngCol
                        .Row = lngRow
                        If .CellTag <> vbNullString Then
                            If Trim(IsProperCase(.CellTag)) = Trim(IsProperCase(clsGridFormat.RowName)) Then
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(clsGridFormat.Text) <> vbNullString And Trim(clsGridFormat.Text) = Trim(.TypeCheckText) Then
                                        .Text = "1"
                                        Exit For
                                    End If
                                End If
                            End If
                        End If
                    Next lngCol
                Next lngRow
            End With
        Loop
    End With
    If cnDevelop.State = adStateOpen Then
        cnDevelop.Close
        Set cnDevelop = Nothing
        Set rsDevelop = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Checkbox_Scales:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_Checkbox_Scales", Me.Name
    Exit Function
    Resume Next
End Function
