        .GetText 1, Row, varCellValue
        udtInPatSched.Appt_Date = varCellValue
        If Trim(udtInPatSched.Appt_Date) <> vbNullString Then
            ccdPrevDate.Value = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
        End If
    End With
    Exit Sub
End Sub


Private Sub grdVisitDate_RightClick(ByVal ClickType As Integer, ByVal Col As Long, ByVal Row As Long, ByVal MouseX As Long, ByVal MouseY As Long)
    If Row <= 0 Then Exit Sub
    With grdVisitDate
        .BlockMode = True
            .Col = 1
            .Col2 = .MaxCols
            .Row = Row
            .Row2 = Row
            .BackColor = NormalColor
        .BlockMode = False
    End With
End Sub


