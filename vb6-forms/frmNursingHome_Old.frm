Private Sub grdSpec_DblClick(ByVal Col As Long, ByVal Row As Long)
Dim lngRow As Long
Dim lngCol As Long
Dim bFound As Boolean
Dim strTag As String
Dim lngSheet As Long

    On Error GoTo Error_Rating_Scale
    With grdSpec
        lngRow = Row
        lngCol = Col
        .Col = lngCol
        .Row = lngRow
        If .CellTag <> vbNullString Then
            strTag = UCase(.CellTag)
            For lngSheet = 1 To grdReport.SheetCount
                grdReport.sheet = lngSheet
                If grdReport.SheetName = "MMSE" And strTag = "MMSE" Then
                    bFound = True
                    grdReport.ActiveSheet = lngSheet
                    grdReport.sheet = lngSheet
                    Exit For
                ElseIf strTag = "HAMILTON RATING" And grdReport.SheetName = "HAMILTON DEPRESSION RATING" Then
                    bFound = True
                    grdReport.ActiveSheet = lngSheet
                    grdReport.sheet = lngSheet
                    Exit For
                ElseIf strTag = "AIMS" And grdReport.SheetName = "AIMS" Then
                    bFound = True
                    grdReport.ActiveSheet = lngSheet
                    grdReport.sheet = lngSheet
                    Exit For
'                ElseIf strTag = "CLINICAL DEMENSIA" And grdReport.SheetName = "AIMS" Then
'                    bFound = True
'                    grdReport.ActiveSheet = lngSheet
'                    grdReport.sheet = lngSheet
'                    Exit For
                End If
            Next lngSheet
            If Not bFound Then
                Select Case strTag
                    Case "MMSE"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "MMSE"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Format_MMMSE
                    Case "HAMILTON RATING"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "HAMILTON DEPRESSION RATING"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Add_Psychiatry_Test_Page
                        Add_Hamilton
                    Case "AIMS"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "AIMS"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Add_AIMS
                    Case "CLINICAL DEMENSIA"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "CLINICAL DEMENESIA"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Load_CDR
                    Case "GERIATRIC PAIN MEASURE"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
