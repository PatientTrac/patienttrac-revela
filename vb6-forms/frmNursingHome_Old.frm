Private Function Add_Batch_Check_Instructions()
Dim strSQL As String
Dim rsTerms As New ADODB.Recordset
Dim cnTerms As New ADODB.Connection
Dim lngRow As Long
Dim lngCol As Long
Dim strTerms As String
Dim lngFirst As Long
Dim Idx%
Dim booData As Boolean
Dim Arr


    On Error GoTo Error_Add_Batch_Check_Instructions
    clsGridFormat.List = vbNullString
    mbooLoad = True
    If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
    strSQL = "Get_Attr_Valid_Value_SubDom_Alphabetic 'sd_PsyPlan_Instruct'"
    Set rsTerms = cnTerms.Execute(strSQL)
    With rsTerms
        Do Until .EOF
            If (!ATTRBTE_VALID_VALUE) <> vbNullString Then
                If Trim(clsGridFormat.List) = vbNullString Then
                    strTerms = Trim(!ATTRBTE_VALID_VALUE)
                End If
            End If
            .MoveNext
            strTerms = Replace(strTerms, "''", "'")
            lngRow = grdPrintForm.MaxRows + 1
            grdPrintForm.MaxRows = lngRow
            If lngFirst = 0 Then lngFirst = lngRow
            lngCol = 2
            Format_CellTypeCheckBox grdPrintForm, lngRow, lngCol, "1", "", "TypeHAlignLeft", "INSTRUCTIONS", False, 0, 0
            lngCol = 3
            Format_CellTypeEdit grdPrintForm, lngRow, lngCol, "4", strTerms, "TypeHAlignLeft", "INSTRUCTION_TEXT"
        Loop
    End With
    Read_Batch_Instruction
    With grdPrintForm
        If Trim(clsReport.Instructions) <> vbNullString Then
            Arr = Split(clsReport.Instructions, vbNewLine)
            If UBound(Arr) > 0 Then
                For Idx = LBound(Arr) To UBound(Arr)
                    booData = False
                    If Arr(Idx) <> vbNullString And Len(Arr(Idx)) > 3 Then
                        For lngRow = lngFirst To .MaxRows
                            .Col = 2
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                If .TypeCheckText = Arr(Idx) Then
                                    booData = False
                                    .Text = "1"
                                    Exit For
                                End If
                            End If
                            If booData Then Exit For
                        Next lngRow
                    End If
                Next Idx
            Else
                booData = False
                For lngRow = lngFirst To .MaxRows
                    .Col = 2
                    .Row = lngRow
                    If .CellType = CellTypeCheckBox Then
                        If .TypeCheckText = Trim(clsReport.Instructions) Then
                            booData = False
                            .Text = "1"
                            Exit For
                        End If
                    End If
                Next lngRow
            End If
        End If
    End With
    If cnTerms.State = adStateOpen Then
        cnTerms.Close
        Set rsTerms = Nothing
        Set cnTerms = Nothing
    End If
    mbooLoad = True
    mbooLoad = True
    Screen.MousePointer = vbDefault
    Exit Function
Error_Add_Batch_Check_Instructions:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Add_Batch_Check_Instructions", Me.Name
    Exit Function
    Resume Next
End Function
