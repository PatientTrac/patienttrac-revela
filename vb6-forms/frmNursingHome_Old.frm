Private Sub grdAppt_DblClick(ByVal Col As Long, ByVal Row As Long)
Dim lngPatient As Long
Dim lngRow As Long
Dim varCellValue
Dim strStart As String
Dim strEnd As String
Dim lngPrimKey As Long
Dim strSQL As String
Dim cnPatient As New ADODB.Connection
Dim rsPatient As New ADODB.Recordset
Dim Idx%

    On Error GoTo Error_grdAppt_DblClick
    Screen.MousePointer = vbHourglass
    If Row < 1 Then Exit Sub
    If cnPatient.State = adStateClosed Then cnPatient.open psConnect(0)
    With grdFacility
        .Col = 1
        .Row = .ActiveRow
        piFacilityID = .GetRowItemData(.ActiveRow)
    End With
'    For Idx = 0 To cboFacility.listcount - 1
'        If cboFacility.List(Idx) = cboFacility.Text Then
'            mbooByPass = True
'            piFacilityID = cboFacility.ItemData(Idx)
'            Exit For
'        End If
'    Next Idx
    With grdAppt
         piPatientID = .GetRowItemData(Row)
        If piPatientID > 0 Then
             .BlockMode = True
                 .Col = 1
                 .Col2 = .MaxCols
                 .Row = Row
                 .Row2 = Row
                 .BackColor = grdCurItem
             .BlockMode = False
         End If
         Get_Patient piPatientID
        .GetText 2, Row, varCellValue
        clsPatient.Status = varCellValue
        udtInPatSched.PatientType = vbNullString
        .GetText 5, Row, varCellValue
        udtInPatSched.PatientType = varCellValue
        If IsProperCase(clsPatient.Status) <> "Active" Then
            piPatientID = .GetRowItemData(Row)
            If Trim(clsPatient.Status) <> vbNullString Then
                strSQL = "Update_Patient_Table_Status  'Active'," & piPatientID
                Set rsPatient = cnPatient.Execute(strSQL)
            End If
        End If
        strStart = DateAdd("d", -30, Now)
        strStart = Format(strStart, "mm/dd/yyyy")
        strEnd = DateAdd("d", 30, strStart)
        strEnd = Format(strEnd, "mm/dd/yyyy")
        strEnd = Format(strEnd, "mm/dd/yyyy hh:mm:ss AM/PM")
        If cnPatient.State = adStateClosed Then cnPatient.open psConnect(0)
        strSQL = "Get_Patient_Status_Range " & piPatientID & ",'" & Format(strStart, "mm/dd/yyyy") & "', '" & Format(strEnd, "mm/dd/yyyy") & "'"
            Set rsPatient = cnPatient.Execute(strSQL)
        With rsPatient
            If Not .EOF Then
                lngPrimKey = (!PATIENT_STATUS_ID)
            End If
        End With
        If cnPatient.State = adStateClosed Then cnPatient.open psConnect(0)
        If lngPrimKey > 0 Then
            strSQL = "UPDATE PATIENT_STATUS SET STATUS_ITEM = '" & CStr(piFacilityID) & "'," _
                & "UPDATE_DATE = '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "' WHERE PATIENT_STATUS_ID = " & lngPrimKey
            Set rsPatient = cnPatient.Execute(strSQL)
        Else
            strSQL = "INSERT INTO PATIENT_STATUS (PATIENT_ID, STATUS_ITEM, INSERT_DATE) " _
                & "VALUES (" & piPatientID & ",'" _
                & CStr(piFacilityID) & "', '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "')"
            Set rsPatient = cnPatient.Execute(strSQL)
        End If
    End With
    If cnPatient.State = adStateOpen Then
        cnPatient.Close
        Set cnPatient = Nothing
        Set rsPatient = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Sub
