            .MaxRows = lngRow
            Get_EnctrRefer piPatientID, piEncounterID
            Format_CellTypeEdit grdReport, lngRow, 1, "1", "REFERRAL PHYSICIAN", "TypeHAlignLeft", "", False, 0, "", True
            Format_CellTypeEdit grdReport, lngRow, 2, "2", clsReferral.Physician, "TypeHAlignLeft", "", False, 0, "", True
            Format_CellTypeEdit grdReport, lngRow, 4, "1", "REFERRAL REASON", "TypeHAlignLeft", "", False, 0, "", True
            Format_CellTypeEdit grdReport, lngRow, 5, "1", clsReferral.Consult_Reason, "TypeHAlignLeft", "", False, 0, "", True
       End If
       lngEnd = lngRow
        For lngRow = lngStart To lngEnd
              grdReport.SetCellBorder 7, lngRow, 7, lngRow, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Next lngRow
        Add_Patient_Photo lngStart, grdReport
        Add_Spacer lngRow, grdReport
        .ReDraw = True
    End With
    lngRow = 2
    Select Case cboPurpose
        Case "Follow-Up"
            Format_CellTypeEdit grdReport, lngRow, 1, "maxcols", "PATIENT SUBSEQUENT PROGRESS NOTE", "TypeHAlignCenter", "", False, HeaderColor
            grdReport.SetCellBorder 1, lngRow, 7, lngRow, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Case "Initial InPatient"
            Format_CellTypeEdit grdReport, lngRow, 1, "maxcols", "INITIAL PATIENT EVALUATION", "TypeHAlignCenter", "", False, HeaderColor
            grdReport.SetCellBorder 1, lngRow, 7, lngRow, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Case "Re-Admission"
        Case "Initial InPatient"
            Format_CellTypeEdit grdReport, lngRow, 1, "maxcols", "RE-ADMISSION PATIENT EVALUATION", "TypeHAlignCenter", "", False, HeaderColor
            grdReport.SetCellBorder 1, lngRow, 7, lngRow, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
    End Select
    'Add_Header
    mbooLoad = True
    Screen.MousePointer = vbDefault
Exit Sub
Error_Format_Headers:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "FormatHeaders", Me.Name
    Exit Sub
    Resume Next
End Sub
