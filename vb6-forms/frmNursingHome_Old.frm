Private Function Run_CDR(ByVal Col As Long, ByVal Row As Long)
Dim strText As String
Dim strTag As String
Dim strTextNote As String
Dim lngCol As Long
Dim lngRow As Long
Dim bFound As Boolean
Dim strAllergy As String
Dim varCellValue
Dim lngActive As Long
Dim bData As Boolean
Dim Arr

    If mbooLoad Then Exit Function
   With grdReport
        mbooLoad = True
        clsGridFormat.FormName = "CLINICAL DEMENSIA"
        .sheet = clsGridFormat.SheetNumber
        If Col = 2 Then
            clsGridFormat.CellTag = vbNullString
            clsGridFormat.Text = vbNullString
            clsGridFormat.TextNote = vbNullString
            clsGridFormat.CellNote = vbNullString
            .Col = Col
            .Row = Row
            lngActive = Row
            If .CellTag <> vbNullString Then
                clsGridFormat.CellTag = .CellTag
                If Trim(clsGridFormat.CellTag) <> vbNullString Then
                    clsGridFormat.Text = vbNullString
                    If .CellType = CellTypeCheckBox Then
                        If .Text = "1" Then
                            clsGridFormat.Text = .TypeCheckText
                            .GetText 3, Row, varCellValue
                            clsGridFormat.RowName = varCellValue
                            If Trim(clsGridFormat.Text) <> vbNullString Then Write_CDR_Grid
                            .Col = Col
                            .Row = Row
                            If .CellTag <> vbNullString Then
                                clsGridFormat.CellTag = .CellTag
                            End If
                            For lngRow = 1 To .MaxRows
                                .Col = 2
                                .Row = lngRow
                                If lngRow <> lngActive Then
                                    If .CellTag <> vbNullString Then
                                        If .CellTag = clsGridFormat.CellTag Then
                                            .Text = "0"
                                            bData = True
                                        ElseIf .CellTag <> clsGridFormat.CellTag And bData Then
                                            Exit For
                                        End If
                                    End If
                                End If
                            Next lngRow
                            clsGridFormat.CellNote = vbNullString
                            Arr = Split(LookUpCellTag(clsGridFormat.CellTag & "_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngRow = Arr(1)
                                If lngRow > 1 Then
                                    lngCol = 2
                                    .Col = Col
                                    .Row = Row
                                    If .CellType = CellTypeCheckBox Then
                                        clsGridFormat.CellNote = .TypeCheckText
                                        Select Case clsGridFormat.CellNote
                                            Case "NONE"
                                                clsGridFormat.TextNote = "0"
                                            Case "QUESTIONABLE"
                                                clsGridFormat.TextNote = "0.5"
                                            Case "MILD"
                                                clsGridFormat.TextNote = "1"
                                            Case "MODERATE"
                                                clsGridFormat.TextNote = "2"
                                            Case "SEVERE"
                                                clsGridFormat.TextNote = "3"
                                        End Select
                                    End If
                                    Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "( " & clsGridFormat.TextNote & " / 3 )", "TypeHAlignLeft", clsGridFormat.CellTag & "_SCORE"
                                End If
                            End If
                        End If
                    End If
                    Calc_CDR
                End If
            End If
        End If
    End With
    mbooLoad = False
    Exit Function
End Function

Private Function Run_GPM(Col As Long, Row As Long)
Dim strText As String
Dim strTag As String
Dim strTextNote As String
Dim lngCol As Long
Dim lngRow As Long
Dim bFound As Boolean
Dim strAllergy As String
Dim varCellValue
Dim Arr

    If mbooLoad Then Exit Function
    With grdReport
        Clear_GridFormat
        .sheet = clsGridFormat.SheetNumber
        .ActiveSheet = clsGridFormat.SheetNumber
        .SheetName = clsGridFormat.SheetName
        .Col = Col
        .Row = Row
        If .CellTag <> vbNullString Then
            clsGridFormat.RowType = .CellTag
            .GetText 1, Row, varCellValue
            clsGridFormat.CellTag = varCellValue
            If Trim(clsGridFormat.CellTag) <> vbNullString Then
                clsGridFormat.Text = vbNullString
                If .CellType = CellTypeCheckBox Then
                    If .Text = "1" Then
                        If Col = 6 Then
                            .GetText 1, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "Yes"
                            mbooLoad = True
                            .Col = 7
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        ElseIf Col = 7 Then
                            .GetText 1, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "No"
                            mbooLoad = True
                            .Col = 6
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        End If
                        If Trim(clsGridFormat.Text) <> vbNullString Then Write_GPM
                    End If
                End If
                Calc_GPM
            End If
        End If
    End With
    Exit Function
End Function

Private Function Run_Katz(Col As Long, Row As Long)
Dim strText As String
Dim strTag As String
Dim strTextNote As String
Dim lngCol As Long
Dim lngRow As Long
Dim bFound As Boolean
Dim strAllergy As String
Dim varCellValue
Dim Arr

    If mbooLoad Then Exit Function
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        .ActiveSheet = clsGridFormat.SheetNumber
        .SheetName = clsGridFormat.SheetName
        Clear_GridFormat
        .Col = Col
        .Row = Row
        If .CellTag <> vbNullString Then
            clsGridFormat.RowType = .CellTag
            .GetText 1, Row - 1, varCellValue
            clsGridFormat.CellTag = varCellValue
            If Trim(clsGridFormat.CellTag) <> vbNullString Then
                clsGridFormat.Text = vbNullString
                If .CellType = CellTypeCheckBox Then
                    If .Text = "1" Then
                        If Col = 2 Then
                            .GetText 3, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "Yes"
                            mbooLoad = True
                            .Col = 5
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        ElseIf Col = 5 Then
                            .GetText 6, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "No"
                            mbooLoad = True
                            .Col = 2
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        End If
                        If Trim(clsGridFormat.Text) <> vbNullString Then Write_Katz
                        Arr = Split(LookUpCellTag(clsGridFormat.CellTag & "_SCORE"), "|")
                        If UBound(Arr) > 0 Then
                            lngRow = Arr(1)
                            If lngRow >= 1 Then
                                lngCol = 3
                                If clsGridFormat.TextNote = "Yes" Then
                                    Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "(1,1)", "TypeHAlignLeft", clsGridFormat.CellTag & "_SCORE"
                                ElseIf clsGridFormat.TextNote = "No" Then
                                    Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "(0,1)", "TypeHAlignLeft", clsGridFormat.CellTag & "_SCORE"
                                End If
                            End If
                        End If
                    End If
                End If
                Calc_Katz
            End If
        End If
    End With
    Exit Function
End Function
Private Function Run_Patient_Encounter_Batch()
