Private Function Write_ProfilerData(vstrOCX As String, vstrValue As String, Optional vstrTag As String)
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strCtl As String
Dim intActX_ID As Integer
Dim strType As String
Dim strSQL As String
Dim booinsert As Boolean
Dim strClinDesc As String
Dim lngPrimKey As Long


    On Error GoTo Error
    Screen.MousePointer = vbHourglass
    mbooLoad = True
    If vstrOCX = "MEDICAL HISTORY" Then
        strOCX = "FN_PP_PastMedHist"
        strCtl = "PastMedical"
        strType = "PROFILER"
    ElseIf vstrOCX = "SUBSTANCE HISTORY" Then
        strOCX = "FN_PsyMse"
        strCtl = "SocialHist"
        strType = "PROFILER"
    ElseIf vstrOCX = "SURGICAL HISTORY" Then
        strOCX = "FN_PP_PastSurg"
        strCtl = "PastSurgery"
        strType = "PROFILER"
    ElseIf vstrOCX = "CURRENT OTC MEDICATION" Then
        strOCX = "FN_PP_PS"
        strCtl = "AddMed"
        strType = "PROFILER"
    ElseIf vstrOCX = "CURRENT MEDICATIONS" Then
        strOCX = "PT_Medications"
        strCtl = "Prescription"
        strType = "PROFILER"
    ElseIf vstrOCX = "CURRENT RX MEDICATIONS" Then
         strOCX = "PT_Medications"
         strCtl = "Prescription"
        strType = "PATIENT"
    ElseIf vstrOCX = "MEDICATION ORDERS" Then
         strOCX = "PT_Medications"
         strCtl = "Prescription"
         strType = "PATIENT"
    ElseIf vstrOCX = "FERTILITY" Then
         strOCX = "FN_ObGyn"
         strCtl = "Infertility"
         strType = "PATIENT"
    ElseIf vstrOCX = "CURRENT MEDICATIONS" Then
         strOCX = "PT_Medications"
         strCtl = "Prescription"
         strType = "PROFILER"
    ElseIf vstrOCX = "MENSTRUAL DISORDER" Then
         strOCX = "FN_ObGyn"
         strCtl = "MensDisorder"
         strType = "PATIENT"
    ElseIf vstrOCX = "PAIN" Then
         strOCX = "FN_ObGyn"
         strCtl = "Pain"
         strType = "PATIENT"
    ElseIf vstrOCX = "INFECTION" Then
         strOCX = "FN_ObGyn"
         strCtl = "INFECTION"
         strType = "PATIENT"
    ElseIf vstrOCX = "BLEEDING" Then
         strOCX = "FN_ObGyn": strCtl = "BLEEDING"
         strType = "PATIENT"
    ElseIf vstrOCX = "FAMILY MEDICAL" Then
         strOCX = "FN_PP_PastMedHist"
         strCtl = "FamilyMedical"
         strType = "PROFILER"
    End If
    intActX_ID = Get_ComponentID(strOCX, strCtl)
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    If PsUserID = vbNullString Then Get_PsUserID (psConnect(0))
    strClinDesc = strOCX & "." & strCtl
    If vstrTag <> "SUBSTANCE HISTORY" Then
        If strType = "PATIENT" Then
            strSQL = "Write_Patient_Clinical " & piPatientID & ", " & piEncounterID & ", " & clsEncounter.ProviderID & "," _
                & intActX_ID & ",'cctSummary', 1, trim(vstrValue), '" & strClinDesc & "',1, '" _
                & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & PsUserID & "'"
            Set rsWrite = cnWrite.Execute(strSQL)
        ElseIf strType = "PROFILER" Then
           If vstrOCX = "CURRENT MEDICATIONS" Then
                lngPrimKey = 0
                strSQL = "Get_Patient_Profiler_Notes_ID " & piEncounterID & ", 'PT_Medications.Prescription', 'CurrentMedication', 1"
                    Set rsWrite = cnWrite.Execute(strSQL)
                    With rsWrite
                        If Not .EOF Then
                            lngPrimKey = (!PROFILER_NOTE_ID)
                        End If
                    End With
                    If lngPrimKey = 0 Then
                        strSQL = "Write_Patient_Profiler_Notes " & piPatientID & ", " & piEncounterID & ", " & intActX_ID & ",'CurrentMedication',1, '" & vstrValue & "', 'PT_Medications.Prescription', 1,'" _
                            & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" & PsUserID & "' "
                            Set rsWrite = cnWrite.Execute(strSQL)
                    Else
                        strSQL = "Update_Patient_Profiler_Note '" & vstrValue & "',1, '" _
                            & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" _
                            & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & lngPrimKey
                            Set rsWrite = cnWrite.Execute(strSQL)
                    End If
            Else
                lngPrimKey = 0
                strSQL = "Get_Patient_Profiler_Notes_ID " & piEncounterID & ", '" & strClinDesc & "', 'cctSummary', 1"
                    Set rsWrite = cnWrite.Execute(strSQL)
                    With rsWrite
                        If Not .EOF Then
                            lngPrimKey = (!PROFILER_NOTE_ID)
                        End If
                    End With
                    If lngPrimKey = 0 Then
                        strSQL = "Write_Patient_Profiler_Notes " & piPatientID & ", " & piEncounterID & ", " & clsEncounter.ProviderID & ", " _
                            & intActX_ID & ",'cctSummary',1, '" & vstrValue & "', '" & strClinDesc & "', 1,'" _
                            & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" & PsUserID & "' "
                            Set rsWrite = cnWrite.Execute(strSQL)
                    Else
                        strSQL = "Update_Patient_Profiler_Note '" & vstrValue & "',1, '" _
                            & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" _
                            & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & lngPrimKey
                            Set rsWrite = cnWrite.Execute(strSQL)
                    End If
             End If
        End If
    End If
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    'need to update the patient_clinical or patient profiler option fields with this data
    Select Case vstrTag
        Case "SUBSTANCE HISTORY"
            lngPrimKey = 0
            If TextFound("denies any pertinent past Alcohol or Substance use history.", vstrValue, Len("denies any pertinent past Alcohol or Substance use history."), True) Then
                strSQL = "Get_Patient_Profiler_ID " & piEncounterID & ", 'FN_PsyMse.SocialHist', 'optDrinkNo', 1"
                Set rsWrite = cnWrite.Execute(strSQL)
                With rsWrite
                    If Not .EOF Then
                        lngPrimKey = (!PROFILER_ID)
                    End If
                End With
                If lngPrimKey = 0 Then
