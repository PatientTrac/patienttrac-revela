                               If Val(.Text) = 1 Then
                                   strText = .TypeCheckText
                                   .GetText 4, lngRow, varCellValue
                                   strText = strText & "|" & varCellValue
                                End If
                                strTag = IsProperCase(.CellTag)
                            End If
                End Select
            End If
            If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
            If Trim(strText) <> vbNullString And strTag <> vbNullString Then
                strSQL = "Get_InPatient_Notes_PT_ID_ENCTR_ID_NOTE_TYPE '" & strTag & "%'," & piPatientID & "," & piEncounterID
                Set rsWrite = cnWrite.Execute(strSQL)
                With rsWrite
