                                strDate = Fld.Value
                            Case "ANNOTATION_IMAGE"
                                clsSentence.Comments = Fld.Value
                        End Select
                    End If
                End If
            Next
        End If
    End With
    If Not bData Then
        If rsLab.State = adStateOpen Then rsLab.Close
        If cnLab.State = adStateClosed Then cnLab.open psConnect(0)
        strSQL = "SELECT CLINICAL_DESC, ANNOTATION_IMAGE FROM " _
            & "ANNOTATIONS WHERE PATIENT_ID = " & piPatientID & " AND " _
            & "ENCOUNTER_ID = " & piEncounterID & " AND ANNOTATION_REF = 'InkSentence'"
        Set rsLab = cnLab.Execute(strSQL)
        With rsLab
            If Not .EOF Then
                bData = True
                Clear_Sentence
                strData = vbNullString
                strInter = vbNullString
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "ANNOTATION_IMAGE"
                                    clsSentence.Comments = Fld.Value
                            End Select
                        End If
                    End If
                Next
            End If
        End With
    End If
    If TextFound("Unable to complete", clsSentence.Comments, Len("Unable to complete"), True) Then
        clsSentence.Comments = Replace(clsSentence.Comments, "Calculated Results", vbNullString)
        clsSentence.Comments = Replace(clsSentence.Comments, "SCORE -", vbNullString)
        clsSentence.Comments = Trim(clsSentence.Comments)
    Else
        clsSentence.Comments = Replace(clsSentence.Comments, "SCORE -", vbNullString)
