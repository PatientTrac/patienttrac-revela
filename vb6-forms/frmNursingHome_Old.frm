Private Function Calc_Prev_MSE_VALUE()
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngEnctr As Long
Dim strDate As String

    
    On Error GoTo Error_Calc_Prev_MSE_VALUE
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    If clsEncounter.StartDate = vbNullString Then
        Get_Encounter piEncounterID
        If clsEncounter.StartDate = vbNullString Then
            strDate = Format(Now, "mm/dd/yyyy")
        Else
            strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
        End If
    Else
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
    End If
    strSQL = "SELECT DISTINCT ENCOUNTER.ENCNTR_START_DATE, ENCOUNTER.ENCOUNTER_ID " _
        & "FROM  PATIENT_ADHD_SCALE " _
        & "INNER JOIN ENCOUNTER ON ENCOUNTER.ENCOUNTER_ID = PATIENT_ADHD_SCALE.ENCOUNTER_ID " _
        & "WHERE PATIENT_ADHD_SCALE.FORM_NAME = 'MMSE' AND " _
        & "PATIENT_ADHD_SCALE.PATIENT_ID = " & piPatientID & "  AND " _
        & "PATIENT_ADHD_SCALE.CLINICAL_VALUE <> '' AND " _
        & "CONVERT(DATETIME, ENCOUNTER.ENCNTR_START_DATE, 101)  < '" & Format(strDate, "mm/dd/yyyy") & "' AND FORM_NAME = 'MMSE' " _
        & "ORDER BY " _
        & "ENCOUNTER.ENCNTR_START_DATE DESC"
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            If Not .EOF Then
                strDate = vbNullString
                lngEnctr = (!Encounter_ID)
                strDate = Format((!ENCNTR_START_DATE), "mm/dd/yyyy")
            End If
        End With
    If lngEnctr > 0 Then
        strSQL = "SELECT SUM(CONVERT(DECIMAL(12,0), PATIENT_ADHD_SCALE.CLINICAL_VALUE, 0)) AS CALC " _
            & "FROM  PATIENT_ADHD_SCALE WHERE ENCOUNTER_ID = " & lngEnctr & "  AND PATIENT_ADHD_SCALE.CLINICAL_VALUE <> '' AND FORM_NAME = 'MMSE'"
            Set rsWrite = cnWrite.Execute(strSQL)
            With rsWrite
                If Not .EOF Then
                    Calc_Prev_MSE_VALUE = (!CALC) & "|" & strDate
                End If
            End With
    Else
        Calc_Prev_MSE_VALUE = vbNullString
    End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_Prev_MSE_VALUE:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Calc_Prev_MSE_VALUE", Me.Name
    Exit Function
    Resume Next
End Function

