Private Function Format_CellType_MSE_Static(vGrid As Object, vlngRow As Long, vlngCol As Long, vstrSpan As String, vstrText As String, vstrHAligh As String, _
Optional vstrCellTag As String, Optional vbooUnderLine As Boolean, Optional vlngBackColor As Long, Optional vstrCellNote As String, Optional vbooCellHeight As Boolean, _
Optional vlngFontSize As Long)
Dim CellNote As Long
Dim lngSpan As Long

    With vGrid
        .sheet = clsGridFormat.SheetNumber
        .BlockMode = True
            .Col = vlngCol
            .Col2 = vlngCol
            .Row = vlngRow
            .Row2 = vlngRow
            .CellType = CellTypeStaticText
            .TypeMaxEditLen = 32000
            .TypeEditMultiLine = True   'Make multi-lines
            .FontName = "Albertus Bold"
            If vlngFontSize > vlngFontSize Then
                .FontSize = 11
            Else
                .FontSize = 0
            End If
            .FontBold = True
            If vbooUnderLine Then .FontUnderline = True
            If vlngBackColor > 0 Then .BackColor = vlngBackColor
            If vstrCellNote <> vbNullString Then .CellNote = vstrCellNote
            If vstrCellTag <> vbNullString Then .CellTag = vstrCellTag
            .TypeVAlign = TypeVAlignCenter
            If vstrHAligh = "TypeHAlignLeft" Then
              .TypeHAlign = TypeHAlignLeft
            Else
              .TypeHAlign = TypeHAlignCenter
            End If
            If TextFound("maxcols", vstrSpan, Len("maxcols"), True) Then
            .AddCellSpan vlngCol, vlngRow, .MaxCols, 1
            ElseIf Trim(vstrSpan) <> vbNullString Then
            lngSpan = vstrSpan
            If lngSpan > 0 Then .AddCellSpan vlngCol, vlngRow, lngSpan, 1
            End If
            .SetText vlngCol, vlngRow, Trim(vstrText)
            .Text = Trim(vstrText)
            If Not vbooCellHeight Then
                CellNote = .MaxTextCellHeight
                If .RowHeight(vlngRow) < CellNote Then
                  .RowHeight(vlngRow) = CellNote + 14
                ElseIf .RowHeight(vlngRow) > CellNote + 10 Then
                    .RowHeight(vlngRow) = CellNote + 14
                End If
            End If
          .BlockMode = False
    End With
End Function
Private Function Get_CellTag_Row(vstrName As String) As String
Dim lngRow As Long
Dim lngCol As Long
Dim varCellValue
Dim booExit As Boolean

    On Error GoTo Error_Get_CellTag_Row
    Screen.MousePointer = vbHourglass
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        Get_CellTag_Row = vbNullString
        For lngRow = 1 To .MaxRows
            For lngCol = 1 To .MaxCols
                .Col = lngCol
                .Row = lngRow
                If .CellTag <> vbNullString Then
                    If Trim(IsProperCase(vstrName)) = Trim(IsProperCase(.CellTag)) Then
                        Get_CellTag_Row = lngCol & "|" & lngRow
                        booExit = True
                        Exit For
                    End If
                End If
            Next lngCol
            If booExit Then Exit For
        Next lngRow
    End With
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_CellTag_Row:
    Screen.MousePointer = vbDefault
   Exit Function
    Resume Next
End Function
