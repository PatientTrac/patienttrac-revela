Private Function Write_AIMS()
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim varCellValue
Dim strDate As String
Dim lngGridPrim As Long
Dim strTag As String
Dim strText As String
Dim strTextNote As String
Dim strRemove As String
Dim iAnswer As Integer
Dim bScale As Boolean

    On Error GoTo Error_Write_AIMS
    Screen.MousePointer = vbHourglass
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    mbooLoad = True
    clsGridFormat.FormName = "AIMS"
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        For lngRow = 1 To .MaxRows
            bScale = False
            clsGridFormat.GridReportID = 0
            strText = vbNullString
            strRemove = vbNullString
            lngGridPrim = 0
            .Col = 1
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If TextFound("_HEADER", .CellTag, Len("_HEADER"), True) Then
                    .GetText 1, lngRow, varCellValue
                    If Trim(varCellValue) <> vbNullString Then
                        strTag = Replace(Trim(varCellValue), ":", "")
                        strTag = Trim(strTag)
                    End If
                End If
            End If
            For lngCol = 3 To grdReport.MaxCols
                .Col = lngCol
                .Row = lngRow
                If .CellTag <> vbNullString Then
                    Select Case Trim(UCase(.CellTag))
                        Case "FACIAL", "JAW", "LIPS", "TONGUE", _
                            "UPPER_EXTREMITY", "LOWER_EXTREMITY", "TRUNK", _
                            "NECK, SHOULDERS", "MOVEMENT", "INCAPACITIES", _
                            "PATIENT_AWARENESS", "TEETH", "DENTURES"
                            bScale = True
                            clsGridFormat.CellTag = UCase(.CellTag)
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                If Val(.Text) = 1 Then
                                    strText = .TypeCheckText
                                End If
                             End If
                    End Select
                End If
            Next lngCol
            strTag = Replace(strTag, "'", "''")
            If Trim(strText) <> vbNullString And bScale Then
                If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
                strSQL = "Get_Patient_Scale_PT_Enct_Form_Name_Row_Name " & piPatientID & "," _
                    & piEncounterID & ",'" & strTag & "','AIMS'"
                    Set rsWrite = cnWrite.Execute(strSQL)
                    If Not rsWrite.EOF Then
                        clsGridFormat.GridReportID = rsWrite.Fields("DEVELOPMENT_ID")
                    End If
                If clsGridFormat.GridReportID = 0 Then
                   strSQL = "Write_Patient_Scale " & piPatientID & "," & piEncounterID & ",'AIMS','" & clsGridFormat.CellTag & "','" _
                       & Trim(strTag) & "','" & Trim(strText) & "','" & Trim(strTextNote) & "','" & strDate & "'"
                       Set rsWrite = cnWrite.Execute(strSQL)
                Else
                   strSQL = "UPDATE PATIENT_ADHD_SCALE SET CLINICAL_VALUE = '" & Trim(strText) & "', " _
                        & "DEVELOPMENT_GROUP = '" & clsGridFormat.CellTag & "', UPDATE_DATE = '" & strDate & "' WHERE DEVELOPMENT_ID = " & clsGridFormat.GridReportID
                       Set rsWrite = cnWrite.Execute(strSQL)
                End If
            End If
        Next lngRow
    End With
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Write_AIMS:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Write_AIMS", Me.Name
    Exit Function
    Resume Next
End Function

