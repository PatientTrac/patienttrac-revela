                        & clsEncounter.ProviderID & "," & clsEncounter.FacilityID & ",'" & clsEncounter.EncounterType & "','" _
                        & Trim(strText) & "','" & strTag & "','" & strDate & "' "
                        Set rsWrite = cnWrite.Execute(strSQL)
                Else
                    strSQL = "Update_InPatient_Notes '" & Trim(strText) & "'," & lngGridPrim
                    Set rsWrite = cnWrite.Execute(strSQL)
                End If
            End If
        Next lngRow
    End With
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
