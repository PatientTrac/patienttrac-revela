Private Function LookUpCPTCode(vstrCPTName As String)
Dim i%
Dim strSQL As String
Dim cnCode As New ADODB.Connection
Dim rsCode As New ADODB.Recordset

    On Error GoTo Error_LookUpCPTCode
    Screen.MousePointer = vbHourglass
    If cnCode.State = adStateClosed Then cnCode.open psConnect(1)
    strSQL = "SELECT * FROM CPT_TEMPLATE WHERE CPT_NAME =  '" & vstrCPTName & "'"
    Set rsCode = cnCode.Execute(strSQL)
    With rsCode
        If Not .EOF Then
            If (!CPT_Code) <> vbNullString Then
                clsPatAcct.CPT_Code = Trim(!CPT_Code)
                udtEncounter.Intrvn_CD = (!CPT_Code)
            End If
            If (!Encntr_Type) <> vbNullString Then
                udtEncounter.EncounterType = (!Encntr_Type)
            End If
        End If
        rsCode.Close
    End With
    If cnCode.State = adStateOpen Then
        Set rsCode = Nothing
        cnCode.Close
        Set cnCode = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_LookUpCPTCode:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "LookUpCPTCode", App.EXEName & "." & "ModPatientData"
    Exit Function
    Resume
End Function

