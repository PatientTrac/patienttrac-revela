    ElseIf vstrPhoto = "SIGNATURE_NURSE" Then
            Get_PlanCollection
            clsSignature.SignReason = clsReport.FollowUp & "|" & clsReport.Instructions & "|" & clsReport.VisitTime & "|" & clsReport.Diagnosis
            If clsSignature.SignReason <> vbNullString Then
                strEncodedSignature = Get_Signature("FN_PsyMse", "Signature", "ccNurseSig", 1, piPatientID, piEncounterID, clsSignature.SignReason)
            Else
                clsSignature.SignReason = Read_Default("FN_PsyMse", "Signature", "txtDefaultReview", mlngLogonUser)
                If Trim(clsSignature.SignReason) <> vbNullString Then
                    strEncodedSignature = Get_Signature("FN_PsyMse", "Signature", "ccNurseSig", 1, piPatientID, piEncounterID, clsSignature.SignReason)
                End If
            End If
            If Trim(strEncodedSignature) <> vbNullString Then
                picSignature.Width = 4000
                picSignature.Height = 1000
                picSignature.BackColor = NormalColor
                booInvalid = ccaSignature.DecodeSignatureValues(strEncodedSignature, clsSignature.SignReason)
                picSignature.Picture = ccaSignature.Picture
                strPhoto = Save_Signature
                SavePicture picSignature.Image, strPhoto
                Format_CellTypeSignature grdReport, lngRow, lngCol, "4", strPhoto, "TypeHAlignCenter", "SIGNATURE_NURSE", 47
            Else
                Format_CellTypeStatic grdReport, lngRow, lngCol, "4", "RESIDENT/CLINICIAN SIGNATURE", "TypeHAlignCenter", "SIGNATURE_NURSE", False, grdGray
            End If
            strRefData = Get_Second_Signature("FN_PsyMse", "Signature", piPatientID, piEncounterID)
            If strRefData <> vbNullString Then
                 Arr = Split(LookUpCellTag("SIGNATURE_MD"), "|")
                If UBound(Arr) > 0 Then
                    lngRow = Arr(1)
                    lngCol = Arr(0)
                End If
                Arr = Split(strRefData, "~")
                If UBound(Arr) > 0 Then
                    If IsNumeric(Arr(1)) Then
                        lngProv = Arr(1)
                        strEncodedSignature = Arr(0)
                        If cnProv.State = adStateClosed Then cnProv.open psConnect(0)
                        strSQL = "SELECT * FROM PROVIDERS WHERE PROVIDER_ID = " & lngProv
                        Set rsProv = cnProv.Execute(strSQL)
                        If Not rsProv.EOF Then
                            If rsProv.Fields("FIRST_NAME") <> vbNullString Then
                                strFirst = rsProv.Fields("FIRST_NAME")
                            ElseIf rsProv.Fields("MIDDLE_NAME") <> vbNullString Then
                                strMiddle = rsProv.Fields("MIDDLE_NAME")
                            ElseIf rsProv.Fields("LAST_NAME") <> vbNullString Then
                                strLast = rsProv.Fields("LAST_NAME")
                            ElseIf Not IsNull(rsProv.Fields("SUFFIX")) Then
                                If rsProv.Fields("SUFFIX") <> vbNullString Then
                                    strSuffix = rsProv.Fields("SUFFIX")
                                End If
                            ElseIf rsProv.Fields("TITLE") <> vbNullString Then
                                strTitle = rsProv.Fields("TITLE")
                            End If
                        End If
                        If Trim(strMiddle) <> vbNullString Then strMiddle = Left(strMiddle, 1)
                        strName = strFirst & " " & strMiddle & " " & strLast
                        If Trim(strSuffix) <> vbNullString Then strName = strName & ",  " & Trim(strSuffix)
                        If Trim(strTitle) <> vbNullString Then strName = strName & ",  " & Trim(strTitle)
                        If cnProv.State = adStateOpen Then
                            cnProv.Close
                            Set cnProv = Nothing
                            Set rsProv = Nothing
                        End If
                        If Trim(strEncodedSignature) <> vbNullString Then
                            picSignature.Width = 4000
                            picSignature.Height = 1000
                            picSignature.BackColor = NormalColor
                            booInvalid = ccaSignature.DecodeSignatureValues(strEncodedSignature, clsSignature.SignReason)
                            picSignature.Picture = ccaSignature.Picture
                            'SavePicture picSignature.Image, App.Path & "\Images\SignNote.bmp"
'                            If FileExists(App.Path & "\Images\SignNote.bmp") Then
'                                SavePicture picSignature.Image, App.Path & "\Images\SignNote.bmp"
'                                strPhoto = App.Path & "\Images\SignNote.bmp"
'                            End If
                            strPhoto = Save_Signature
                            SavePicture picSignature.Image, strPhoto
                            If clsSignature.Physician <> vbNullString Then
                                 Arr = Split(LookUpCellTag("PHYSCIAN_NOTE"), "|")
                                If UBound(Arr) > 0 Then
                                    lngNoteRow = Arr(1)
                                End If
                                If lngNoteRow > 0 Then
                                    Format_CellTypeEdit grdReport, lngNoteRow, lngCol, "4", clsSignature.Physician, "TypeHAlignCenter", "PHYSCIAN_NOTE"
                                    Format_CellTypeSignature grdReport, lngRow, lngCol, "4", strPhoto, "TypeHAlignCenter", "SIGNATURE_MD", 47
                                Else
                                    lngNoteRow = lngRow
                                    Format_CellTypeEdit grdReport, lngNoteRow, lngCol, "4", clsSignature.Physician, "TypeHAlignCenter", "PHYSCIAN_NOTE"
                                    lngNoteRow = lngNoteRow + 1
                                    grdReport.MaxRows = grdReport.MaxRows + 1
                                    grdReport.InsertRows lngRow, 1
                                    Format_CellTypeSignature grdReport, lngNoteRow, lngCol, "4", strPhoto, "TypeHAlignCenter", "SIGNATURE_MD", 47
                                End If
                            Else
                                Format_CellTypeSignature grdReport, lngRow, lngCol, "4", strPhoto, "TypeHAlignCenter", "SIGNATURE_MD", 47
                            End If
                        End If
                    End If
                End If
            End If
    Else
        If vstrCellSpan <> vbNullString Then
            lngCellSpan = Val(vstrCellSpan)
        Else
            lngCellSpan = 1
        End If
        If vlngRow > 0 Then
            lngRow = vlngRow
        Else
            lngRow = 1
        End If
        If vlngCol > 0 Then
            lngCol = vlngCol
        Else
            lngCol = 1
        End If
        If vstrPhoto <> vbNullString And FileExists(vstrPhoto) Then
            Format_CellTypePicture grdReport, lngRow, lngCol, CStr(lngCellSpan), vstrPhoto, "TypeHAlignCenter", "", 75
        End If
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_SetImage:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, vstrPhoto, "SetImage", Me.Name
    Exit Function
    Resume Next
End Function

