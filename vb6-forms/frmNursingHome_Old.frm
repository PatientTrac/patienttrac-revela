'                    Remove_Scales vstrHeader
'                    Remove_Scales clsGridFormat.CellTag
                    Populate_Scales clsGridFormat.CellTag
                    booFound = True
            End Select
            If Not booFound Then
                Values_Psychiatry clsGridFormat.CellTag
                 If Trim(mstrRowData) <> vbNullString Then
                    Arr = Split(LookUpHeaderRow(clsGridFormat.CellTag), "|")
                    If UBound(Arr) > 0 Then
                       lngRow = 0
