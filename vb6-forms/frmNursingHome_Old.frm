        .SetCellBorder 3, lngRow, 3, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
        grdEnctr.sheet = 1
        grdEnctr.ActiveSheet = 1
        Add_Spacer SpreadHeader + 1, grdEnctr
    End With
    lngRow = 0
    If cnEnctr.State = adStateClosed Then cnEnctr.open psConnect(0)
    strSQL = "SELECT * FROM ENCOUNTER WHERE PATIENT_ID = " & piPatientID & " AND " _
        & "(CURRENT_STATE = 'MD COMPLETED' OR CURRENT_STATE = 'WORKUP') AND ENCOUNTER_ID <> " & piEncounterID & " AND PURGE = 0 ORDER BY ENCNTR_START_DATE DESC"
    Set rsEnctr = cnEnctr.Execute(strSQL)
    With rsEnctr
        Do Until .EOF
            lngEnctr = 0
            strEntrDate = vbNullString
            strEnctrType = vbNullString
            strCurState = vbNullString
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "ENCOUNTER_ID"
                                lngEnctr = Fld.Value
                            Case "ENCNTR_START_DATE"
                                strEntrDate = Format(Fld.Value, "mm/dd/yyyy")
                            Case "VISIT_TYPE"
                                strEnctrType = Fld.Value
                            Case "CURRENT_STATE"
                                strCurState = Fld.Value
                        End Select
                    End If
                End If
            Next
            .MoveNext
            If Trim(strEntrDate) <> vbNullString Then
                lngRow = lngRow + 1
                grdEnctr.MaxRows = lngRow
                grdEnctr.SetRowItemData lngRow, lngEnctr
                Format_CellTypeEdit grdEnctr, lngRow, 1, "1", strEntrDate, "TypeHAlignLeft"
                grdEnctr.SetCellBorder 1, lngRow, 1, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                Format_CellTypeEdit grdEnctr, lngRow, 2, "1", strEnctrType, "TypeHAlignLeft"
                grdEnctr.SetCellBorder 2, lngRow, 2, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                Format_CellTypeEdit grdEnctr, lngRow, 3, "1", strCurState, "TypeHAlignLeft"
                grdEnctr.SetCellBorder 3, lngRow, 3, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
            End If
        Loop
    End With
    If cnEnctr.State = adStateOpen Then
        cnEnctr.Close
        Set cnEnctr = Nothing
        Set rsEnctr = Nothing
    End If
    Run_Prev_Patient_Enctr_Batch
    fraEnctr.Visible = True
    fraEnctr.ZOrder 0
    piEncounterID = lngCurEnctr
    Screen.MousePointer = vbDefault
    Exit Function
Error_Create_Prev_Visits:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Create_Prev_Visits", Me.Name
    Exit Function
    Resume Next
End Function

Private Function Encounter_NewVisit()
Dim strSQL As String
Dim cnStatus As New ADODB.Connection
Dim rsStatus As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim lngDateDiff As Long
Dim strEnctTime As String
Dim lngEnctrID As Long
Dim iAnswer As Integer
Dim strDate As String
Dim lngTestProvider As Long
Dim i%
Dim strInsert As String
Dim Idx%
Dim strReadAdmit As String
Dim lngAppt As Long


    On Error GoTo Error_Encounter_NewVisit
    Screen.MousePointer = vbHourglass
    Get_Patient piPatientID
    piEncounterID = 0
    If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
    Get_Providers mlngLogonUser
    udtInPatSched.Appt_Date = Format(ccdPrevDate.Value, "mm/dd/yyyy hh:mm:ss AM/PM")
    With grdFacility
        .Col = 1
        .Row = .ActiveRow
        piFacilityID = .GetRowItemData(.ActiveRow)
    End With
    'If clsEDI_Client.Site_ID = "1999" Then
    If udtInPatSched.Provider_ID = 0 Then udtInPatSched.Provider_ID = mlngLogonUser
    'End If
    udtTime.StartDate = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy 00:00:00 AM/PM")
    udtTime.EndDate = DateAdd("h", 23, udtTime.StartDate)
    udtTime.EndDate = Format(udtTime.EndDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    If piEncounterID = 0 Then
        If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
        strSQL = "SELECT * FROM ENCOUNTER WHERE PATIENT_ID = " & piPatientID & " AND PROVIDER_ID = " & mlngLogonUser & " AND " _
            & "FACILITY_ID  = " & piFacilityID & " AND  PURGE = 0 AND " _
            & "ENCNTR_START_DATE BETWEEN '" & DateAdd("d", -1, Format(mstrRangeDate, "mm/dd/yyyy")) & "' AND '" & Format(udtTime.StartDate, "mm/dd/yyyy") & "'  ORDER BY ENCNTR_START_DATE DESC, CURRENT_STATE"
        Set rsStatus = cnStatus.Execute(strSQL)
        With rsStatus
            Do Until .EOF
                Dump_EncounterStrData
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case Fld.Name
                                Case "CURRENT_STATE"
                                    clsEncounter.Encounter_State = Fld.Value
                                Case "ENCNTR_START_DATE"
                                    clsEncounter.StartDate = Fld.Value
                                Case "RENDERING_PROVIDER"
                                    clsEncounter.RendProv = Fld.Value
                                Case "FACILITY_ID"
                                    clsEncounter.FacilityID = Fld.Value
                                Case "ENCOUNTER_ID"
                                    clsEncounter.EncounterID = Fld.Value
                                Case "VISIT_TYPE"
                                    clsEncounter.VisitType = Fld.Value
                                Case "ENCNTR_TYPE"
                                    clsEncounter.VisitType = Fld.Value
                                Case "INSERT_DATE"
                                    strInsert = Fld.Value
                            End Select
                        End If
                    End If
                Next
                .MoveNext
                If clsEncounter.StartDate = vbNullString Then
                    clsEncounter.EncounterID = 0
                    Dump_EncounterStrData
                Else
                    lngDateDiff = DateDiff("d", Format(udtTime.StartDate, "mm/dd/yyyy"), Format(clsEncounter.StartDate, "mm/dd/yyyy"))
                    If lngDateDiff > 30 Then
                        clsEncounter.EncounterID = 0
                        Dump_EncounterStrData
                    ElseIf lngDateDiff >= -1 And lngDateDiff < 0 Then
                        Exit Do
                    End If
                End If
            Loop
        End With
    Else
        clsEncounter.EncounterID = piEncounterID
    End If
    If lngAppt > 0 Then
        Get_Pat_Appt_Data lngAppt
    Else
        Get_InPatient_Appt_Data
    End If
    ' udtInPatSched.Current_Location
    Get_Facilities piFacilityID
    clsEncounter.FacilityID = piFacilityID
    If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
    If clsEncounter.EncounterID > 0 Then
        piEncounterID = clsEncounter.EncounterID
        If PsUserID = vbNullString Then
            PsUserID = Get_PsUserID(psConnect(0))
        End If
        If clsEncounter.EncounterType <> vbNullString Then udtInPatSched.VisitType = clsEncounter.EncounterType
        Select Case udtInPatSched.VisitType
            Case "Follow-Up", "Subsequent Care", "Subsequent Visit", "Subsequent care, nursing facility E&M, limited", "Follow-Up visit, asst living facility, limited"
                udtInPatSched.PatientType = "Subsequent Care"
                For Idx = 0 To cboPurpose.listcount - 1
                    mbooByPass = True
                    If cboPurpose.List(Idx) = "Follow-Up" Then
                        cboPurpose.Text = cboPurpose.List(Idx)
                        Exit For
                    End If
                Next Idx
                mbooByPass = False
            Case "Initial InPatient", "New Patient", "Initial Visit", "Initial E&M Care, Detailed Visit", "Initial E&M Care, Brief Visit", _
                "Initial E&M Care, Extended Visit", "Initial E&M Care, Complex Visit", "Diagnostic Interview Exam", "Psychiatric Diagnostic Exam"
                udtInPatSched.PatientType = "Initial InPatient"
                strReadAdmit = Is_ReAdmit_Patient
                mbooByPass = True
                If strReadAdmit = "Re-Admission" Then
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Re-Admission" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                Else
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Initial InPatient" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                End If
                mbooByPass = False
        End Select
        If Trim(udtInPatSched.PatientType) <> vbNullString Then
            clsEncounter.EncounterType = udtInPatSched.PatientType
        End If
        If clsEncounter.FacilityID > 0 Then
            Get_Facilities clsEncounter.FacilityID
        End If
        If clsFacility.FacType <> vbNullString Then
            clsEncounter.ServicePlace = clsFacility.FacType
        End If
        If clsFacility.pos <> 0 Then
            clsEncounter.ServicePlaceCode = clsFacility.pos
        End If
        If clsEncounter.ServicePlaceCode = "31" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99307"
                clsEncounter.VisitType = "Subsequent care, nursing facility E&M, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = "99304"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        ElseIf clsEncounter.ServicePlaceCode = "13" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99334"
                clsEncounter.VisitType = "Follow-Up visit, asst living facility, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = " 99325"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        End If
        If clsEncounter.VisitType <> vbNullString Then
            strSQL = "UPDATE ENCOUNTER SET ENCOUNT_CPT_INTRVN = '" & clsEncounter.Intrvn_CD & "', " _
                & "VISIT_TYPE = '" & clsEncounter.VisitType & "' WHERE ENCOUNTER_ID = " & clsEncounter.EncounterID
            Set rsStatus = cnStatus.Execute(strSQL)
        End If
    ElseIf clsEncounter.EncounterID = 0 Then
        If PsUserID = vbNullString Then
            PsUserID = Get_PsUserID(psConnect(0))
        End If
        Select Case udtInPatSched.VisitType
            Case "Follow-Up", "Subsequent Care", "Subsequent Visit", "Subsequent care, nursing facility E&M, limited", "Follow-Up visit, asst living facility, limited"
                udtInPatSched.PatientType = "Subsequent Care"
                For Idx = 0 To cboPurpose.listcount - 1
                    mbooByPass = True
                    If cboPurpose.List(Idx) = "Follow-Up" Then
                        cboPurpose.Text = cboPurpose.List(Idx)
                        Exit For
                    End If
                Next Idx
                mbooByPass = False
            Case "Initial InPatient", "New Patient", "Initial Visit", "Initial E&M Care, Detailed Visit", "Initial E&M Care, Brief Visit", _
                "Initial E&M Care, Extended Visit", "Initial E&M Care, Complex Visit", "Diagnostic Interview Exam"
                udtInPatSched.PatientType = "Initial InPatient"
                strReadAdmit = Is_ReAdmit_Patient
                mbooByPass = True
                If strReadAdmit = "Re-Admission" Then
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Re-Admission" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                Else
                    For Idx = 0 To cboPurpose.listcount - 1
                        mbooByPass = True
                        If cboPurpose.List(Idx) = "Initial InPatient" Then
                            cboPurpose.Text = cboPurpose.List(Idx)
                            Exit For
                        End If
                    Next Idx
                End If
                mbooByPass = False
        End Select
        If Trim(udtInPatSched.PatientType) <> vbNullString Then
            clsEncounter.EncounterType = udtInPatSched.PatientType
        End If
        If clsEncounter.FacilityID > 0 Then
            Get_Facilities clsEncounter.FacilityID
        End If
        If clsFacility.FacType <> vbNullString Then
            clsEncounter.ServicePlace = clsFacility.FacType
        End If
        If clsFacility.pos <> 0 Then
            clsEncounter.ServicePlaceCode = clsFacility.pos
        End If
        If clsEncounter.ServicePlaceCode = "31" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99307"
                clsEncounter.VisitType = "Subsequent care, nursing facility E&M, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = "99304"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        ElseIf clsEncounter.ServicePlaceCode = "13" Then
            If udtInPatSched.PatientType = "Subsequent Care" Then
                clsEncounter.Intrvn_CD = "99334"
                clsEncounter.VisitType = "Follow-Up visit, asst living facility, limited"
            ElseIf udtInPatSched.PatientType = "Initial InPatient" Then
                clsEncounter.Intrvn_CD = " 99325"
                clsEncounter.VisitType = "Initial E&M Care, Brief Visit"
            End If
        End If
        If udtAppointment.VisitType = vbNullString Then udtAppointment.VisitType = clsEncounter.VisitType
        strSQL = "Write_Encounter_Extender " & piPatientID & "," & mlngLogonUser & "," & piFacilityID & ",'" _
            & Format(udtTime.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & clsEncounter.Intrvn_CD & "','" & clsEncounter.VisitType & "','" _
            & clsEncounter.EncounterType & "','" & clsEncounter.ServicePlace & "'," & clsEncounter.ServicePlaceCode & ",'" & PsUserID & "','" _
            & Format(udtTime.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & mlngLogonUser & ",'" & udtAppointment.VisitType & "','MD COMPLETED'"
            Set rsStatus = cnStatus.Execute(strSQL)
            strSQL = "SELECT * FROM ENCOUNTER WHERE PATIENT_ID = " & piPatientID & " AND PROVIDER_ID = " & mlngLogonUser & " AND " _
                & "FACILITY_ID  = " & piFacilityID & " AND  PURGE = 0 AND " _
                & "CONVERT(VARCHAR(10), ENCNTR_START_DATE, 101) = '" & Format(udtTime.StartDate, "mm/dd/yyyy") & "' ORDER BY ENCNTR_START_DATE DESC, CURRENT_STATE"
            Set rsStatus = cnStatus.Execute(strSQL)
            With rsStatus
                If Not .EOF Then
                    clsEncounter.EncounterID = (!Encounter_ID)
                End If
            End With
    End If
    If cnStatus.State = adStateClosed Then cnStatus.open psConnect(0)
    piEncounterID = clsEncounter.EncounterID
    If mstrNewPat Then
        strSQL = "UPDATE ENCOUNTER SET ENCOUNT_CPT_INTRVN = '90801', VISIT_TYPE = 'Psychiatric Diagnostic Exam', " _
            & "NOTE_TYPE = 'SHORT_CONSULT' WHERE ENCOUNTER_ID = " & clsEncounter.EncounterID
        Set rsStatus = cnStatus.Execute(strSQL)
    ElseIf mstrFollowPat Then
        strSQL = "UPDATE ENCOUNTER SET  NOTE_TYPE = 'UNSCHED CONSULT' WHERE ENCOUNTER_ID = " & clsEncounter.EncounterID
        Set rsStatus = cnStatus.Execute(strSQL)
    End If
    Get_Encounter piEncounterID
    modSpecific.piEncounterID = piEncounterID
    Write_SuperBill
    If cnStatus.State = adStateOpen Then
        cnStatus.Close
        Set cnStatus = Nothing
        Set rsStatus = Nothing
        Set Flds = Nothing
    End If
    If clsEncounter.Note_Type = "SHORT_CONSULT" Then
        Add_New_Consult_Grid
    ElseIf clsEncounter.Note_Type = "UNSCHED CONSULT" Then
        Add_Emergency_Follow_Grid
    ElseIf clsEncounter.EncounterType = "Initial InPatient" Or udtInPatSched.Current_Location = "Re-Admission" Then
        mbooByPass = True
        If clsEncounter.EncounterType = "Initial InPatient" And Trim(udtInPatSched.Current_Location) = vbNullString Then
        For Idx = 0 To cboPurpose.listcount - 1
            If cboPurpose.List(Idx) = clsEncounter.EncounterType Then
                cboPurpose.Text = cboPurpose.List(Idx)
                Exit For
            End If
        Next Idx
        ElseIf udtInPatSched.Current_Location = "Re-Admission" Then
            For Idx = 0 To cboPurpose.listcount - 1
                If cboPurpose.List(Idx) = udtInPatSched.Current_Location Then
                    cboPurpose.Text = cboPurpose.List(Idx)
                    Exit For
                End If
            Next Idx
        End If
        If grdReport.SheetCount = 2 Then
            clsGridFormat.SheetNumber = 2
        ElseIf grdReport.SheetCount > 2 Then
            clsGridFormat.SheetNumber = clsGridFormat.SheetNumber + 1
        End If
        clsGridFormat.SheetNumber = 1
        grdReport.SheetCount = 2
        grdReport.sheet = clsGridFormat.SheetNumber
        Format_Headers
        Get_Values
        clsGridFormat.SheetNumber = 2
        grdReport.SheetCount = clsGridFormat.SheetNumber
        grdReport.sheet = clsGridFormat.SheetNumber
        clsGridFormat.SheetName = "PAST AND SOCIAL"
        Add_Initial_Grid
    Else
        mbooByPass = True
        For Idx = 0 To cboPurpose.listcount - 1
            If cboPurpose.List(Idx) = clsEncounter.EncounterType Then
                cboPurpose.Text = cboPurpose.List(Idx)
                Exit For
            End If
        Next Idx
        grdReport.SheetCount = 2
        Format_Headers
        Get_Values
        clsGridFormat.SheetNumber = 2
        grdReport.SheetCount = clsGridFormat.SheetNumber
        grdReport.sheet = clsGridFormat.SheetNumber
        clsGridFormat.SheetName = "MMSE"
        grdReport.SheetName = clsGridFormat.SheetName
        Format_MMMSE
    End If
    mbooByPass = False
    Get_Patient piPatientID
    udtInPatSched.Status = "Present"
    Update_InPatient_Status
    Get_Psychiatry
    grdReport.sheet = 1
    grdReport.ActiveSheet = 1
    clsGridFormat.SheetNumber = 1
    Picture1.Visible = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Encounter_NewVisit:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Encounter_NewVisit", Me.Name
    Exit Function
    Resume Next
End Function

