Private Function Add_History(vlngRow As Long, vstrCellTag As String)
Dim Arr
Dim Idx%
Dim lngRow As Long
Dim strCellTag As String
Dim lngCnt As Long

    If vlngRow = 0 Then Exit Function
    clsGridFormat.Text = vbNullString
    strCellTag = vstrCellTag
    mbooLoad = True
    lngRow = vlngRow
    With grdReport
        Arr = Split(Trim(mstrRowData), vbNewLine)
        If UBound(Arr) > 0 Then
            For Idx = LBound(Arr) To UBound(Arr)
                clsGridFormat.Text = vbNullString
                If Trim(Arr(Idx)) <> vbNullString Then
                    lngCnt = lngCnt + 1
                End If
                If lngCnt = 1 Then
                    clsGridFormat.Text = Arr(Idx)
                    Format_CellTypeSplit grdReport, lngRow, 2, "5", Trim(clsGridFormat.Text), "TypeHAlignLeft", "CURRENT HISTORY"
                ElseIf lngCnt > 1 Then
                    clsGridFormat.Text = Arr(Idx)
                    If Trim(clsGridFormat.Text) <> vbNullString Then
                        lngRow = lngRow + 1
                        .RemoveCellSpan 2, lngRow
                        grdReport.InsertRows lngRow, 1
                        grdReport.MaxRows = grdReport.MaxRows + 1
                        Format_CellTypeSplit grdReport, lngRow, 2, "5", Trim(clsGridFormat.Text), "TypeHAlignLeft", "CURRENT HISTORY"
                    End If
                End If
            Next Idx
        Else
            Format_CellTypeEdit grdReport, lngRow, 2, "5", Trim(mstrRowData), "TypeHAlignLeft", "CURRENT HISTORY"
        End If
    End With
    mbooLoad = False
    Exit Function
End Function
Private Function Read_Checkbox_Scales()
Dim strSQL As String
Dim cnDevelop As New ADODB.Connection
Dim rsDevelop As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim strBullet As String
Dim lngDateDiff As Long
Dim strData As String
Dim strEnctrDate As String
Dim bData As Boolean
Dim lngRow As Long
Dim lngCol As Long


    On Error GoTo Error_Read_Checkbox_Scales
    If cnDevelop.State = adStateClosed Then cnDevelop.open psConnect(0)
    strSQL = "Get_Patient_Scale_PT_Enct_Form_Name " & piPatientID & "," & piEncounterID & ",'" & clsGridFormat.FormName & "'"
    Set rsDevelop = cnDevelop.Execute(strSQL)
    With rsDevelop
        Do Until .EOF
            clsGridFormat.CellTag = vbNullString
            clsGridFormat.RowName = vbNullString
            clsGridFormat.Text = vbNullString
            clsGridFormat.TextNote = vbNullString
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "DEVELOPMENT_GROUP"
                                clsGridFormat.CellTag = Fld.Value
                            Case "ROW_NAME"
                                clsGridFormat.RowName = Fld.Value
                            Case "CLINICAL_VALUE"
                                clsGridFormat.Text = Fld.Value
                            Case "CLINICAL_NOTE"
                                clsGridFormat.TextNote = Fld.Value
                        End Select
                    End If
                End If
            Next
            .MoveNext
            With grdReport
                .sheet = clsGridFormat.SheetNumber
                For lngRow = 1 To .MaxRows
'                    For lngCol = 1 To .MaxCols
                        .Col = 2
                        .Row = lngRow
                        If .CellTag <> vbNullString Then
                            If Trim(IsProperCase(.CellTag)) = Trim(IsProperCase(clsGridFormat.CellTag)) Then
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(clsGridFormat.Text) <> vbNullString And Trim(clsGridFormat.Text) = Trim(.TypeCheckText) Then
                                        .Text = "1"
                                        Exit For
                                    End If
                                End If
                            End If
                        End If
'                    Next lngCol
                Next lngRow
            End With
        Loop
    End With
    If cnDevelop.State = adStateOpen Then
        cnDevelop.Close
        Set cnDevelop = Nothing
        Set rsDevelop = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Checkbox_Scales:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_Checkbox_Scales", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Recalculate_MMSE()
Dim lngRow As Long
Dim lngData As Long
Dim strTag As String
Dim lngCol As Long
Dim Arr


    On Error Resume Next
    
    With grdReport
        Clear_MMSE_Score
        mbooLoad = True
        .sheet = 2
        .ActiveSheet = 2
        For lngRow = 1 To .MaxRows
            .Col = 1
            .Row = lngRow
            If .CellTag <> vbNullString Then
                strTag = Replace(.CellTag, "-", "")
                strTag = IsProperCase(strTag)
                strTag = Trim(strTag)
                lngData = 0
                Select Case Trim(IsProperCase(strTag))
                    Case "Time"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Time = clsMMSE_Score.Time + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Time > -1 Then
                            Arr = Split(Get_CellTag_Row("TIME_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(5/" & clsMMSE_Score.Time & ")", "TypeHAlignleft", "TIME_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Time
                    Case "Place"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Place = clsMMSE_Score.Place + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Place > -1 Then
                            Arr = Split(Get_CellTag_Row("PLACE_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(5/" & clsMMSE_Score.Place & ")", "TypeHAlignleft", "PLACE_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Place
                    Case "Immediate Recall", "Immediate_recall", "Immediate_Recall"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Immediate_Recall = clsMMSE_Score.Immediate_Recall + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Immediate_Recall > -1 Then
                            Arr = Split(Get_CellTag_Row("IMMEDIATE_RECALL_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(3/" & clsMMSE_Score.Immediate_Recall & ")", "TypeHAlignleft", "IMMEDIATE_RECALL_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Immediate_Recall
                    Case "Delayed Recall", "Delayed_recall", "Delayed_Recall"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Delayed_Recall = clsMMSE_Score.Delayed_Recall + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Immediate_Recall > -1 Then
                            Arr = Split(Get_CellTag_Row("DELAYED_RECALL_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(3/" & clsMMSE_Score.Delayed_Recall & ")", "TypeHAlignleft", "DELAYED_RECALL_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Delayed_Recall
                    Case "Calculation", "Serial 7 Calculation"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Serial_7 = clsMMSE_Score.Serial_7 + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Serial_7 > -1 Then
                            Arr = Split(Get_CellTag_Row("CALCULATION_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(5/" & clsMMSE_Score.Serial_7 & ")", "TypeHAlignleft", "CALCULATION_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Serial_7
                    Case "Attention"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Attention = clsMMSE_Score.Attention + Val(.Text)
                            End If
                        Next lngCol
                        If clsMMSE_Score.Attention > -1 Then
                            Arr = Split(Get_CellTag_Row("ATTENTION_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(5/" & clsMMSE_Score.Attention & ")", "TypeHAlignleft", "ATTENTION_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Attention
                    Case "Naming"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Naming = clsMMSE_Score.Naming + Val(.Text)
                            End If
                        Next lngCol
                        If clsMMSE_Score.Naming > -1 Then
                            Arr = Split(Get_CellTag_Row("NAMING_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(2/" & clsMMSE_Score.Naming & ")", "TypeHAlignleft", "NAMING_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Naming
                    Case "3 Stage Command", "3stage Command"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Three_Stage = clsMMSE_Score.Three_Stage + Val(.Text)
                            End If
                        Next lngCol
                        If clsMMSE_Score.Three_Stage > -1 Then
                            Arr = Split(Get_CellTag_Row("3 STAGE COMMAND SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(3/" & clsMMSE_Score.Three_Stage & ")", "TypeHAlignleft", "3 STAGE COMMAND SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Three_Stage
                    Case "Reading"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Reading = clsMMSE_Score.Reading + Val(.Text)
                            End If
                        Next lngCol
                        If clsMMSE_Score.Reading > -1 Then
                            Arr = Split(Get_CellTag_Row("READING_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(1/" & clsMMSE_Score.Reading & ")", "TypeHAlignleft", "READING_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Reading
                    Case "Repetition"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Repetition = clsMMSE_Score.Repetition + Val(.Text)
                            End If
                        Next lngCol
                        If clsMMSE_Score.Reading > -1 Then
                            Arr = Split(Get_CellTag_Row("REPETITION_SCORE"), "|")
