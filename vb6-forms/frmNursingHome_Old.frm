Dim IsSpan As Boolean

    ' Get the selected cells
    grdReport.getSelection 0, Col, Row, Col2, Row2

    ' Check to see if cells are already in span
    For i = 1 To grdReport.MaxCols
        For j = 1 To grdReport.MaxRows
            Span = grdReport.GetCellSpan(i, j, anchorcol, anchorrow, colspan, rowspan)
            If Span Then
                If grdReport.Col = 1 Then anchorcol = "1"
                If j = 1 Then anchorrow = 1
                If j = 1 + 1 Then anchorrow = 1 + 1
                If j = 1 + 2 Then anchorrow = 1 + 2
                grdReport.RemoveCellSpan anchorcol, anchorrow
                IsSpan = True
            End If
        Next j
    Next i
    
    Exit Function
    
End Function
