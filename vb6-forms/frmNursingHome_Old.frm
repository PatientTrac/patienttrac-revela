Private Function Format_CellTypeCheckBox(vGrid As Object, vlngRow As Long, vlngCol As Long, vstrSpan As String, vstrText As String, vstrHAligh As String, _
Optional vstrCellTag As String, Optional vbooUnderLine As Boolean, Optional vlngBackColor As Long, Optional vstrValue As Long, _
Optional vstrCellNote As String, Optional vlngFontSize As Long, Optional vstrCheckAligh As String)
Dim CellNote As Long
Dim lngSpan As Long

    With vGrid
        .sheet = clsGridFormat.SheetNumber
        .BlockMode = True
            .Col = vlngCol
            .Col2 = vlngCol
            .Row = vlngRow
            .Row2 = vlngRow
            .CellType = CellTypeCheckBox
            .FontName = "Albertus Bold"
            If vlngFontSize > 0 Then
                .FontSize = vlngFontSize
            Else
                .FontSize = 11
            End If
            .FontBold = True
            .TypeCheckType = TypeCheckTypeNormal
            If vbooUnderLine Then .FontUnderline = True
            If vstrCellNote <> vbNullString Then .CellNote = vstrCellNote
            If vstrCellTag <> vbNullString Then .CellTag = vstrCellTag
            .TypeVAlign = TypeVAlignTop
            If vstrHAligh = "TypeHAlignCenter" Then
              .TypeHAlign = TypeHAlignCenter
            Else
              .TypeHAlign = TypeHAlignLeft
            End If
            If TextFound("maxcols", vstrSpan, Len("maxcols"), True) Then
                .AddCellSpan vlngCol, vlngRow, .MaxCols, 1
            ElseIf Trim(vstrSpan) <> vbNullString Then
                lngSpan = vstrSpan
                If lngSpan > 0 Then .AddCellSpan vlngCol, vlngRow, lngSpan, 1
            End If
            If vstrCheckAligh <> vbNullString Then
                .TypeCheckTextAlign = vstrCheckAligh
            End If
            .CellType = CellTypeCheckBox
            .TypeCheckText = Trim(vstrText)
            .Text = vstrValue
          .BlockMode = False
    End With
End Function


