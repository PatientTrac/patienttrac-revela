Private Function Add_Patient_Photo(vlngStart As Long, vObjGrid As Object)
Dim fso As New FileSystemObject
Dim lngStart As Long

    lngStart = vlngStart
    psImageFilePath = QueryValue(HKEY_LOCAL_MACHINE, psRegGeneral, "ImagePath")
    If psImageFilePath = vbNullString Then
       psImageFilePath = "C:\"
    End If
    If fso.FileExists(psImageFilePath & piPatientID & "\Photo.jpg") Then
        psPhoto = psImageFilePath & piPatientID & "\Photo.jpg"
        Add_Patient_Photo_Grid vObjGrid, lngStart, 6, psPhoto, vObjGrid.MaxRows, "PATIENT_PHOTO"
    End If
    Exit Function
End Function

Private Function Add_Patient_Photo_Grid(vGrid As Object, vlngRow As Long, vlngCol As Long, vstrPhotoPath As String, vlngSpan As Long, Optional vstrCellTag As String)
Dim CellNote As Long
Dim lngSpan As Long

    lngSpan = vlngSpan
    With vGrid
        .sheet = clsGridFormat.SheetNumber
        .ActiveSheet = .sheet
        .BlockMode = True
            .Col = vlngCol
            .Col2 = vlngCol
            .Row = vlngRow
            .Row2 = vlngRow
            .RowHeight(vlngRow) = 25
            .RowHeight(vlngRow + 1) = 25
            .CellType = CellTypePicture
            .TypePictCenter = True
            lngSpan = lngSpan - vlngRow
            .AddCellSpan vlngCol, vlngRow, 2, lngSpan
            If FileExists(vstrPhotoPath) Then
                .TypePictPicture = LoadPicture(vstrPhotoPath)
            End If
            If vstrCellTag <> vbNullString Then .CellTag = vstrCellTag
          .BlockMode = False
    End With
End Function

Private Function Add_Print_Header()
Dim CellNote As Long
Dim strPhoto As String
Dim Idx As Integer
Dim cnHead As New ADODB.Connection
Dim rsHead As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim strSQL As String
Dim fso As New FileSystemObject
Dim strHeader As String
Dim lngFac As Long

    On Error GoTo Error_Add_Print_Header
    Screen.MousePointer = vbHourglass
    lngFac = piFacilityID
    mbooLoad = True
    If clsEDI_Client.Site_ID = "1999" Then
        Get_Nursing_Facility
    ElseIf clsEncounter.FacilityID = 0 Then
         Get_Bill_Facility
        Get_ReportFacility clsFacility.BillFacility
    Else
        Get_ReportFacility clsEncounter.FacilityID
    End If
    With grdPrintForm
        mbooLoad = True
        .sheet = clsGridFormat.SheetNumber
        .ActiveSheet = .sheet
        .InsertRows 1, 2
        .MaxRows = .MaxRows + 2
    End With
    piFacilityID = lngFac
    clsGridFormat.FormName = vbNullString
    grdPrintForm.RemoveCellSpan 2, 1
    grdPrintForm.ClearRange 1, 1, grdPrintForm.MaxCols, 1, False
    mbooLoad = True
    If udtFacility.Logo <> vbNullString Then
        udtFacility.Logo = Replace(udtFacility.Logo, "C:\Program Files (x86) (x86)", "C:\Program Files (x86)")
        If FileExists(udtFacility.Logo) Then
            Format_CellTypePicture grdPrintForm, 1, 1, "1", udtFacility.Logo, "TypeHAlignCenter", "", 73
            Format_CellTypeEdit grdPrintForm, 1, 2, "maxcols", udtFacility.FacHeader, "TypeHAlignCenter", "", False, 0, "", 73, 14, "Arial Black"
            grdPrintForm.SetCellBorder 2, 1, grdPrintForm.MaxCols, 1, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Else
            Format_CellTypeEdit grdPrintForm, 1, 1, "maxcols", udtFacility.FacHeader, "TypeHAlignCenter", "", False, 0, "", 73, 14, "Arial Black"
            grdPrintForm.SetCellBorder 1, 1, grdPrintForm.MaxCols, 1, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        End If
    Else
        Format_CellTypeEdit grdPrintForm, 1, 1, "maxcols", udtFacility.FacHeader, "TypeHAlignCenter", "", False, 0, "", 73, 14, "Arial Black"
        grdPrintForm.SetCellBorder 1, 1, grdPrintForm.MaxCols, 1, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
    End If
    If cnHead.State = adStateOpen Then
        cnHead.Close
        Set cnHead = Nothing
        Set Flds = Nothing
    End If
    mbooLoad = True
    Add_Spacer 2, grdPrintForm
    Screen.MousePointer = vbDefault
    Exit Function
Error_Add_Print_Header:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Add_Print_Header", Me.Name
    Exit Function
    Resume Next
End Function

Private Function Calculate_Batch_CDR_Data()
Dim lngRow As Long
Dim lngCol As Long
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngCal As Double
Dim strCase As String
Dim Arr

    
    On Error GoTo Error_Calc_CDR
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    
    strSQL = "SELECT DISTINCT ROW_NAME, DEVELOPMENT_GROUP, CLINICAL_VALUE FROM  PATIENT_ADHD_SCALE WHERE FORM_NAME = 'CLINICAL DEMENTIA RATING' AND " _
        & "PATIENT_ID = " & piPatientID & "  AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND CLINICAL_VALUE <> '' AND (ROW_NAME <> 'CDR_SCORE' AND ROW_NAME <> 'CDR_INTERPRETATION')"
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            Do Until .EOF
                clsGridFormat.CellTag = vbNullString
                clsGridFormat.TextNote = vbNullString
                If Not IsNull((!ROW_NAME)) Then
                    clsGridFormat.RowName = UCase((!ROW_NAME))
                End If
                If Not IsNull((!DEVELOPMENT_GROUP)) Then
                    clsGridFormat.CellTag = UCase((!DEVELOPMENT_GROUP))
                End If
                If Not IsNull((!CLINICAL_VALUE)) Then
                    clsGridFormat.Text = UCase((!CLINICAL_VALUE))
                End If
                .MoveNext
                Select Case UCase(clsGridFormat.Text)
                    Case "NONE"
                        clsGridFormat.TextNote = "0"
                    Case "QUESTIONABLE"
                        clsGridFormat.TextNote = "0.5"
                    Case "MILD"
                        clsGridFormat.TextNote = "1"
                    Case "MODERATE"
                        clsGridFormat.TextNote = "2"
                    Case "SEVERE"
                        clsGridFormat.TextNote = "3"
                End Select
                lngCal = lngCal + Val(clsGridFormat.TextNote)
            Loop
        End With
        strCase = CStr(lngCal)
        clsGridFormat.CellNote = vbNullString
        Select Case Format(strCase, "##.0")
            Case "0.0"
                clsGridFormat.CellNote = "Normal"
'            Case "0.5", "4.5"
'                clsGridFormat.CellNote = "Questionable cognitive impairment"
            Case "0.5", "1.0", "1.5", "2.0", "2.5"
                clsGridFormat.CellNote = "Questionable impairment"
            Case "3.0", "3.5", "4.0"
                clsGridFormat.CellNote = "Very mild dementia"
            Case "4.5", "5.0", "5.5", "6.0", "6.5", "7.0", "7.5", "8.0", "8.5", "9.0"
                clsGridFormat.CellNote = "Very mild dementia"
            Case "9.5", "10", "10.5", "11", "11.5", "12", "12.5", "13", "13.5", "14.0", "14.5", "15.0"
                clsGridFormat.CellNote = "Moderate dementia"
            Case "16.0", "16.5", "17.0", "17.5", "18.00"
                clsGridFormat.CellNote = "Severe dementia"
        End Select
        Arr = Split(LookUpCellTag("CDR_SCORE"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
            If lngRow > 1 Then
                lngCol = 2
                Format_CellTypeEdit grdPrintForm, lngRow, lngCol, "1", "( " & Format(strCase, "##.0") & "/18.00 )", "TypeHAlignLeft", "CDR_SCORE"
                clsGridFormat.TextNote = strCase
                clsGridFormat.RowName = "CDR_SCORE"
                clsGridFormat.CellTag = "CDR_SCORE"
                Write_CDR_Grid
                lngCol = 3
                Format_CellTypeEdit grdPrintForm, lngRow, lngCol, "1", clsGridFormat.CellNote, "TypeHAlignLeft", "CDR_INTERPRETATION"
                clsGridFormat.TextNote = clsGridFormat.CellNote
                clsGridFormat.RowName = "CDR_INTERPRETATION"
                clsGridFormat.CellTag = "CDR_INTERPRETATION"
                Write_CDR_Grid
            End If
        End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_CDR:
    Screen.MousePointer = vbDefault
