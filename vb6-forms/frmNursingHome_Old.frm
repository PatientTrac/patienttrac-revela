    Screen.MousePointer = vbHourglass
    With grdReport
        clsGridFormat.SheetNumber = 1
        .sheet = clsGridFormat.SheetNumber
        .SheetName = "EVALUATION"
        .ReDraw = False
        .ProcessTab = True
        .FontBold = True
        .FontName = "Albertus Bold"
        .FontSize = 11
        .GridSolid = False
        .GridShowHoriz = False
        .GridShowVert = False
        .RowHeadersShow = False
        .ColHeadersShow = False
        .ColHeadersAutoText = DispBlank
        .PrintBorder = False
        .ColHeaderRows = 0
        .MaxCols = 7
        .FontBold = True
        .ColWidth(1) = 25
        .ColWidth(2) = 18
        .ColWidth(3) = 17
        .ColWidth(4) = 17
        .ColWidth(5) = 18
        .ColWidth(6) = 17
        .ColWidth(7) = 17
        .MaxRows = lngRow
        Add_Spacer lngRow, grdReport
         lngRow = lngRow + 1
        .MaxRows = lngRow
         lngRow = lngRow + 1
        .MaxRows = lngRow
        Add_Spacer lngRow, grdReport
         lngRow = lngRow + 1
        .Row = lngRow
        .MaxRows = lngRow
        lngStart = lngRow
        Format_CellTypeEdit grdReport, lngRow, 1, "1", "PATIENT NAME", "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 2, "2", clsPatient.Name, "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 4, "1", "EMR NO.", "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 5, "1", clsPatient.IntId, "TypeHAlignLeft", "", False, 0, "", True
         lngRow = lngRow + 1
        .Row = lngRow
        .MaxRows = lngRow
        clsPatient.DOB = Format(clsPatient.DOB, "mmmm dd , yyyy")
        If clsEncounter.Provider = vbNullString Then
            Get_EnctrProviderName mlngLogonUser
        End If
        Format_CellTypeEdit grdReport, lngRow, 1, "1", "DATE OF BIRTH", "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 2, "2", clsPatient.DOB, "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 4, "1", "PROVIDER NAME", "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 5, "1", clsEncounter.Provider, "TypeHAlignLeft", "", False, 0, "", True
        lngRow = lngRow + 1
        .Row = lngRow
        .MaxRows = lngRow
        Format_CellTypeEdit grdReport, lngRow, 1, "1", "FACILITY", "TypeHAlignLeft", "FACILITY_NAME", False, 0, "", True
        Format_CellTypeEdit grdReport, lngRow, 2, "2", UCase(cctFacility.Text), "TypeHAlignLeft"
        Format_CellTypeEdit grdReport, lngRow, 4, "1", "ROOM NUMBER", "TypeHAlignLeft", "", False, 0, "", True
        If clsPatient.RoomNumber = vbNullString Then clsPatient.RoomNumber = udtInPatSched.RoomNumber
        Format_CellTypeEdit grdReport, lngRow, 5, "1", clsPatient.RoomNumber, "TypeHAlignLeft", "", False, 0, "", True
         lngRow = lngRow + 1
        .MaxRows = lngRow
      If TextFound("ADMISSION", clsEncounter.VisitReason, Len("ADMISSION"), True) Or _
            TextFound("DISCHARGE", clsEncounter.VisitReason, Len("DISCHARGE"), True) Then
            Format_CellTypeEdit grdReport, lngRow, 1, "1", "ADMISSION DATE", "TypeHAlignLeft"
            If clsEncounter.Admission <> vbNullString Then
                Format_CellTypeEdit grdReport, lngRow, 2, "2", Format(clsEncounter.Admission, "mmmm dd, yyyy"), "TypeHAlignLeft", "", False, 0, "", True
            End If
      End If
      If TextFound("DISCHARGE", clsEncounter.VisitReason, Len("Discharge"), True) Then
            Format_CellTypeEdit grdReport, lngRow, 4, "1", "DISCHARGE DATE", "TypeHAlignLeft", "", False, 0, "", True
            clsEncounter.StartDate = Format(clsEncounter.StartDate, "mmmm dd , yyyy")
            Format_CellTypeEdit grdReport, lngRow, 5, "1", clsEncounter.Discharge, "TypeHAlignLeft", "", False, 0, "", True
        Else
            Format_CellTypeEdit grdReport, lngRow, 4, "1", "VISIT DATE", "TypeHAlignLeft", "", False, 0, "", True
            clsEncounter.StartDate = Format(clsEncounter.StartDate, "mmmm dd , yyyy")
            Format_CellTypeEdit grdReport, lngRow, 5, "1", clsEncounter.StartDate, "TypeHAlignLeft", "", False, 0, "", True
        End If
      If TextFound("CONSULTATION", strReportName, Len("CONSULTATION"), True) And mstrPractice <> vbNullString Then
