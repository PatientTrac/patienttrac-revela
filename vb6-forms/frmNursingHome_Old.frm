Dim strReportName As String
Dim lngRow As Long
Dim lngStart As Long
Dim lngEnctr As Long
Dim lngEnd As Long

    On Error GoTo Error_Format_Headers
    fpImagePhoto = vbNullString
    fpImageFacility = vbNullString
    lngEnctr = piEncounterID
    If clsEncounter.StartDate = vbNullString Then Get_Encounter lngEnctr
    lngRow = 1
