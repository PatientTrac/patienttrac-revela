    udtEM_Value.Staff_Discuss = vbNullString
    udtEM_Value.Medication_Evaluation = vbNullString
    udtEM_Value.System_Review = vbNullString
    udtEM_Value.RecRev = vbNullString
    With grdReport
          For lngCol = 2 To .MaxCols
            .Col = lngCol
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If UCase(.CellTag) = "RECORD REVIEW" Then
                    If .CellType = CellTypeCheckBox Then
                        Select Case IsProperCase(.TypeCheckText)
                            Case "Chart Reviewed"
                                .Col = lngCol
                                .Row = lngRow
                                If .Text = "1" Then
                                    udtEM_Value.RecRev = "Chart Reviewed"
                                End If
                            Case "Case Discussed with Staff", "Case Discussed With Staff"
                                .Col = lngCol
                                .Row = lngRow
                                If .Text = "1" Then
                                    udtEM_Value.Staff_Discuss = "Case Discussed with Staff"
                                End If
                            Case "Medication Evaluation Rendered"
                                .Col = lngCol
                                .Row = lngRow
                                If .Text = "1" Then
                                    udtEM_Value.Medication_Evaluation = "Medication Evaluation Rendered"
                                End If
                            Case "Systems Review"
                                .Col = lngCol
                                .Row = lngRow
                                If .Text = "1" Then
                                    udtEM_Value.System_Review = "Systems Review"
                                End If
                        End Select
                    End If
                End If
            End If
          Next lngCol
    End With
    Screen.MousePointer = vbHourglass
    If cnPlan.State = adStateClosed Then cnPlan.open psConnect(0)
    strSQL = "Get_Evaluation_Management " & piPatientID & "," & piEncounterID
        Set rsPlan = cnPlan.Execute(strSQL)
        If Not rsPlan.EOF Then
            lngPrimKey = rsPlan.Fields("EM_ID")
