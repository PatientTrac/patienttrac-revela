       End If
        For lngRow = 4 To 8
              grdPrintForm.SetCellBorder 7, lngRow, 7, lngRow, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Next lngRow
        Add_Spacer lngRow, grdPrintForm
        .ReDraw = True
    End With
    Select Case clsEncounter.EncounterType
        Case "Follow-Up", "Subsequent Care"
            Format_CellTypeEdit grdPrintForm, 3, 1, "maxcols", "PATIENT SUBSEQUENT PROGRESS NOTE", "TypeHAlignCenter", "", False, HeaderColor
            grdPrintForm.SetCellBorder 1, 3, 7, 3, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Case "Initial InPatient"
            Format_CellTypeEdit grdPrintForm, 3, 1, "maxcols", "INITIAL PATIENT EVALUATION", "TypeHAlignCenter", "", False, HeaderColor
            grdPrintForm.SetCellBorder 1, 3, 7, 3, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
        Case "Re-Admission"
        Case "Initial InPatient"
            Format_CellTypeEdit grdPrintForm, 3, 1, "maxcols", "RE-ADMISSION PATIENT EVALUATION", "TypeHAlignCenter", "", False, HeaderColor
            grdPrintForm.SetCellBorder 1, 3, 7, 3, CellBorderIndexRight, GridBlue, CellBorderStyleSolid
    End Select
    mbooLoad = True
    Screen.MousePointer = vbDefault
Exit Function
Error_Format_Headers:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "FormatHeaders", Me.Name
    Exit Function
    Resume Next
End Function

