            & "ENCOUNTER_ID = " & piEncounterID & " AND ROW_NAME = '" & strRow & "'"
        Set rsRelation = cnRelation.Execute(strSQL)
        With rsRelation
            If Not .EOF Then
                lngPrim = (!GRID_ID)
            End If
        End With
        If lngPrim = 0 Then
            strSQL = "INSERT INTO PATIENT_SUB_ABUSE (PATIENT_ID, ENCOUNTER_ID, ROW_NAME, CLINICAL_NOTE, " _
                & "INSERT_DATE) VALUES (" & piPatientID & ", " & piEncounterID & ", '" _
                & strRow & "','" & Trim(strCollection) & "', '" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "') "
            Set rsRelation = cnRelation.Execute(strSQL)
        Else
            strSQL = "UPDATE PATIENT_SUB_ABUSE SET CLINICAL_NOTE = '" & Trim(strCollection) & "' WHERE  GRID_ID = " & lngPrim
            Set rsRelation = cnRelation.Execute(strSQL)
        End If
    End If
    If cnRelation.State = adStateOpen Then
        cnRelation.Close
        Set cnRelation = Nothing
