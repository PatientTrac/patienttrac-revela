                                    If UBound(Arr) > 0 Then
                                        lngRow = Arr(1)
                                         If lngRow > 0 Then
                                            Format_CellTypeEdit grdReport, lngRow, 2, "maxcols", clsGridFormat.Text, "TypeHAlignLeft", "ESTIMATED LENGTH OF STAY"
                                        End If
                                    End If
                                Case "INITIAL DISCHARGE", "INITIAL DISCHARGE PLAN / AFTERCARE TREATMENT"
                                    Arr = Split(LookUpHeaderRow("INITIAL DISCHARGE"), "|")
                                    If UBound(Arr) > 0 Then
                                        lngRow = Arr(1)
                                         If lngRow > 0 Then
                                            Format_CellTypeEdit grdReport, lngRow, 2, "maxcols", clsGridFormat.Text, "TypeHAlignLeft", "INITIAL DISCHARGE"
                                        End If
                                    End If
                                Case "GRID_NOTE"
                                    mstrGridNote = clsGridFormat.Text
                            End Select
                        ElseIf (!Note_Type) = "ADDITIONAL NOTES" Or (!Note_Type) = "ADDITIONAL DATA" _
                            Or (!Note_Type) = "ADDITIONAL NOTES/DATA" Or (!Note_Type) = "NOTES" Then
                                clsGridFormat.Text = vbNullString
                                clsGridFormat.Text = Trim(!NOTES_DESC)
                                mstrRowData = Trim(clsGridFormat.Text)
                                Exit Do
                        ElseIf (!Note_Type) = "PHYSICIAN NOTES" Then
                                clsGridFormat.Text = vbNullString
                                clsGridFormat.Text = Trim(!NOTES_DESC)
                                mstrRowData = Trim(clsGridFormat.Text)
                                Exit Do
                        Else
                            clsGridFormat.Text = vbNullString
                            clsGridFormat.Text = Trim(!NOTES_DESC)
                            Arr = Split(clsGridFormat.Text, ",")
                            If UBound(Arr) > 0 Then
                                clsGridFormat.Text = vbNullString
                                For Idx = LBound(Arr) To UBound(Arr)
                                    If Arr(Idx) <> vbNullString Then
                                        If clsGridFormat.Text = vbNullString Then
                                            clsGridFormat.Text = Trim(Arr(Idx))
                                        Else
                                            clsGridFormat.Text = clsGridFormat.Text & vbNewLine & Trim(Arr(Idx))
                                        End If
                                    End If
                                Next Idx
                            End If
                            clsGridFormat.Text = Replace(clsGridFormat.Text, "''", "'")
                            mstrRowData = Trim(clsGridFormat.Text)
                        End If
                    End If
                End If
            End If
            grdReport.ReDraw = False
            .MoveNext
        Loop
    End With
    clsGridFormat.Text = vbNullString
    If Trim(mstrGridNote) <> vbNullString Then Read_GridNotes
    mbooByPass = False
    mbooHasChanged = False
    Screen.MousePointer = vbDefault
    If cnRead.State = adStateOpen Then
        cnRead.Close
        Set cnRead = Nothing
        Set Flds = Nothing
        Set rsRead = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_ReadDataGrid:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "ReadDataGrid", Me.Name
    Exit Function
    Resume Next
End Function
Private Function ReadReferPhys(vstrSpecialty As String) As String
Dim strSQL As String
Dim lID As Long
Dim strSpecialty As String
Dim cnRef As New ADODB.Connection
Dim rsRef As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim strName As String
Dim strFirstName As String
Dim strMiddle As String
Dim strLastName As String
Dim strReason As String
Dim strTitle As String
Dim lngRefID As Long

    On Error GoTo Error
    Screen.MousePointer = vbHourglass
    If cnRef.State = adStateClosed Then cnRef.open psConnect(0)
    ReadReferPhys = vbNullString
    strSQL = "Collect_Referal_Specialty '" & vstrSpecialty & "'"
    Set rsRef = cnRef.Execute(strSQL)
    With rsRef
        Do Until .EOF
            strFirstName = vbNullString
            strMiddle = vbNullString
            strLastName = vbNullString
            strTitle = vbNullString
            strReason = vbNullString
            lngRefID = 0
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "FIRST_NAME"
                                strFirstName = Fix_Name(Fld.Value)
                            Case "MIDDLE_NAME"
                                strMiddle = Fix_Name(Fld.Value)
                            Case "LAST_NAME"
                                strLastName = Fix_Name(Fld.Value)
                            Case "TITLE"
                                strTitle = Fix_Title(Fld.Value)
                        End Select
                    End If
                End If
            Next
                strName = vbNullString
                strName = strFirstName
                If strMiddle <> vbNullString Then strName = Trim(strName) & " " & strMiddle
                If strLastName <> vbNullString Then strName = Trim(strName) & " " & strLastName
                If strTitle <> vbNullString Then strName = Trim(strName) & " " & strTitle
            .MoveNext
            If Trim(strName) <> vbNullString Then
                If ReadReferPhys = vbNullString Then
                    ReadReferPhys = Trim(strName)
                Else
                    ReadReferPhys = ReadReferPhys & Chr(9) & Trim(strName)
                End If
            End If
        Loop
    End With
    If cnRef.State = adStateOpen Then
        cnRef.Close
        Set cnRef = Nothing
        Set rsRef = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_GridNotes", Me.Name
    Exit Function
    Resume Next
End Function
