Private Function Read_Instruction()
Dim strSQL As String
Dim cnPlan As New ADODB.Connection
Dim rsPlan As New ADODB.Recordset
Dim lngPrimKey As Long
Dim strDate As String
Dim lngRow As Long
Dim lngCol As Long
Dim Idx%
Dim Arr
Dim varCellValue


    On Error GoTo Error_Read_Instruction
    mbooLoad = True
    Values_Psychiatry "INSTRUCTIONS"
    clsReport.Instructions = Replace(clsReport.Instructions, "''", "'")
    clsReport.Instructions = Replace(clsReport.Instructions, Chr(34), "'")
    If Trim(clsReport.Instructions) <> vbNullString And Len(Trim(clsReport.Instructions)) > 2 Then
        Arr = Split(LookUpHeaderRow("INSTRUCTIONS"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
        End If
        Arr = Split(clsReport.Instructions, vbNewLine)
        If UBound(Arr) > 0 Then
            clsReport.Instructions = vbNullString
            For Idx = LBound(Arr) To UBound(Arr)
                clsReport.Instructions = vbNullString
                clsReport.Instructions = Arr(Idx)
                clsReport.Instructions = Replace(clsReport.Instructions, "''''", "'")
                If Trim(clsReport.Instructions) <> vbNullString And Len(Trim(clsReport.Instructions)) > 2 Then
                    With grdReport
                          For lngRow = lngRow To .MaxRows
                            .Col = 2
                            .Row = lngRow
                            If .CellTag <> vbNullString Then
                                If UCase(.CellTag) = "INSTRUCTIONS" Then
                                    If .CellType = CellTypeCheckBox Then
                                        .GetText 3, lngRow, varCellValue
                                        If Trim(varCellValue) <> vbNullString Then
                                            If Trim(clsReport.Instructions) = Trim(varCellValue) Then
                                                .Col = 2
                                                .Row = lngRow
                                                .Text = "1"
                                                Exit For
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        Next lngRow
                    End With
                End If
            Next Idx
        Else
            With grdReport
                For lngRow = lngRow To .MaxRows
                    .Col = 2
                    .Row = lngRow
                    If .CellTag <> vbNullString Then
                        If UCase(.CellTag) = "INSTRUCTIONS" Then
                            If .CellType = CellTypeCheckBox Then
                                .GetText 3, lngRow, varCellValue
                                If Trim(varCellValue) <> vbNullString Then
                                    If Trim(clsReport.Instructions) = Trim(varCellValue) Then
                                        .Col = 2
                                        .Row = lngRow
                                        .Text = "1"
                                        Exit For
                                    End If
                                End If
                            End If
                        End If
                    End If
                Next lngRow
            End With
        End If
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Instruction:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_Instruction", Me.Name
    Exit Function
    Resume Next
End Function

