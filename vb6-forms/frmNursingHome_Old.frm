'                                 booExit = True
'                                 Exit For
'                            End If
                        If Trim(IsProperCase(varCellValue)) = Trim(IsProperCase(vstrName)) Then
                            LookUpHeaderRow = 1 & "|" & lngRow
                            booExit = True
                            Exit For
                        End If
                    'End If
                End If
            Next lngRow
