Dim lngCol As Long
Dim Arr
Dim Idx%


    On Error GoTo Error_Read_Checkbox_Scales
    If cnDevelop.State = adStateClosed Then cnDevelop.open psConnect(0)
     mbooLoad = True
    strSQL = "Get_Patient_Scale_PT_Enct_Form_Name " & piPatientID & "," & piEncounterID & ",'MMSE'"
    Set rsDevelop = cnDevelop.Execute(strSQL)
    With rsDevelop
        Do Until .EOF
            clsGridFormat.CellTag = vbNullString
            clsGridFormat.RowName = vbNullString
            clsGridFormat.Text = vbNullString
            clsGridFormat.TextNote = vbNullString
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "DEVELOPMENT_GROUP"
                                clsGridFormat.CellTag = Fld.Value
                            Case "ROW_NAME"
                                clsGridFormat.RowName = Fld.Value
                            Case "CLINICAL_VALUE"
                                clsGridFormat.Text = Fld.Value
                            Case "CLINICAL_NOTE"
                                clsGridFormat.TextNote = Fld.Value
                        End Select
                    End If
                End If
            Next
            .MoveNext
            With grdReport
                lngRow = 0
                .sheet = clsGridFormat.SheetNumber
                Arr = Split(LookUpCellTag(clsGridFormat.CellTag), "|")
                If UBound(Arr) > 0 Then
                    lngRow = Arr(1)
                End If
                If lngRow > 0 Then
                    If IsProperCase(clsGridFormat.CellTag) = "Time" Then
                        If clsGridFormat.RowName = "What day of the week is today?" Then
                            For lngCol = 1 To .MaxCols
                                .Col = lngCol
                                .Row = lngRow
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(LCase(.TypeCheckText)) = "day of the week is today?" Then
                                        .Text = clsGridFormat.Text
                                        Exit For
                                    End If
                                End If
                            Next lngCol
                        ElseIf clsGridFormat.RowName = "What is the month?" Then
                            For lngCol = 1 To .MaxCols
                                .Col = lngCol
                                .Row = lngRow
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(LCase(.TypeCheckText)) = "the month?" Then
                                        .Text = clsGridFormat.Text
                                        Exit For
                                    End If
                                End If
                            Next lngCol
                        ElseIf clsGridFormat.RowName = "What is the year?" Then
                            For lngCol = 1 To .MaxCols
                                .Col = lngCol
                                .Row = lngRow
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(LCase(.TypeCheckText)) = "the year?" Then
                                        .Text = clsGridFormat.Text
                                        Exit For
                                    End If
                                End If
                            Next lngCol
                        ElseIf clsGridFormat.RowName = "What is today's date?" Then
                            For lngCol = 1 To .MaxCols
                                .Col = lngCol
                                .Row = lngRow
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(LCase(.TypeCheckText)) = "today's date?" Then
                                        .Text = clsGridFormat.Text
                                        Exit For
                                    End If
                                End If
                            Next lngCol
                        ElseIf clsGridFormat.RowName = "What season is it?" Then
                            For lngCol = 1 To .MaxCols
                                .Col = lngCol
                                .Row = lngRow
                                If .CellType = CellTypeCheckBox Then
                                    If Trim(LCase(.TypeCheckText)) = "season is it?" Then
                                        .Text = clsGridFormat.Text
                                        Exit For
                                    End If
                                End If
                            Next lngCol
                        End If
                    Else
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            clsGridFormat.RowName = Replace(clsGridFormat.RowName, "What is", "")
                            clsGridFormat.RowName = Replace(clsGridFormat.RowName, "What", "")
                            If .CellType = CellTypeCheckBox Then
                                If Trim(clsGridFormat.RowName) <> vbNullString And Trim(clsGridFormat.RowName) = Trim(.TypeCheckText) Then
                                    .Text = clsGridFormat.Text
                                    Exit For
                                End If
                            End If
                        Next lngCol
                    End If
                End If
            End With
        Loop
    End With
    If cnDevelop.State = adStateOpen Then
        cnDevelop.Close
        Set cnDevelop = Nothing
        Set rsDevelop = Nothing
    End If
    
     mbooLoad = True
     Recalculate_MMSE
     mbooLoad = True
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        Arr = Split(LookUpCellTag("TOTAL_CALC_SCORE"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
        End If
        If lngRow > 0 Then
            lngCol = 5
            Format_CellTypeEdit grdReport, lngRow, lngCol, "1", CStr(clsMMSE_Score.Total_MMSE), "TypeHAlignCenter", "TOTAL_CALC_SCORE", False, HeaderColor
            grdReport.SetCellBorder lngCol, lngRow, lngCol, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
        End If
    End With
    Screen.MousePointer = vbDefault
    Exit Function
