Private Function Calc_CDR()
Dim lngRow As Long
Dim lngCol As Long
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngCal As Double
Dim strCase As String
Dim Arr

    
    On Error GoTo Error_Calc_CDR
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    
    strSQL = "SELECT DISTINCT ROW_NAME, DEVELOPMENT_GROUP, CLINICAL_VALUE FROM  PATIENT_ADHD_SCALE WHERE FORM_NAME = 'CLINICAL DEMENTIA RATING' AND " _
        & "PATIENT_ID = " & piPatientID & "  AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND CLINICAL_VALUE <> '' AND (ROW_NAME <> 'CDR_SCORE' AND ROW_NAME <> 'CDR_INTERPRETATION')"
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            Do Until .EOF
                clsGridFormat.CellTag = vbNullString
                clsGridFormat.TextNote = vbNullString
                If Not IsNull((!ROW_NAME)) Then
                    clsGridFormat.RowName = UCase((!ROW_NAME))
                End If
                If Not IsNull((!DEVELOPMENT_GROUP)) Then
                    clsGridFormat.CellTag = UCase((!DEVELOPMENT_GROUP))
                End If
                If Not IsNull((!CLINICAL_VALUE)) Then
                    clsGridFormat.Text = UCase((!CLINICAL_VALUE))
                End If
                .MoveNext
                Select Case UCase(clsGridFormat.Text)
                    Case "NONE"
                        clsGridFormat.TextNote = "0"
                    Case "QUESTIONABLE"
                        clsGridFormat.TextNote = "0.5"
                    Case "MILD"
                        clsGridFormat.TextNote = "1"
                    Case "MODERATE"
                        clsGridFormat.TextNote = "2"
                    Case "SEVERE"
                        clsGridFormat.TextNote = "3"
                End Select
                lngCal = lngCal + Val(clsGridFormat.TextNote)
            Loop
        End With
        strCase = CStr(lngCal)
        clsGridFormat.CellNote = vbNullString
        Select Case Format(strCase, "##.0")
            Case "0.0"
                clsGridFormat.CellNote = "Normal"
'            Case "0.5", "4.5"
'                clsGridFormat.CellNote = "Questionable cognitive impairment"
            Case "0.5", "1.0", "1.5", "2.0", "2.5"
                clsGridFormat.CellNote = "Questionable impairment"
            Case "3.0", "3.5", "4.0"
                clsGridFormat.CellNote = "Very mild dementia"
            Case "4.5", "5.0", "5.5", "6.0", "6.5", "7.0", "7.5", "8.0", "8.5", "9.0"
                clsGridFormat.CellNote = "Very mild dementia"
            Case "9.5", "10", "10.5", "11", "11.5", "12", "12.5", "13", "13.5", "14.0", "14.5", "15.0"
                clsGridFormat.CellNote = "Moderate dementia"
            Case "16.0", "16.5", "17.0", "17.5", "18.00"
                clsGridFormat.CellNote = "Severe dementia"
        End Select
        Arr = Split(LookUpCellTag("CDR_SCORE"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
            If lngRow > 1 Then
                lngCol = 2
                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "( " & Format(strCase, "##.0") & "/18.00 )", "TypeHAlignLeft", "CDR_SCORE"
                clsGridFormat.TextNote = strCase
                clsGridFormat.RowName = "CDR_SCORE"
                clsGridFormat.CellTag = "CDR_SCORE"
                Write_CDR_Grid
                lngCol = 3
                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsGridFormat.CellNote, "TypeHAlignLeft", "CDR_INTERPRETATION"
                clsGridFormat.TextNote = clsGridFormat.CellNote
                clsGridFormat.RowName = "CDR_INTERPRETATION"
                clsGridFormat.CellTag = "CDR_INTERPRETATION"
                Write_CDR_Grid
            End If
        End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_CDR:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Calc_CDR", TypeName(Me)
    Exit Function
    Resume Next
End Function
Private Function Write_CDR_Grid()
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim varCellValue
Dim strDate As String
Dim lngGridPrim As Long
Dim strTag As String
Dim strText As String
Dim strTextNote As String
Dim strRemove As String
Dim iAnswer As Integer
Dim bScale As Boolean

    On Error GoTo Error_Write_CDR_Grid
    Screen.MousePointer = vbHourglass
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    clsGridFormat.FormName = "CLINICAL DEMENTIA RATING"
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "SELECT * FROM PATIENT_ADHD_SCALE WHERE PATIENT_ID = " & piPatientID & " AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND FORM_NAME = '" & clsGridFormat.FormName & "' AND " _
        & "DEVELOPMENT_GROUP = '" & clsGridFormat.CellTag & "' ORDER BY CONVERT(DATETIME, INSERT_DATE, 101) DESC"
    Set rsWrite = cnWrite.Execute(strSQL)
    If Not rsWrite.EOF Then
        clsGridFormat.GridReportID = rsWrite.Fields("DEVELOPMENT_ID")
    End If
    clsGridFormat.Text = Replace(clsGridFormat.Text, "'", "''")
    If clsGridFormat.GridReportID = 0 Then
       strSQL = "Write_Patient_Scale " & piPatientID & "," & piEncounterID & ",'" & clsGridFormat.FormName & "','" & clsGridFormat.CellTag & "','" _
           & Trim(clsGridFormat.RowName) & "','" & Trim(clsGridFormat.Text) & "','" & Trim(clsGridFormat.TextNote) & "','" & strDate & "'"
           Set rsWrite = cnWrite.Execute(strSQL)
    Else
       strSQL = "UPDATE PATIENT_ADHD_SCALE SET CLINICAL_VALUE = '" & Trim(clsGridFormat.Text) & "', " _
            & "CLINICAL_NOTE = '" & clsGridFormat.TextNote & "', UPDATE_DATE = '" & strDate & "' WHERE DEVELOPMENT_ID = " & clsGridFormat.GridReportID
           Set rsWrite = cnWrite.Execute(strSQL)
    End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Write_CDR_Grid:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Write_CDR_Grid", TypeName(Me)
    Exit Function
    Resume Next
End Function

