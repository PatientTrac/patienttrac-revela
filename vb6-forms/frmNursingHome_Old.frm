Dim varCellValue
Dim booExit As Boolean

    On Error GoTo Error
    
    With grdReport
        For lngRow = 7 To .MaxRows
            .Col = 2
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If TextFound(vstrName, .CellTag, Len(vstrName), True) And lngRow <> mlngGridRow Then
                    .ClearRange 2, lngRow, .MaxCols, lngRow, True
                    .DeleteRows lngRow, 1
                    .MaxRows = .MaxRows - 1
                End If
            End If
        Next lngRow
    End With
    Exit Function
