Private Function Run_Patient_Batch()
Dim i%
Dim strSQL As String
Dim cnEnctr As New ADODB.Connection
Dim rsEnctr As New ADODB.Recordset
Dim lngSheet As Long
Dim iReturn As Integer
Dim strRS
Dim Cnt As Long
Dim strSheetName As String
Dim strEnd As String
Dim bData As Boolean
Dim strRange As String

    On Error GoTo Error_Run_Patient_Batch
    Screen.MousePointer = vbHourglass
    If cnEnctr.State = adStateClosed Then cnEnctr.open psConnect(0)
    If udtTime.StartDate = vbNullString Then udtTime.StartDate = Format(Now, "mm/dd/yyyy")
    grdPrintForm.SheetCount = 1
    If Format(ccdPrevDate.Value, "mm/dd/yyyy") <> "01/01/1900" And ccdPrevDate.CheckBox Then
        udtInPatSched.Appt_Date = Format(ccdPrevDate.Value, "mm/dd/yyyy")
    Else
        udtInPatSched.Appt_Date = Format(Now, "mm/dd/yyyy")
    End If
    If cnEnctr.State = adStateClosed Then cnEnctr.open psConnect(0)

    strSQL = "SELECT DISTINCT PATIENT.LAST_NAME, INPATIENT_APPOINTMENTS.PURPOSE_VISIT, INPATIENT_APPOINTMENTS.APPT_TYPE, " _
        & "INPATIENT_APPOINTMENTS.STATUS, INPATIENT_APPOINTMENTS.APPT_DATE, INPATIENT_APPOINTMENTS.ROOM_NUMBER, " _
        & "PATIENT.TITLE, PATIENT.PREF_CONTACT, PATIENT.SUFFIX, PATIENT.FIRST_NAME, PATIENT.MIDDLE_NAME, " _
        & "ENCOUNTER.* FROM INPATIENT_APPOINTMENTS INNER JOIN PATIENT ON " _
        & "PATIENT.PATIENT_ID = INPATIENT_APPOINTMENTS.PATIENT_ID " _
        & "INNER JOIN ENCOUNTER ON ENCOUNTER.PATIENT_ID = INPATIENT_APPOINTMENTS.PATIENT_ID " _
        & "INNER JOIN PATIENT_NOTES ON ENCOUNTER.ENCOUNTER_ID = PATIENT_NOTES.ENCOUNTER_ID " _
        & "Where INPATIENT_APPOINTMENTS.Facility_ID = 1026 And INPATIENT_APPOINTMENTS.Active = 0 " _
        & "AND PATIENT.STATUS = 'Active' AND CONVERT( VARCHAR(10), INPATIENT_APPOINTMENTS.APPT_DATE, 101) <=  CONVERT( VARCHAR(10), ENCOUNTER.ENCNTR_START_DATE, 101) " _
        & "AND (ENCOUNTER.ENCNTR_END_DATE IS NULL OR CONVERT( VARCHAR(10), ENCOUNTER.ENCNTR_END_DATE, 101) = '" & udtInPatSched.Appt_Date & "') " _
        & "AND CONVERT(DATETIME, ENCNTR_START_DATE, 101) > '02/01/2012' AND ENCOUNTER.PURGE = 0 ORDER BY PATIENT.LAST_NAME, " _
        & "PATIENT.FIRST_NAME, ENCOUNTER.ENCNTR_START_DATE DESC, INPATIENT_APPOINTMENTS.APPT_DATE DESC " _

'    strSQL = "SELECT  ENCOUNTER.*, INPATIENT_APPOINTMENTS.ROOM_NUMBER, PATIENT.LAST_NAME, PATIENT.FIRST_NAME FROM ENCOUNTER " _
'        & "INNER JOIN INPATIENT_APPOINTMENTS ON INPATIENT_APPOINTMENTS.PATIENT_ID = ENCOUNTER.PATIENT_ID " _
'        & "INNER JOIN PATIENT ON PATIENT.PATIENT_ID = ENCOUNTER.PATIENT_ID " _
'        & "WHERE CONVERT( VARCHAR(10), INPATIENT_APPOINTMENTS.APPT_DATE, 101)  BETWEEN '" & Format(strRange, "mm/dd/yyyy") & "' AND  '" & Format(strEnd, "mm/dd/yyyy") & "'  AND " _
'        & "INPATIENT_APPOINTMENTS.FACILITY_ID = " & piFacilityID & " AND " _
'        & "EXT_ENCOUNTER_ID IS NULL AND ENCOUNTER.PURGE = 0 AND ENCOUNTER.CURRENT_STATE IS NOT NULL AND " _
'        & "INPATIENT_APPOINTMENTS.PROVIDER_ID = " & mlngLogonUser & " AND INPATIENT_APPOINTMENTS.ACTIVE = 0  AND  " _
'        & "(INPATIENT_APPOINTMENTS.STATUS <> 'Cancelled' AND  INPATIENT_APPOINTMENTS.STATUS <> 'Second Round') " _
'        & "ORDER BY INPATIENT_APPOINTMENTS.ROOM_NUMBER, PATIENT.LAST_NAME, PATIENT.FIRST_NAME"
    If strSQL <> vbNullString Then
        Set rsEnctr = cnEnctr.Execute(strSQL)
        With rsEnctr
            Do Until .EOF
                piPatientID = 0
                piEncounterID = 0
                If (!Encounter_ID) <> 0 Then
                    piPatientID = (!Patient_ID)
                    piEncounterID = (!Encounter_ID)
                End If
                .MoveNext
                If piEncounterID > 0 Then
                    Get_Patient piPatientID
                    Get_Encounter piEncounterID
                    clsGridFormat.SheetNumber = 1
                    Cnt = Cnt + 1
                    clsGridFormat.SheetNumber = Cnt
                    If grdPrintForm.SheetCount < Cnt Then grdPrintForm.SheetCount = Cnt
                    grdPrintForm.sheet = clsGridFormat.SheetNumber
                    grdPrintForm.ActiveSheet = clsGridFormat.SheetNumber
                    bData = True
                    grdPrintForm.SheetName = piPatientID & "_" & "Prog_Note" & "_" & Format(clsEncounter.StartDate, "mm_dd_yyyy")
                    If clsEncounter.EncounterType = "Initial InPatient" Or clsEncounter.EncounterType = "Re-Admission" Then
                        mbooByPass = True
                        Format_PDG_Grid_Header
                        Format_Batch_Subsequent
                        Add_Batch_Past_Social
                    Else
                        mbooByPass = True
                        Format_PDG_Grid_Header
                        Format_Batch_Subsequent
                        Add_Batch_MMSE
                    End If
                End If
            Loop
        End With
    End If
    If bData Then Print_Files
    If cnEnctr.State = adStateOpen Then
        cnEnctr.Close
        Set cnEnctr = Nothing
        Set rsEnctr = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Run_Patient_Batch:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Run_Patient_Batch", App.EXEName & "." & TypeName(Me)
    Exit Function
    Resume Next
End Function
