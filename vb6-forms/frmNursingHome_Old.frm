Private Function Get_InPatient_Appt_Data()
Dim cnReadAppt As New ADODB.Connection
Dim rsReadAppt  As New ADODB.Recordset
Dim strSQL As String
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim lngRow As Long
Dim lngCol As Long
Dim lngApptID As Long
Dim i%
Dim strList As String
Dim strRange As String
Dim strEnd As String

    On Error GoTo Error_Get_InPatient_Appt_Data
    Screen.MousePointer = vbHourglass
    Get_Appt_Range
    If cnReadAppt.State = adStateClosed Then cnReadAppt.open psConnect(0)
    strSQL = "SELECT * FROM INPATIENT_APPOINTMENTS WHERE FACILITY_ID =  " & piFacilityID & "  AND " _
        & "PROVIDER_ID = " & mlngLogonUser & " AND PATIENT_ID = " & piPatientID & " AND " _
        & "CONVERT( VARCHAR(10), INPATIENT_APPOINTMENTS.APPT_DATE, 101) " _
        & "BETWEEN '" & Format(mstrRangeDate, "mm/dd/yyyy") & "' AND '" & Format(mstrUpperRange, "mm/dd/yyyy") & "' ORDER BY APPT_DATE DESC"
    Set rsReadAppt = cnReadAppt.Execute(strSQL)
    With rsReadAppt
        If Not .EOF Then
            Clear_InSched
            Clear_Appt
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) > vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "SUFFIX"
                                udtInPatSched.Suffix = Trim(Fld.Value)
                            Case "LAST_NAME"
                                udtInPatSched.LastName = IsProperCase(Fld.Value)
                            Case "MIDDLE_NAME"
                                udtInPatSched.MiddleInitial = IsProperCase(Fld.Value)
                            Case "FIRST_NAME"
                                udtInPatSched.FirstName = Fld.Value
                            Case "PREF_CONTACT"
                                udtInPatSched.RoomTelephone = Trim(Fld.Value)
                            Case "PATIENT_ID"
                                udtInPatSched.IntId = Fld.Value
                            Case "PURPOSE_VISIT"
                                udtInPatSched.VisitType = Fld.Value
                            Case "STATUS"
                                udtInPatSched.Status = Trim(Fld.Value)
                            Case "FACILITY_ID"
                                udtInPatSched.Facility_ID = Fld.Value
                            Case "RESOURCE_TYPE"
                                udtInPatSched.ResourceType = Fld.Value
                            Case "ROOM", "ROOM_NUMBER"
                                udtInPatSched.RoomNumber = Fld.Value
'                            Case "TELEPHONE"
'                                udtInPatSched.RoomTelephone = Fld.Value
                            Case "DURATION"
                                udtInPatSched.Duration = Fld.Value
                            Case "PATIENT_TYPE"
                                udtInPatSched.PatientType = Fld.Value
                            Case "CURRENT_LOCATION"
                                udtInPatSched.Current_Location = Fld.Value
                            Case "STATUS_NOTES"
                                udtInPatSched.ApptComment = Fld.Value
                                udtInPatSched.ApptComment = Replace(udtInPatSched.ApptComment, "''", "'")
                            Case "INPATIENT_APPT_ID"
                                udtInPatSched.Appointment_ID = Fld.Value
                        End Select
                    End If
                End If
            Next
        End If
    End With
    If cnReadAppt.State = adStateOpen Then
        cnReadAppt.Close
        Set cnReadAppt = Nothing
        Set rsReadAppt = Nothing
        Set Flds = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_InPatient_Appt_Data:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Get_InPatient_Appt_Data", App.EXEName & "." & Me.Name
    Exit Function
    Resume Next
End Function
