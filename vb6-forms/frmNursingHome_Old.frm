Private Function Clinical_Preview_Event(ByVal Col As Long, ByVal Row As Long)
Dim strFile As String
Dim lngCloseIt As Long
Dim Idx As Long
Dim Cnt As Long
Dim Ret As Long

    On Error GoTo Error_Clinical_Preview_Event
    
    With grdRoster
        piPatientID = .GetRowItemData(Row)
        If piPatientID > 0 Then
            If piEncounterID > 0 Then
                Get_Patient piPatientID
                Get_Encounter piEncounterID
                With grdPrintForm
                    For Idx = 1 To .SheetCount
                        .sheet = Idx
                        .ActiveSheet = Idx
                        If .SheetName = piPatientID & "_" & "Prog_Note" & "_" & Format(clsEncounter.StartDate, "mm_dd_yyyy") Then
                            Cnt = Idx
                            Exit For
                        End If
                    Next Idx
                End With
                If Cnt > 0 Then
                    If mbooWrite Then
                        clsGridFormat.SheetNumber = Cnt
                        If grdPrintForm.SheetCount < Cnt Then grdPrintForm.SheetCount = Cnt
                        grdPrintForm.sheet = clsGridFormat.SheetNumber
                        grdPrintForm.ActiveSheet = clsGridFormat.SheetNumber
                        grdPrintForm.SheetName = piPatientID & "_" & "Prog_Note" & "_" & Format(clsEncounter.StartDate, "mm_dd_yyyy")
                        If clsEncounter.EncounterType = "Initial InPatient" Or clsEncounter.EncounterType = "Re-Admission" Then
                            mbooByPass = True
                            Format_PDG_Grid_Header
                            Format_Batch_Subsequent
                            Add_Batch_Past_Social
                            Get_Batch_Psychiatry
                            Re_Print_Patient
                        Else
                            mbooByPass = True
                            Format_PDG_Grid_Header
                            Format_Batch_Subsequent
                            Add_Batch_MMSE
                            Get_Batch_Psychiatry
                            Re_Print_Patient
                        End If
                    End If
                Else
                    clsGridFormat.SheetNumber = grdPrintForm.SheetCount + 1
                    grdPrintForm.SheetCount = clsGridFormat.SheetNumber
                    grdPrintForm.sheet = clsGridFormat.SheetNumber
                    grdPrintForm.ActiveSheet = clsGridFormat.SheetNumber
                    If clsEncounter.EncounterType = "Initial InPatient" Or clsEncounter.EncounterType = "Re-Admission" Then
                        mbooByPass = True
                        Format_PDG_Grid_Header
                        Format_Batch_Subsequent
                        Add_Batch_Past_Social
                        Get_Batch_Psychiatry
                        Re_Print_Patient
                        Sleep 150
                    Else
                        mbooByPass = True
                        Format_PDG_Grid_Header
                        Format_Batch_Subsequent
                        Add_Batch_MMSE
                        Get_Batch_Psychiatry
                        Re_Print_Patient
                        Sleep 150
                    End If
                End If
            End If
        End If
          
        If FileExists(mstrPrintPath & "\" & CStr(piPatientID) & ".pdf") Then
            Ret = ShellExecuteA(Me.Hwnd, "open", mstrPrintPath & "\" & CStr(piPatientID) & ".pdf", "C:\", vbNullString, 1)
        Else
            Write_Error mstrPrintPath & "\" & CStr(piPatientID) & ".pdf", Err.Number, CStr(piPatientID) & ".pdf", "Clinical_Preview_Event", Me.Name
        End If
    End With
    Set clsPDF = Nothing
    Exit Function
    Screen.MousePointer = vbDefault
    Exit Function
Error_Clinical_Preview_Event:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, CStr(piPatientID) & ".pdf", "Clinical_Preview_Event", Me.Name
    Exit Function
    Resume Next
End Function
