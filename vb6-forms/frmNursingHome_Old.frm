Private Function Get_Appt_Range()
Dim lngRow As Long
Dim lngCol As Long
Dim strSQL As String
Dim cnEnctr As New ADODB.Connection
Dim rsEnctr As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim lngEnctr As Long
Dim strEntrDate As String
Dim strEnctrType As String
Dim strCurState As String
Dim lngCurEnctr As Long
Dim strPrevDate As String
Dim lngCnt As Long
Dim strLast As String
Dim varCellValue


    On Error GoTo Error_Get_Appt_Range
    If cnEnctr.State = adStateClosed Then cnEnctr.open psConnect(0)
    mstrUpperRange = vbNullString
    strSQL = "SELECT APPT_DATE, STATUS FROM INPATIENT_APPOINTMENTS WHERE FACILITY_ID = " & piFacilityID & " AND " _
        & "ACTIVE = 0 AND (STATUS <> 'Postpone' AND STATUS <> 'Active')  " _
        & "ORDER BY APPT_DATE ASC"
    Set rsEnctr = cnEnctr.Execute(strSQL)
'    With rsEnctr
'        If Not .EOF Then
'            mstrRangeDate = (!Appt_Date)
'        End If
'    End With
   With rsEnctr
        Do Until .EOF
            strCurState = vbNullString
            strLast = vbNullString
            If Not IsNull((!Status)) Then strCurState = (!Status)
            mstrRangeDate = (!Appt_Date)
            lngCnt = lngCnt + 1
            .MoveNext
            If strCurState = "Present" Then
                strPrevDate = mstrRangeDate
                Exit Do
            End If
        Loop
    End With
    
    
    If grdVisitDate.ActiveRow > 0 Then
        With grdVisitDate
            .Col = 1
            .Row = grdVisitDate.ActiveRow
            If .BackColor = grdCurItem Then
                .GetText 1, grdVisitDate.ActiveRow, varCellValue
                If Trim(varCellValue) <> vbNullString Then
                    strEntrDate = varCellValue
                End If
            End If
        End With
        strCurState = vbNullString
        strPrevDate = vbNullString
        If strEntrDate <> vbNullString Then
            mstrRangeDate = vbNullString
             strSQL = "SELECT DISTINCT APPT_DATE, STATUS FROM INPATIENT_APPOINTMENTS WHERE FACILITY_ID = " & piFacilityID & " AND " _
                & "ACTIVE = 0 AND (STATUS <> 'Postpone' AND STATUS <> 'Active')  AND CONVERT(VARCHAR(10), APPT_DATE, 101) < '" & Format(strEntrDate, "mm/dd/yyyy") & "' " _
                & "ORDER BY APPT_DATE ASC"
            Set rsEnctr = cnEnctr.Execute(strSQL)
            With rsEnctr
                Do Until .EOF
                    strCurState = vbNullString
                    strLast = vbNullString
                    If Not IsNull((!Status)) Then strCurState = (!Status)
                    mstrRangeDate = (!Appt_Date)
                    .MoveNext
                    If strCurState = "Present" Then
                        If DateDiff("d", mstrRangeDate, strEntrDate) < 30 Then
                            Exit Do
                        End If
                    End If
                    strPrevDate = mstrRangeDate
                Loop
            End With
        End If
    Else
        If strPrevDate <> vbNullString And strLast <> vbNullString Then
            If DateDiff("d", strPrevDate, strLast) > 0 Then
                mstrRangeDate = strLast
            Else
                mstrRangeDate = DateAdd("d", 1, strPrevDate)
            End If
        End If
    End If
    strSQL = "SELECT APPT_DATE FROM INPATIENT_APPOINTMENTS WHERE FACILITY_ID = " & piFacilityID & " AND " _
        & "ACTIVE = 0 AND (STATUS <> 'Postpone' AND STATUS <> 'Active') AND CONVERT(VARCHAR(10), APPT_DATE, 101) < '" & udtInPatSched.Appt_Date & "' ORDER BY APPT_DATE DESC"
    Set rsEnctr = cnEnctr.Execute(strSQL)
    With rsEnctr
        If Not .EOF Then
            mstrUpperRange = (!Appt_Date)
        End If
    End With
    If grdVisitDate.ActiveRow > 0 Then
        With grdVisitDate
            .Col = 1
            .Row = grdVisitDate.ActiveRow
            If .BackColor = grdCurItem Then
                .GetText 1, grdVisitDate.ActiveRow, varCellValue
                If Trim(varCellValue) <> vbNullString Then
                    strEntrDate = varCellValue
                End If
            End If
        End With
        If strEntrDate <> vbNullString Then
            mstrUpperRange = strEntrDate
        End If
    Else
        strEntrDate = DateAdd("d", 1, udtInPatSched.Appt_Date)
        If mstrUpperRange = mstrRangeDate Then
            mstrUpperRange = Format(Now, "mm/dd/yyyy")
        ElseIf DateDiff("d", Format(strEntrDate, "mm/dd/yyyy"), Format(mstrUpperRange, "mm/dd/yyyy")) > 1 Then
            mstrUpperRange = Format(strEntrDate, "mm/dd/yyyy")
        End If
        If DateDiff("d", mstrUpperRange, udtInPatSched.Appt_Date) >= 1 Then
            mstrUpperRange = udtInPatSched.Appt_Date
        End If
    End If
    If cnEnctr.State = adStateOpen Then
        cnEnctr.Close
        Set cnEnctr = Nothing
        Set rsEnctr = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Appt_Range:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Get_Appt_Range", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Get_Last_MD_Completed() As String
Dim lngRow As Long
Dim lngCol As Long
Dim strSQL As String
Dim cnEnctr As New ADODB.Connection
Dim rsEnctr As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim lngEnctr As Long
Dim strLowerDate As String
Dim strEntrDate As String
Dim strEnctrType As String
Dim strCurState As String
Dim lngCurEnctr As Long

    On Error GoTo Error_Get_Last_MD_Completed
    If cnEnctr.State = adStateClosed Then cnEnctr.open psConnect(0)
    mstrUpperRange = vbNullString
    strSQL = "SELECT DISTINCT INPATIENT_APPOINTMENTS.APPT_DATE FROM INPATIENT_APPOINTMENTS " _
        & "INNER JOIN ENCOUNTER ON ENCOUNTER.PATIENT_ID = INPATIENT_APPOINTMENTS.PATIENT_ID " _
        & "WHERE INPATIENT_APPOINTMENTS.FACILITY_ID = " & piFacilityID & " AND " _
        & "INPATIENT_APPOINTMENTS.ACTIVE = 0 AND (INPATIENT_APPOINTMENTS.STATUS <> 'Postpone' AND INPATIENT_APPOINTMENTS.STATUS <> 'Active')  ORDER BY INPATIENT_APPOINTMENTS.APPT_DATE ASC"
    Set rsEnctr = cnEnctr.Execute(strSQL)
    With rsEnctr
        If Not .EOF Then
            strLowerDate = (!Appt_Date)
        End If
    End With
    If strLowerDate = vbNullString Then
        strSQL = "SELECT DISTINCT INPATIENT_APPOINTMENTS.APPT_DATE FROM INPATIENT_APPOINTMENTS " _
            & "INNER JOIN ENCOUNTER ON ENCOUNTER.PATIENT_ID = INPATIENT_APPOINTMENTS.PATIENT_ID " _
            & "WHERE INPATIENT_APPOINTMENTS.FACILITY_ID = " & piFacilityID & " AND " _
            & "INPATIENT_APPOINTMENTS.ACTIVE = 0 AND INPATIENT_APPOINTMENTS.STATUS = 'Present'  ORDER BY INPATIENT_APPOINTMENTS.APPT_DATE DESC"
        Set rsEnctr = cnEnctr.Execute(strSQL)
        With rsEnctr
            If Not .EOF Then
                strLowerDate = (!Appt_Date)
            End If
        End With
    End If
    If strLowerDate = vbNullString Then
        If udtInPatSched.Appt_Date <> vbNullString Then
            If strLowerDate <> vbNullString Then strLowerDate = DateAdd("d", -2, udtInPatSched.Appt_Date)
        Else
            If strLowerDate <> vbNullString Then strLowerDate = DateAdd("d", -2, Now)
        End If
    End If
    strLowerDate = Format(strLowerDate, "mm/dd/yyyy")
    If strLowerDate <> vbNullString Then
        strSQL = "SELECT ENCNTR_START_DATE FROM ENCOUNTER WHERE FACILITY_ID = " & piFacilityID & " AND " _
            & "(CURRENT_STATE = 'MD COMPLETED' OR CURRENT_STATE = 'WORKUP') AND PURGE = 0 AND CONVERT(VARCHAR(10), ENCNTR_START_DATE, 101) > '" & Format(strLowerDate, "mm/dd/yyyy") & "' ORDER BY ENCNTR_START_DATE DESC"
        Set rsEnctr = cnEnctr.Execute(strSQL)
        With rsEnctr
            Do Until .EOF
                strEntrDate = (!ENCNTR_START_DATE)
                .MoveNext
                If strEntrDate >= strLowerDate Then
                    Get_Last_MD_Completed = strLowerDate
                    Exit Do
                End If
            Loop
        End With
    End If
    If cnEnctr.State = adStateOpen Then
        cnEnctr.Close
        Set cnEnctr = Nothing
        Set rsEnctr = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Last_MD_Completed:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Get_Last_MD_Completed", Me.Name
    Exit Function
    Resume Next
End Function


