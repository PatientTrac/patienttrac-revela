Private Function Write_MSE_Values()
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim lngGridPrim As Long



    On Error GoTo Error_Write_MSE_Values
    Screen.MousePointer = vbHourglass
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "Get_Patient_Mental_Status_Item " & piPatientID & "," & piEncounterID & ",'" & Trim(udtNew_MSE.MSE_Item) & "'"
    Set rsWrite = cnWrite.Execute(strSQL)
    With rsWrite
        If Not rsWrite.EOF Then
            lngGridPrim = (!MSE_ID)
        End If
    End With
    If lngGridPrim = 0 Then
        strSQL = "Insert_Patient_Mental_Status " & piPatientID & "," & piEncounterID & "," _
            & clsEncounter.ProviderID & "," & clsEncounter.FacilityID & ",'" _
            & Trim(udtNew_MSE.MSE_Item) & "','" & Trim(udtNew_MSE.MSE_Data) & "','" & Trim(udtNew_MSE.MSE_Note) & "','" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'"
            Set rsWrite = cnWrite.Execute(strSQL)
    Else
        strSQL = "UPDATE PATIENT_MENTAL_STATUS SET MSE_ITEM = '" & udtNew_MSE.MSE_Item & "', MSE_DATA = '" & udtNew_MSE.MSE_Data & "', " _
            & "UPDATE_DATE = '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "' WHERE MSE_ID = " & lngGridPrim
        Set rsWrite = cnWrite.Execute(strSQL)
        If Trim(udtNew_MSE.MSE_Note) <> vbNullString Then
            strSQL = "UPDATE PATIENT_MENTAL_STATUS SET MSE_NOTES = '" & Trim(udtNew_MSE.MSE_Note) & "', UPDATE_DATE = '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "' WHERE MSE_ID = " & lngGridPrim
            Set rsWrite = cnWrite.Execute(strSQL)
        End If
    End If


    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Write_MSE_Values:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Write_MSE_Values", Me.Name
    Exit Function
    Resume Next
End Function

Private Function Write_Other_Social()
