        .SetCellBorder 1, lngRow, 1, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
        Format_CellTypeEdit grdRoster, lngRow, 2, "1", "PATIENT NAME", "TypeHAlignCenter", "", False, HeaderColor, "", 0, 10
