Dim lngMyCnt As Long


    On Error GoTo Error_Format_AdultDevelopment
    Get_Patient piPatientID
    Clear_ChildDev
    Clear_AdultDevelop
    Screen.MousePointer = vbHourglass
    mlngExamRow = 0
    booExam = True
    Arr = Split(LookUpHeaderRow("ADULT DEVELOPMENTAL HISTORY"), "|")
    If UBound(Arr) > 0 Then
        lngRow = Arr(1)
    Else
        Arr = Split(LookUpHeaderRow("CHILD DEVELOPMENTAL HISTORY"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
        End If
    End If
    If lngRow = 0 Then
        Arr = Split(LookUpHeaderRow("ADULT DEVELOPMENTAL"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
        Else
            Arr = Split(LookUpHeaderRow("CHILD DEVELOPMENTAL"), "|")
            If UBound(Arr) > 0 Then
                lngRow = Arr(1)
            End If
        End If
    End If
     
    Get_Patient piPatientID
    If lngRow = 0 Then
        Arr = Split(LookUpHeaderRow("SOCIAL HISTORY"), "|")
            If UBound(Arr) > 0 Then
                lngRow = Arr(1) + 2
            End If
    End If
    If lngRow = 0 Then
        Arr = Split(LookUpHeaderRow("REVIEW OF SOCIAL HISTORY"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1) + 2
        End If
    End If
    lngRow = 0
    If lngRow = 0 Then
        Arr = Split(LookUpHeaderRow("SUBSTANCE HISTORY"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
        End If
    End If
    With grdReport
        .ReDraw = False
        For lngMyCnt = lngRow + 1 To .MaxRows
            .Col = 1
            .Row = lngMyCnt
            If .CellTag <> vbNullString Then
                If .CellTag = "ADULT_DEVELOPMENT" Then

                    Arr = Split(clsRowCount.AdultDev, "|")
                    If UBound(Arr) > 0 Then
                        lngStartRow = Arr(0)
                        lngEndRow = Arr(1)
                    End If
                    If lngStartRow > 0 Then lngCnt = lngEndRow - lngStartRow
                    If lngStartRow > 0 Then
                        .DeleteRows lngStartRow, lngCnt + 1
