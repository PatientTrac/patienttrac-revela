                        Add_Katz
                End Select
            End If
        End If
    End With
    Exit Sub
Error_Rating_Scale:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Load", Me.Name
    Resume Next
    Exit Sub
End Sub
Private Function PrinterIndex(ByVal PrinterName As String) As Integer
    Dim i As Integer
    Dim hdc
    
    For i = 0 To Printers.Count - 1
        If LCase(Printers(i).DeviceName) Like LCase(PrinterName) Then
            PrinterIndex = i
            Printer_HDC = Printers(i).hdc
            Exit Function
        End If
    Next
    PrinterIndex = -1
End Function
Private Function Print_Files()
Dim i As Integer
Dim Idx%
Dim prtidx As Integer
Dim sPrinterName As String
Dim settings As Object
Dim util As Object
Dim Arr
Dim fso As New FileSystemObject

    On Error GoTo Error_Print_Files
    
    Set util = CreateObject(UTIL_PROGID)
    sPrinterName = util.defaultprintername
    mbooCancelPrint = False
    Printer.TrackDefault = True
    If mbooCancelPrint Then
        MsgBox "Print Command Cancelled", vbInformation
        Exit Function
    End If
    With grdPrintForm
        For Idx = 1 To .SheetCount
            clsFolder.Folder_Name = vbNullString
            .sheet = Idx
            .ActiveSheet = grdPrintForm.sheet
            Arr = Split(.SheetName, "_")
            If UBound(Arr) > 0 Then
                clsFolder.Folder_Name = Arr(0)
            Else
                clsFolder.Folder_Name = .SheetName
            End If
'            If clsFolder.Folder_Name = "4349" Then
'                Debug.Print
'            End If
            If Trim(clsFolder.Folder_Name) <> vbNullString Then
                .PrintJobName = mstrPrintPath & "\" & clsFolder.Folder_Name
                .PrintType = PrintTypeAll
                prtidx = PrinterIndex(sPrinterName)
                If prtidx < 0 Then Err.Raise 1000, , "No printer was found by the name of '" & sPrinterName & "'."
                Set Printer = Printers(prtidx)
                .hDCPrinter = Printer_HDC
                .PrintColHeaders = False
'                .PrintBestFitPagesWide = True
                .PrintScalingMethod = PrintScalingMethodSmartPrint
                .PrintRowHeaders = False
                .PrintMarginLeft = 650
                .PrintMarginRight = 700
                .PrintMarginBottom = 100
                .PrintMarginTop = 100
                .PrintBorder = False
                .PrintColor = True
                .PrintOrientation = PrintOrientationPortrait
                .PrintShadows = False
               ' .PrintSmartPrint = True
                 Set Printer = Printers(prtidx)
                Set settings = CreateObject(SETTINGS_PROGID)
                settings.PrinterName = sPrinterName
                If Not fso.FileExists(mstrPrintPath & "\" & clsFolder.Folder_Name) Then
                    settings.setValue "Output", mstrPrintPath & "\" & clsFolder.Folder_Name & ".pdf"
                    settings.setValue "ConfirmOverwrite", "no"
                    settings.setValue "ShowSaveAS", "never"
                    settings.setValue "ShowSettings", "never"
                    settings.setValue "ShowPDF", "no"
                    settings.setValue "RememberLastFileName", "no"
                    settings.setValue "RememberLastFolderName", "no"
                    settings.WriteSettings True
                    .PrintSheet
                    Printer.EndDoc
                    Dim runonce As String
                    runonce = settings.GetSettingsFilePath(True)
                    While Dir(runonce, vbNormal) <> ""
                        Sleep 100
                    Wend
                End If
            End If
        Next Idx
        .sheet = 1
    End With
    Set fso = Nothing
    Set settings = Nothing
    Screen.MousePointer = vbDefault
    Exit Function
Error_Print_Files:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Print_Files", Me.Name
    Exit Function
    Resume Next
End Function
