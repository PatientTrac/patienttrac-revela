Private Function Write_Alcohol_Drug()
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strSQL As String
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim varCellValue
Dim strDate As String
Dim lngGridPrim As Long
Dim strAlchol As String
Dim strValue As String
Dim strDrug As String
Dim intActX_ID As Integer


    On Error GoTo Error_Write_Alcohol_Drug
    Screen.MousePointer = vbHourglass
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    With grdReport
        .Col = .ActiveCol
        .Row = .ActiveRow
        If .CellTag <> vbNullString Then
            If .CellTag = "ALCOHOL" Then
                If .CellType = CellTypeCheckBox Then
                    If .TypeCheckText = "No" Then
                        strAlchol = "False"
                    ElseIf .TypeCheckText = "Yes" Then
                        strAlchol = "True"
                    End If
                End If
            ElseIf .CellTag = "DRUG" Then
                If .CellType = CellTypeCheckBox Then
                    If .TypeCheckText = "No" Then
                        strDrug = "False"
                    ElseIf .TypeCheckText = "Yes" Then
                        strDrug = "True"
                    End If
                End If
            End If
        End If
    End With
    If Trim(strAlchol) <> vbNullString Then
        If strAlchol = "False" Then
            strSQL = "Get_Profiler_Value 'FN_PsyMSE.SocialHist', 'optDrinkNo',1," & piPatientID & "," & piEncounterID
            Set rsWrite = cnWrite.Execute(strSQL)
               With rsWrite
                   If Not .EOF Then
                       lngGridPrim = (!PROFILER_ID)
                   End If
               End With
               intActX_ID = Get_ComponentID("FN_PsyMSE", "SocialHist")
               If lngGridPrim = 0 Then
                   strSQL = "Write_Patient_Profiler " & piPatientID & "," _
                       & piEncounterID & "," & intActX_ID & ", 'optDrinkNo', 1,'True','FN_PsyMSE.SocialHist', 1,'" _
                        & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" _
                       & PsUserID & "'"
                   Set rsWrite = cnWrite.Execute(strSQL)
               Else
                   strSQL = "Update_Patient_Profiler 'True',1,'" _
                       & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & lngGridPrim
                   Set rsWrite = cnWrite.Execute(strSQL)
                    lngGridPrim = 0
                    strSQL = "Get_Profiler_Value 'FN_PsyMSE.SocialHist', 'optDrinkYes',1," & piPatientID & "," & piEncounterID
                    Set rsWrite = cnWrite.Execute(strSQL)
                       With rsWrite
                           If Not .EOF Then
                               lngGridPrim = (!PROFILER_ID)
                           End If
                       End With
                    If lngGridPrim > 0 Then
                       strSQL = "Update_Patient_Profiler 'False',1,'" _
                           & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & lngGridPrim
                       Set rsWrite = cnWrite.Execute(strSQL)
                    End If
               End If
        ElseIf strAlchol = "True" Then
            lngGridPrim = 0
            strSQL = "Get_Profiler_Value 'FN_PsyMSE.SocialHist', 'optDrinkYes',1," & piPatientID & "," & piEncounterID
            Set rsWrite = cnWrite.Execute(strSQL)
               With rsWrite
                   If Not .EOF Then
                       lngGridPrim = (!PROFILER_ID)
                   End If
               End With
               intActX_ID = Get_ComponentID("FN_PsyMSE", "SocialHist")
               If lngGridPrim = 0 Then
                   strSQL = "Write_Patient_Profiler " & piPatientID & "," _
                       & piEncounterID & "," & intActX_ID & ", 'optDrinkYes', 1,'True','FN_PsyMSE.SocialHist', 1,'" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" _
                       & PsUserID & "'"
                   Set rsWrite = cnWrite.Execute(strSQL)
               Else
                   strSQL = "Update_Patient_Profiler 'True',1,'" _
                       & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & lngGridPrim
                   Set rsWrite = cnWrite.Execute(strSQL)
                    lngGridPrim = 0
                    strSQL = "Get_Profiler_Value 'FN_PsyMSE.SocialHist', 'optDrinkNo',1," & piPatientID & "," & piEncounterID
                    Set rsWrite = cnWrite.Execute(strSQL)
                       With rsWrite
                           If Not .EOF Then
                               lngGridPrim = (!PROFILER_ID)
                           End If
                       End With
                    If lngGridPrim > 0 Then
                       strSQL = "Update_Patient_Profiler 'False',1,'" _
                           & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "'," & lngGridPrim
                       Set rsWrite = cnWrite.Execute(strSQL)
                    End If
               End If
        End If
    End If
    If Trim(strDrug) <> vbNullString Then
        lngGridPrim = 0
