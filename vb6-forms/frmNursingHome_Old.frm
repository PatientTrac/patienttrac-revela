                Case "Legal", "Attorney"
                    Get_Legal_Contact lngPatID
                    If clsLegal.Practice <> vbNullString Then
                        strLastName = clsLegal.Name & ", " & clsLegal.Practice & " " & Trim(strStatus) & " " & Trim(strReason) & vbNewLine & "Appointment Time:" & " " & Format(strTime, "hh:mm AM/PM")
                    Else
                        strLastName = clsLegal.Name & " " & Trim(strStatus) & " " & Trim(strReason) & vbNewLine & "Appointment Time:" & " " & Format(strTime, "hh:mm AM/PM")
                    End If
                Case "Physician"
                    Get_Referral lngPatID
                    strLastName = clsReferral.Physician & " " & Trim(strStatus) & " " & Trim(strReason) & vbNewLine & "Appointment Time:" & " " & Format(strTime, "hh:mm AM/PM")
            End Select
            Select Case IsProperCase(strStatus)
                Case "Rescheduled"
                    If IsProperCase(strReason) = "Change" Then strReason = vbNullString
                    If Trim(strLastName) <> vbNullString Then
                        If Trim(cctDoctor.Text) = vbNullString Then
                            cctDoctor.Text = Trim(strLastName)
                        ElseIf Not TextFound(Trim(strLastName), Trim(cctDoctor.Text), Len(Trim(strLastName)), True) Then
                            cctDoctor.Text = Trim(cctDoctor.Text) & vbNewLine & strLine & vbNewLine & Trim(strLastName)
                        End If
                    End If
                Case "Cancelled", "No Show"
                    Remove_Data lngPatID
                    If Trim(strLastName) <> vbNullString Then
                        If Trim(cctDoctor.Text) = vbNullString Then
                            cctDoctor.Text = Trim(strLastName)
                        ElseIf Not TextFound(Trim(strLastName), Trim(cctDoctor.Text), Len(Trim(strLastName)), True) Then
                            cctDoctor.Text = Trim(cctDoctor.Text) & vbNewLine & strLine & vbNewLine & Trim(strLastName)
                        End If
                    End If
            End Select
        Loop
    End With
    If cnChange.State = adStateOpen Then
        cnChange.Close
        Set cnChange = Nothing
        Set rsChange = Nothing
        Set Flds = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Changes:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Get_Changes", Me.Name
    Exit Function
    Resume
End Function
