    Arr = Split(LookUpCellTag("RECORD REVIEW"), "|")
    If UBound(Arr) > 0 Then
        lngRow = Arr(1)
    End If
    With grdPrintForm
          For lngCol = 2 To .MaxCols
            .Col = lngCol
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If UCase(.CellTag) = "RECORD REVIEW" Then
                    If .CellType = CellTypeCheckBox Then
                        Select Case IsProperCase(.TypeCheckText)
                            Case "Chart Reviewed"
                                If Trim(udtEM_Value.RecRev) <> vbNullString Then
                                    .Text = "1"
                                End If
                            Case "Case Discussed With Staff"
                                If Trim(udtEM_Value.Staff_Discuss) <> vbNullString Then
                                    .Text = "1"
                                End If
                            Case "Medication Evaluation Rendered"
                                If Trim(udtEM_Value.Medication_Evaluation) <> vbNullString Then
                                    .Text = "1"
                                End If
                            Case "Systems Review"
                                If Trim(udtEM_Value.System_Review) <> vbNullString Then
                                    .Text = "1"
                                End If
                        End Select
                    End If
                End If
            End If
          Next lngCol
    End With
    mbooLoad = False
    If cnPlan.State = adStateOpen Then
        cnPlan.Close
        Set cnPlan = Nothing
        Set rsPlan = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Batch_Record_Evaluation:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_Batch_Record_Evaluation", Me.Name
    Exit Function
    Resume Next
End Function

Private Function Read_Vital_Signs()
Dim lngRow As Long
Dim lngCol As Long
Dim Arr
Dim Idx%
Dim bData As Boolean

    On Error GoTo Error_Read_Vital_Signs
    With grdReport
        Arr = Split(LookUpHeaderRow("VITAL SIGNS"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
        End If
        If lngRow > 0 Then
            For lngRow = lngRow To .MaxRows
                For lngCol = 2 To .MaxCols
                    .Col = lngCol
                    .Row = lngRow
                    If .CellTag <> vbNullString Then
                        Select Case UCase(.CellTag)
                            Case "BP_FIELD"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsVitals.Systolic & "/" & clsVitals.Diastolic, "TypeHAlignLeft", "BP_FIELD", True
                            Case "TEMP_FIELD"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsVitals.Temperature, "TypeHAlignLeft", "TEMP_FIELD", True
                            Case "PULSE_FIELD"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsVitals.Pulse, "TypeHAlignLeft", "PULSE_FIELD", True
                            Case "RESP_FIELD"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsVitals.Respiratory_Rate, "TypeHAlignLeft", "RESP_FIELD", True
                            Case "WEIGHT_FIELD"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsVitals.Weight_Lb, "TypeHAlignLeft", "WEIGHT_FIELD", True
                            Case "PREV_WEIGHT"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", clsVitals.Prev_Weight_Lb, "TypeHAlignLeft", "PREV_WEIGHT", True
                            Case "PAIN_SCALE"
                                Format_CellTypeEdit grdReport, lngRow, lngCol, "4", clsVitals.PainScale, "TypeHAlignLeft", "PAIN_SCALE", True
                                bData = True
                                Exit For
                        End Select
                    End If
                Next lngCol
                If bData Then Exit For
            Next lngRow
        End If
    End With
    Exit Function
Error_Read_Vital_Signs:
    Resume Next
    Exit Function
End Function

