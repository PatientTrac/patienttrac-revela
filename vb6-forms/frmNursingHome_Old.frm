Private Function Get_Current_Roster()
Dim strSQL As String
Dim cnSpec As New ADODB.Connection
Dim rsSpec As New ADODB.Recordset
Dim lngRow As Long
Dim varCellValue
Dim lngFac As Long
Dim strFac As String
Dim strDate As String
Dim strCurDate As String

    On Error GoTo Error_Get_Current_Roster
    Screen.MousePointer = vbHourglass
    grdFacility.GetText 1, grdFacility.ActiveRow, varCellValue
    If Trim(varCellValue) <> vbNullString Then strFac = Trim(varCellValue)
    lngFac = grdFacility.GetRowItemData(grdFacility.ActiveRow)
    If lngFac > 0 Then
        If cnSpec.State = adStateClosed Then cnSpec.open psConnect(0)
        strSQL = "SELECT DISTINCT ENCNTR_START_DATE FROM ENCOUNTER WHERE " _
            & "FACILITY_ID = " & lngFac & " AND  " _
            & "CONVERT(VARCHAR(10), ENCNTR_START_DATE, 101) > '02/01/2012' AND " _
            & "CURRENT_STATE = 'WORKUP' AND PURGE = 0 ORDER BY ENCNTR_START_DATE DESC"
        Set rsSpec = cnSpec.Execute(strSQL)
        With rsSpec
            Do Until .EOF
                strCurDate = (!ENCNTR_START_DATE)
                If Trim(strCurDate) <> vbNullString And Format(strCurDate, "mm/dd/yyyy") <> "01/01/1900" Then
                    Exit Do
                End If
                .MoveNext
            Loop
        End With
    End If
   If Trim(strCurDate) <> vbNullString Then
        udtInPatSched.Appt_Date = Format(strCurDate, "mm/dd/yyyy")
        ccdPrevDate.Value = Format(udtInPatSched.Appt_Date, "mm/dd/yyyy")
    End If
    If cnSpec.State = adStateOpen Then
        cnSpec.Close
        Set cnSpec = Nothing
        Set rsSpec = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Current_Roster:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Get_Current_Roster", Me.Name
    Exit Function
    Resume Next
End Function


