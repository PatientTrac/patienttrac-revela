Private Function Collect_Nursing_MSE()
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim ArrTerms
Dim ArrVerbal
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim varCellValue
Dim strDate As String
Dim lngData As Long
Dim bData As Boolean
Dim Idx%
Dim strTerms As String
Dim lngCollect As Long
Dim lngStart As Long
Dim strHomical As String
Dim strSuicide As String
Dim strNote As String
Dim lngTargetRow As Long
Dim lngActiveRow As Long
Dim strWear As String


    On Error GoTo Error_Collect_Nursing_MSE
    Screen.MousePointer = vbHourglass
    grdReport.sheet = clsGridFormat.SheetNumber
    grdReport.ActiveSheet = clsGridFormat.SheetNumber
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    mbooLoad = True
    Arr = Split(LookUpCellTag("LEVEL OF CONSCIOUSNESS"), "|")
    If UBound(Arr) > 0 Then
        lngStart = Arr(1)
    End If
    If lngStart = 0 Then
        Arr = Split(LookUpCellTag("CONSCIOUSNESS"), "|")
        If UBound(Arr) > 0 Then
            lngStart = Arr(1)
        End If
    End If
    If lngStart = 0 Then lngStart = 7
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "Read_Mental_Status_New " & piPatientID & "," & piEncounterID
    Set rsWrite = cnWrite.Execute(strSQL)
    With rsWrite
        Do Until .EOF
            Clear_New_MSE
            bData = False
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "MSE_ITEM"
                                udtNew_MSE.MSE_Item = Trim(Fld.Value)
                            Case "MSE_DATA"
                                udtNew_MSE.MSE_Data = Trim(Fld.Value)
                            Case "MSE_NOTES"
                                udtNew_MSE.MSE_Note = Trim(Fld.Value)
                        End Select
                    End If
                End If
            Next
            .MoveNext
            lngRow = 0
            udtNew_MSE.MSE_Data = Replace(udtNew_MSE.MSE_Data, ",,", "")
            udtNew_MSE.MSE_Data = Trim(udtNew_MSE.MSE_Data)
            udtNew_MSE.MSE_Data = Replace(udtNew_MSE.MSE_Data, ";", ",")
            If Trim(udtNew_MSE.MSE_Data) <> vbNullString Then
'                For lngRow = lngRow To grdReport.MaxRows
                   ' grdReport.GetText 1, lngRow, varCellValue
                    Select Case IsProperCase(udtNew_MSE.MSE_Item)
                        Case "Consciousness", "Level Of Consciousness"
                            Arr = Split(LookUpHeaderRow("Level Of Consciousness"), "|")
                            If UBound(Arr) > 0 Then
                                lngRow = Arr(1)
                            Else
                                Arr = Split(LookUpHeaderRow("Consciousness"), "|")
                                If UBound(Arr) > 0 Then
                                    lngRow = Arr(1)
                                End If
                            End If
                            If lngRow > 0 Then
                                ArrTerms = Split(udtNew_MSE.MSE_Data, ",")
                                If UBound(ArrTerms) > 0 Then
                                    For Idx = LBound(ArrTerms) To UBound(ArrTerms)
                                        udtNew_MSE.MSE_Data = vbNullString
                                        If Trim(ArrTerms(Idx)) <> vbNullString Then
                                            udtNew_MSE.MSE_Data = Trim(ArrTerms(Idx))
                                            For lngCol = 2 To grdReport.MaxCols
                                                grdReport.Col = lngCol
                                                grdReport.Row = lngRow
                                                If grdReport.CellType = CellTypeCheckBox Then
                                                    If Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                                          grdReport.Text = "1"
                                                          bData = True
                                                    End If
                                                End If
                                            Next lngCol
                                            If Trim(IsProperCase(udtNew_MSE.MSE_Data)) <> vbNullString Then
                                                If Trim(IsProperCase(udtNew_MSE.MSE_Data)) = "Alert" Then
                                                    For lngCol = 2 To grdReport.MaxCols
