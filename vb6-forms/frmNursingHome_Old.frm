                                    grdReport.InsertRows lngRow, 1
                                    grdReport.MaxRows = grdReport.MaxRows + 1
                                    Format_CellTypeSplit grdReport, lngRow, 2, "maxcols", Trim(clsGridFormat.Text), "TypeHAlignLeft", clsGridFormat.CellTag
                                    clsYBOCS.Notes = Trim(clsYBOCS.Notes) & vbNewLine & clsGridFormat.Text
                                End If
                            End If
                        Next Idx
                    Else
                        Format_CellTypeEdit grdReport, lngRow, 2, "maxcols", Trim(clsYBOCS.Notes), "TypeHAlignLeft", clsGridFormat.CellTag
                    End If
            End Select
        End If
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Polulate_Scales:
    Screen.MousePointer = vbDefault
