        If .CellTag <> vbNullString Then
            clsGridFormat.CellTag = .CellTag
        End If
        If clsGridFormat.CellTag = "SIGNATURE_MD" Or clsGridFormat.CellTag = "SIGNATURE_NURSE" Then
                grdReport.sheet = clsGridFormat.SheetNumber
                mstrPatOcx = "FN_PsyMse"
                mstrPatCtl = "Signature"
                frmLoadControl.piSelEnctrID = piEncounterID
                frmLoadControl.piSelPatientID = piPatientID
                frmLoadControl.Caption = "E-Signature"
'                Load frmLoadControl
                frmLoadControl.Show vbModal
                Set_Image strTerm, Row, Col, "4"
                Screen.MousePointer = vbDefault
                Exit Sub
        ElseIf clsGridFormat.CellTag = "CLOCK_IMAGE" Then
            grdReport.sheet = clsGridFormat.SheetNumber
            mstrPatOcx = "FN_PsyROS"
            mstrPatCtl = "MMSECircle"
            frmLoadControl.piSelEnctrID = piEncounterID
            frmLoadControl.piSelPatientID = piPatientID
            frmLoadControl.Caption = "Patient Clock Drawing"
            frmLoadControl.Show vbModal
            mbooWrite = True
            Get_Clock_History
            '-----------------------
            lngCol = 4
            If FileExists(clsClockDraw.Image) Then
                Format_CellTypePicture grdReport, Row, lngCol, "1", clsClockDraw.Image, "TypeHAlignCenter", "CLOCK_IMAGE", 70
                grdReport.SetCellBorder lngCol, Row, lngCol, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
            Else
                Format_CellTypeEdit grdReport, Row, lngCol, "2", clsClockDraw.Comments, "TypeHAlignCenter", "CLOCK_IMAGE"
            End If
            If Trim(clsClockDraw.Recall1) <> vbNullString Then
                clsClockDraw.Recall1 = "Memory recall after clock drawing was:" & vbNewLine & clsClockDraw.Recall1
            End If
            If Trim(clsClockDraw.Recall2) <> vbNullString Then
                If Trim(clsClockDraw.Recall1) <> vbNullString Then
                    clsClockDraw.Recall1 = clsClockDraw.Recall1 & vbNewLine & clsClockDraw.Recall2
                Else
                    clsClockDraw.Recall1 = clsClockDraw.Recall2
                End If
            End If
            If Trim(clsClockDraw.Recall3) <> vbNullString Then
                If Trim(clsClockDraw.Recall1) <> vbNullString Then
                    clsClockDraw.Recall1 = clsClockDraw.Recall1 & vbNewLine & clsClockDraw.Recall3
                Else
                    clsClockDraw.Recall1 = clsClockDraw.Recall3
                End If
            End If
            lngRow = Row + 1
            If grdReport.MaxRows < lngRow Then grdReport.MaxRows = grdReport.MaxRows + 1
            If Trim(clsClockDraw.Recall1) <> vbNullString Then
                Format_CellTypeEdit grdReport, lngRow, lngCol, "2", clsClockDraw.Recall1 & vbNewLine & clsClockDraw.Comments, "TypeHAlignleft", "CLOCK_IMAGE"
                grdReport.SetCellBorder lngCol, lngRow, lngCol, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
            ElseIf clsClockDraw.Comments <> vbNullString Then
                Format_CellTypeEdit grdReport, lngRow, lngCol, "2", clsClockDraw.Comments, "TypeHAlignleft", "CLOCK_IMAGE"
            End If
            lngRow = 0
            For lngRow = 1 To 6
                grdReport.GetText 1, lngRow, varCellValue
                If Trim(varCellValue) = "PHYSICIAN'S FINDINGS" Then
                    Exit For
                End If
            Next lngRow
            If lngRow > Row Then
                lngCol = 2
                Format_CellTypeEdit grdReport, lngRow, lngCol, "4", clsClockDraw.PhysFinding, "TypeHAlignLeft", "CLOCK_IMAGE"
            End If
        ElseIf clsGridFormat.CellTag = "PENTAGON_IMAGE" Then
            grdReport.sheet = clsGridFormat.SheetNumber
            mstrPatOcx = "FN_PsyROS"
            mstrPatCtl = "MMSEPentagon"
            frmLoadControl.piSelEnctrID = piEncounterID
            frmLoadControl.piSelPatientID = piPatientID
            frmLoadControl.Caption = "Patient Pentagon Drawing"
'            Load frmLoadControl
            frmLoadControl.Show vbModal
            clsClockDraw.Image = vbNullString
            Get_Pentagon
            If FileExists(clsClockDraw.Image) Then
                lngCol = 2
                Format_CellTypeEdit grdReport, Row, lngCol, "1", "(1/1)", "TypeHAlignCenter", "SENTENCE", True
                lngCol = 4
                Format_CellTypePicture grdReport, Row, lngCol, "1", clsClockDraw.Image, "TypeHAlignCenter", "SENTENCE LANGUAGE", 70
                grdReport.SetCellBorder lngCol, Row, lngCol, Row, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
            Else
                lngCol = 2
                Format_CellTypeEdit grdReport, Row, lngCol, "1", "(1/0)", "TypeHAlignLeft", "SENTENCE", True
                lngCol = 4
                Format_CellTypeEdit grdReport, Row, 5, "2", clsClockDraw.Comments, "TypeHAlignCenter", "SENTENCE LANGUAGE"
            End If
            mbooWrite = True
'-------------------------
        ElseIf clsGridFormat.CellTag = "SENTENCE LANGUAGE" Then
            grdReport.sheet = clsGridFormat.SheetNumber
            mstrPatOcx = "FN_PsyROS"
            mstrPatCtl = "MMSESentence"
            frmLoadControl.piSelEnctrID = piEncounterID
            frmLoadControl.piSelPatientID = piPatientID
            frmLoadControl.Caption = "Patient Sentence Language"
            frmLoadControl.Show vbModal
            clsClockDraw.Image = vbNullString
            Get_MMSE_Sentence
            mbooWrite = True
            If FileExists(clsClockDraw.Image) Then
                lngCol = 2
                Format_CellTypeEdit grdReport, Row, lngCol, "1", "(1/1)", "TypeHAlignCenter", "PENTAGON", True
                lngCol = 4
                Format_CellTypePicture grdReport, Row, lngCol, "1", clsClockDraw.Image, "TypeHAlignCenter", "PENTAGON_IMAGE", 70
                grdReport.SetCellBorder lngCol, Row, lngCol, Row, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                
            Else
                lngCol = 2
                Format_CellTypeEdit grdReport, Row, lngCol, "1", "(1/0)", "TypeHAlignLeft", "PENTAGON", True
                lngCol = 4
                Format_CellTypeEdit grdReport, Row, 5, "2", clsClockDraw.Comments, "TypeHAlignCenter", "PENTAGON_IMAGE"
            End If
        ElseIf clsGridFormat.CellTag = "REFERRAL_OTHER_NOTES" Then
            grdReport.GetText 4, Row, varCellValue
            If Trim(varCellValue) <> vbNullString Then
                frmComment_All.mstrCommentItem = Trim(varCellValue)
            Else
                frmComment_All.mstrCommentItem = vbNullString
            End If
            frmComment_All.Caption = "REFERRAL REASON"
            frmComment_All.Show vbModal
            If Trim(frmComment_All.mstrCommentItem) <> vbNullString Then
                clsReport.Referral_Other = frmComment_All.mstrCommentItem
                Format_CellTypeEdit grdPrintForm, Row, 4, "3", Trim(clsReport.Referral_Other), "TypeHAlignLeft", "REFERRAL_OTHER_NOTES"
                Write_Referral_Other
                mbooLoad = True
                .Col = 2
                .Row = Row
                If .CellType = CellTypeCheckBox Then
                    If .Text = "0" Then .Text = "1"
                End If
            End If
            clsReport.Referral_Other = vbNullString
        Else
            .Col = 2
            .Row = Row
            If grdReport.CellTag <> vbNullString Then
                clsGridFormat.CellTag = grdReport.CellTag
            End If
            mstrPatOcx = vbNullString: mstrPatCtl = vbNullString
            Select Case UCase(clsGridFormat.CellTag)
                Case "DIAGNOSIS"
                    mstrPatOcx = "FN_PsyMse"
                    mstrPatCtl = "Diagnosis"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "Diagnosis"
                    frmLoadControl.Show vbModal
                    Values_Psychiatry ("DIAGNOSIS")
                    lngCol = 2
                    Format_CellTypeEdit grdReport, Row, 2, "5", Trim(mstrRowData), "TypeHAlignLeft", "DIAGNOSIS"
                    mbooWrite = True
                Case "COMPLAINT"
                    mstrPatOcx = "FN_PsyMse"
                    mstrPatCtl = "HPI"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "Chief Complaint"
                    frmLoadControl.Show vbModal
                    Values_Psychiatry ("CHIEF COMPLAINT")
                    lngCol = 2
                    Format_CellTypeEdit grdReport, Row, 2, "5", Trim(clsReport.ChiefComplaint), "TypeHAlignLeft", "COMPLAINT"
                    mbooWrite = True
                 Case "HISTORY", "HISTORY PRESENT ILLNESS", "HISTORY OF PRESENT ILLNESS", "CURRENT_HISTORY", "CURRENT HISTORY", "CURRENT SYMPTOMS"
                    If clsEDI_Client.Site_ID = "9702" Then
                        mstrPatOcx = "FN_PsyMse": mstrPatCtl = "Psych_History"
                    Else
                        If Val(clsPatient.Age) < 18 Then
                            mstrPatOcx = "FN_PsyRos": mstrPatCtl = "ChildDevRos"
                        Else
                            mstrPatOcx = "FN_PsyRos": mstrPatCtl = "PsyRevAll"
                        End If
                    End If
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "History Present Illness"
                    frmLoadControl.Show vbModal
                    Values_Psychiatry "HISTORY"
                    Add_History Row, "HISTORY"
'                    Remove_History_Notes "CURRENT HISTORY"
'                    Values_Psychiatry "HISTORY"
'                    If Trim(mstrRowData) <> vbNullString Then
'                        Add_History lngRow, "CURRENT HISTORY"
'                    End If

                    mbooWrite = True
 '----------------------------
                Case "VITALS", "VITAL SIGNS", "VITAL", "PAIN"
                    mstrPatOcx = "FN_Orders"
                    mstrPatCtl = "PatientVitals"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "Vital Signs"
                    frmLoadControl.Show vbModal
                    Values_Psychiatry ("VITAL SIGNS")
                    Read_Vital_Signs
                    mbooWrite = True
'--------------------
                Case "ALLERGIES"
                    mstrPatOcx = "PT_Medications"
                    mstrPatCtl = "NAllergy"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "Allergies"
'                    Load frmLoadControl
                    frmLoadControl.Show vbModal
                    Values_Psychiatry ("ALLERGIES")
                    lngCol = 2
                    Format_CellTypeEdit grdReport, Row, lngCol, "5", Trim(clsReport.AllergyData), "TypeHAlignLeft", "ALLERGIES"
                    mbooWrite = True
            Case "REVIEW OF SYSTEMS", "MEDICAL REVIEW OF SYSTEMS", "MEDICAL ROS"
                    mstrPatOcx = "FN_RevSys"
                    mstrPatCtl = "ReviewSystems"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "MEDICAL REVIEW OF SYSTEMS"
'                    Load frmLoadControl
                    frmLoadControl.Show vbModal
                    Values_Psychiatry ("MEDICAL REVIEW OF SYSTEMS")
                    lngCol = 2
                    Format_CellTypeEdit grdReport, Row, lngCol, "5", Trim(clsReport.MedRos), "TypeHAlignLeft", "REVIEW OF SYSTEMS"
                    ' need to check "Chart Reviewed" if not checked
                    mbooWrite = True
                Case "RECOMMENDATION", "RECOMMENDATIONS"
                    Read_Recommendation piPatientID, piEncounterID
                    If Trim(clsReport.Recommendation) <> vbNullString Then
                        Strip_Recommendation CStr(varCellValue)
                        frmComment_All.mstrCommentItem = clsReport.Recommendation
                    Else
                        frmComment_All.mstrCommentItem = vbNullString
                    End If
                    frmComment_All.CommentType = "Recommendation"
                    frmComment_All.Caption = clsGridFormat.CellTag
                    frmComment_All.Show vbModal
                    If frmComment_All.mstrCommentItem = vbNullString Then
                        Values_Psychiatry "RECOMMENDATION"
                    Else
                        clsReport.Recommendation = frmComment_All.mstrCommentItem
                    End If
                    If Trim(clsReport.Recommendation) <> vbNullString Then
                        Strip_Recommendation clsReport.Recommendation
                        Format_CellTypeEdit grdReport, Row, 2, "5", clsReport.Recommendation, "TypeHAlignLeft", "RECOMMENDATIONS"
                        WriteDataGrid "RECOMMENDATION", clsReport.Recommendation
                        Write_Recommendation piPatientID, piEncounterID, clsGridFormat.CellTag
                    End If
                    mbooWrite = True
                Case "CURRENT_MEDICATIONS", "CURRENT MEDICATIONS"
                    mstrPatOcx = "PT_Medications"
                    mstrPatCtl = "Prescription"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "Medications"
'                    Load frmLoadControl
                    frmLoadControl.Show vbModal
                    Get_CurrentMeds
                    lngCol = 2
                    Format_CellTypeEdit grdReport, Row, 2, "5", Trim(clsReport.CurrentMed), "TypeHAlignLeft", "CURRENT_MEDICATIONS"
                    mbooWrite = True
'----------------

                Case "MEDICATION ORDERS"
                    mstrPatOcx = "PT_Medications"
                    mstrPatCtl = "Prescription"
                    frmLoadControl.piSelEnctrID = piEncounterID
                    frmLoadControl.piSelPatientID = piPatientID
                    frmLoadControl.Caption = "Medications"
'                    Load frmLoadControl
                    frmLoadControl.Show vbModal
                    Values_Psychiatry ("MEDICATION ORDERS")
                    mstrRowData = Replace(mstrRowData, "''", "'")
                    mstrRowData = Replace(mstrRowData, Chr(34), "'")
                    lngCol = 2
                    Format_CellTypeEdit grdReport, Row, 2, "5", Trim(mstrRowData), "TypeHAlignLeft", "MEDICATION ORDERS"
                    mbooWrite = True
'---------------
                Case "SUBJECTIVE"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "OBJECTIVE"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.ZOrder 0
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "ASSESSMENT"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "PLAN", "PLAN AND RECOMMENDATION"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "MOOD"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "PHYSICAL AIDS"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "PATIENT WAS WEARING", "GENERAL APPEARANCE"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    If TextFound("patient was wearing", varCellValue, Len("patient was wearing"), True) Then
                        cctDoctor = Replace(varCellValue, "Patient was wearing", "")
                        fraDoctor.Visible = True
                    End If
                    mbooWrite = True
                Case "PRIOR_MEDICAL_NOTES", "PRIOR_SURGERY_NOTES", "PRIOR_HOSP_NOTES"
                    cctDoctor = vbNullString
                    .GetText 2, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
                Case "OTHER_SOCIAL", "ALCOHOL_TYPE", "DRUG_TYPE"
                    cctDoctor = vbNullString
                    .GetText 3, Row, varCellValue
                    cctDoctor = Trim(varCellValue)
                    fraDoctor.Visible = True
                    mbooWrite = True
            End Select
            .LeftCol = 1
        End If
    End With
    grdReport.ActiveSheet = clsGridFormat.SheetNumber
    clsGridFormat.CellTag = vbNullString
    grdReport.ReDraw = True
    Screen.MousePointer = vbDefault
    Exit Sub
Error_grdReport_DblClick:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, CStr(varHeader), "grdReport_DblClick", Me.Name
    Exit Sub
    Resume Next
End Sub
