Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim cnRead As New ADODB.Connection
Dim rsRead As New ADODB.Recordset
Dim Arr
Dim Idx As Integer

    On Error GoTo Error_ReadDataGrid
    Screen.MousePointer = vbHourglass
    mstrGridNote = vbNullString
    mbooByPass = True
    mbooHasChanged = True
    mbooLoad = True
    If UCase(clsEncounter.ServicePlace) = "INPATIENT HOSPITAL" And UCase(clsEncounter.EncounterType) = "INITIAL INPATIENT" Then
        Get_PsychAdmission piPatientID, piEncounterID
    End If
    mstrRowData = vbNullString
    If cnRead.State = adStateClosed Then cnRead.open psConnect(0)
    strSQL = "Get_InPatient_Notes_Read_Data_Grid 'CURRENT HISTORY', " & piPatientID & ", " & piEncounterID
    Set rsRead = cnRead.Execute(strSQL)
    With rsRead
        Do Until rsRead.EOF
            lngRow = 0
            If Not IsNull(!Note_Type) Then
                If Trim(!Note_Type) <> vbNullString Then
                    If Not IsNull(!NOTES_DESC) Then
                        If Trim(!NOTES_DESC) <> vbNullString And (!Note_Type) <> "ADDITIONAL NOTES" _
                            And (!Note_Type) <> "RECOMMENDATION" And (!Note_Type) <> "NOTES" And (!Note_Type) <> "PHYSICIAN NOTES" Then
                            clsGridFormat.Text = vbNullString
                            clsGridFormat.Text = Trim(!NOTES_DESC)
                            Arr = Split(clsGridFormat.Text, ",")
                            If UBound(Arr) > 0 Then
                                clsGridFormat.Text = vbNullString
                                For Idx = LBound(Arr) To UBound(Arr)
