    On Error GoTo Error_LookUpHeaderRow
    Screen.MousePointer = vbHourglass
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        LookUpHeaderRow = vbNullString
        If IsProperCase(mstrPractice) = "Psychiatry" Or IsProperCase(mstrPractice) = "Gyn" Or UCase(mstrPractice) = "IVF" Then lngRow = 7 Else lngRow = 12
            For lngRow = lngRow To .MaxRows
                .Col = 1
                .Row = lngRow
                .GetText 1, lngRow, varCellValue
                If Trim(varCellValue) <> vbNullString Then
                    'If varCellValue <> "PLAN AND RECOMMENDATIONS" Then
'                        If varCellValue <> "FAMILY PSYCHIATRIC HISTORY" Then
'                            If Trim(varCellValue) <> vbNullString And TextFound(Trim(vstrName), Trim(varCellValue), Len(Trim(vstrName)), True) Then
