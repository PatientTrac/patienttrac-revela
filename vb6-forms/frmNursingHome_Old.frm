Private Function Save_Instruction_Notes()
Dim cnNotes As New ADODB.Connection
Dim rsNote As New ADODB.Recordset
Dim strSQL As String
Dim strCntr As String
Dim lngPrimKey As Long
Dim lngSeq As Long
Dim strEncrDate As String
Dim IntActX As Integer
Dim lngFac As Long

    On Error GoTo Error_Save_Instruction_Notes
    Screen.MousePointer = vbHourglass
    lngFac = piFacilityID
    strEncrDate = Get_Enctr_Date(piEncounterID)
    If strEncrDate <> vbNullString Then
        strEncrDate = strEncrDate
    Else
        strEncrDate = Format(Now, "mm/dd/yyyy")
    End If
    piFacilityID = lngFac
    lngSeq = 1
    If cnNotes.State = adStateClosed Then cnNotes.open psConnect(0)
    strSQL = "Get_Patient_Notes_Clinical_Value_Ref 'cctNotes', 'FN_PsyMse.Plan', " & piPatientID & "," & piEncounterID
        Set rsNote = cnNotes.Execute(strSQL)
        With rsNote
            If Not .EOF Then
                lngPrimKey = (!PATIENT_NOTE_ID)
            End If
        End With
    If Trim(Right(clsPlan.PhysNote, 1)) = "'" Then
        Right(clsPlan.PhysNote, 1) = ""
    End If
    If Len(Trim(clsPlan.PhysNote)) <= 4 Then
        clsPlan.PhysNote = Replace(clsPlan.PhysNote, vbNewLine, vbNullString)
    End If
    IntActX = Get_ComponentID("FN_PsyMse", "Plan")
     clsPlan.PhysNote = Replace(clsPlan.PhysNote, "'", "''")
    If Trim(clsPlan.PhysNote) <> vbNullString Then
        If lngPrimKey = 0 Then
            strSQL = "Write_Patient_Note " & piPatientID & ", " & piEncounterID & "," & piProviderID & ", " & IntActX & ", 'cctNotes', " & lngSeq & ",'" _
                & clsPlan.PhysNote & "','FN_PsyMse.Plan', 1,'" & Format(strEncrDate, "mm/dd/yyyy hh:mm:ss AM/PM") & "','" & PsUserID & "' "
            Set rsNote = cnNotes.Execute(strSQL)
        Else
            strSQL = "Update_Patient_Note '" & clsPlan.PhysNote & "','" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', " & lngPrimKey
            Set rsNote = cnNotes.Execute(strSQL)
        End If
    End If
    If cnNotes.State = adStateOpen Then
        cnNotes.Close
        Set cnNotes = Nothing
        Set rsNote = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Save_Instruction_Notes:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, clsPlan.PhysNote & " " & strSQL, "Save_Instruction_Notes", Me.Name
    Exit Function
    Resume
End Function
Private Function WriteDataGrid(Optional vstrCellTag As String, Optional vstrData As String)
Dim lngRow As Long
Dim varCellValue
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strNoteDesc As String
Dim sDate As String
Dim lngPrimKey As Long
Dim booinsert As Boolean
Dim lngGridPrim As Long
Dim booCosPlan As Boolean
Dim strPlan As String
Dim lngCol As Long
Dim Arr
Dim lngID As Long
Dim strData As String
Dim booSkip As Boolean
Dim strCellTag As String

    On Error GoTo Error_WriteDataGrid
    Screen.MousePointer = vbHourglass
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    If clsEncounter.StartDate <> vbNullString Then
        sDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        sDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    mbooLoad = True
    Select Case UCase(vstrCellTag)
        Case "STRENGTH", "STRENGTHS/ASSETS"
            strCellTag = "STRENGTHS/ASSETS"
        Case "LIMITATIONS", "LIMITATIONS/LIABILITIES"
            strCellTag = "LIMITATIONS/LIABILITIES"
        Case "ADDITIONAL NOTES", "ADDITIONAL DATA", "ADDITIONAL NOTES/DATA", "NOTES"
            strCellTag = "ADDITIONAL NOTES"
        Case "ASSESSMENT"
            strCellTag = "ASSESSMENT"
        Case "ADL CAPACITY"
            strCellTag = "ADL CAPACITY"
        Case "IMPRESSION"
            strCellTag = "IMPRESSION"
        Case "RECOMMENDATION", "RECOMMENDATIONS"
            strCellTag = "RECOMMENDATION"
        Case "JUSTIFICATION", "JUSTIFICATION FOR ADMISSION", "ADMIT PATIENT"
            strCellTag = "JUSTIFICATION FOR ADMISSION"
        Case "ADDITIONAL RISKS", "ADDITIONAL RISKS REQUIRING MONITORING"
            strCellTag = "ADDITIONAL RISKS REQUIRING MONITORING"
        Case "PROBLEM LIST", "PROBLEM LIST / TREATMENT PLAN"
            strCellTag = "PROBLEM LIST"
        Case "RESTRAINT"
            strCellTag = "RESTRAINT RISKS"
        Case "ADMIT PATIENT", "ADMIT PATIENT FOR"
            strCellTag = "ADMIT PATIENT FOR"
        Case "PROGNOSIS"
            strCellTag = "PROGNOSIS"
        Case "CRITERIA", "CRITERIA FOR DISCHARGE"
            strCellTag = "CRITERIA FOR DISCHARGE"
        Case "ESTIMATED LENGTH", "ESTIMATED LENGTH OF STAY"
            strCellTag = "ESTIMATED LENGTH"
        Case "FACE"
            strCellTag = "FACE"
        Case "BODY"
            strCellTag = "BODY"
        Case "NOSE"
            strCellTag = "NOSE"
        Case "OTHER"
            strCellTag = "OTHER"
        Case "INITIAL DISCHARGE", "INITIAL DISCHARGE PLAN / AFTERCARE TREATMENT"
            strCellTag = "INITIAL DISCHARGE PLAN / AFTERCARE TREATMENT"
    End Select
    If Trim(strCellTag) <> vbNullString And Trim(vstrData) <> vbNullString Then
        strData = Replace(vstrData, "'", "''")
        If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
        strSQL = "Get_InPatient_Notes_Type_PT_Enctr '" & Trim(strCellTag) & "'," & piPatientID & "," & piEncounterID
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            If Not rsWrite.EOF Then
                lngGridPrim = (!Note_ID)
            End If
        End With
        If lngGridPrim = 0 And Trim(strData) <> vbNullString Then
            strData = Replace(strData, "'", "''")
            strData = Replace(strData, "After a complete evaluation of the patients PFSH, Psychiatric Review of Systems, and a comprehensive Mental Status Examination" _
            & " " & "my recommendatations are as follows", "")
            strData = Trim(strData)
            strSQL = "Insert_InPatient_Notes " & piPatientID & "," & piEncounterID & "," & mlngLogonUser & "," _
                & psFacilityID & ",'" & clsEncounter.EncounterType & "','" & Trim(strData) & "','" _
                & Trim(strCellTag) & "','" & sDate & "'"
                Set rsWrite = cnWrite.Execute(strSQL)
        ElseIf Trim(strData) <> vbNullString Then
            strData = Replace(strData, "After a complete evaluation of the patients PFSH, Psychiatric Review of Systems, and a comprehensive Mental Status Examination" _
            & " " & "my recommendatations are as follows", "")
            strData = Trim(strData)
            strSQL = "Update_InPatient_Notes '" & Trim(strData) & "'," & lngGridPrim
            Set rsWrite = cnWrite.Execute(strSQL)
        End If
    End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_WriteDataGrid:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "WriteDataGrid", Me.Name
    Exit Function
    Resume Next
End Function


