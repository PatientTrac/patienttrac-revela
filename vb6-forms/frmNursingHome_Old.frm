Private Function Remove_PastSocial(vstrRowName As String, vstrRowData As String)
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim iAnswer As Integer
Dim lngGridPrim As Long

    mbooLoad = True
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        iAnswer = MsgBox("Do you want to delete" & " " & vstrRowName & "?", vbYesNo, "PatientTrac Electronic Medical Records")
        If iAnswer = vbYes Then
            strSQL = "Get_InPatient_Notes_PT_ID_ENCTR_ID_NOTE_TYPE '" & vstrRowName & "%'," & piPatientID & "," & piEncounterID
            Set rsWrite = cnWrite.Execute(strSQL)
            With rsWrite
                If Not rsWrite.EOF Then
                    lngGridPrim = (!Note_ID)
                End If
            End With
            If lngGridPrim > 0 Then
                strSQL = "DELETE INPATIENT_NOTES WHERE NOTE_ID = " & lngGridPrim
                Set rsWrite = cnWrite.Execute(strSQL)
            End If
        Else
            .Col = 2
            .Row = .ActiveRow
            mbooByPass = True
            If .CellType = CellTypeCheckBox Then
                .Text = "1"
             End If
        End If
    End With
    mbooLoad = False
End Function

