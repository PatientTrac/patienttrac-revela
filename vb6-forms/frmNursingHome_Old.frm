        Format_CellTypeEdit grdPrintForm, lngRow, 2, "2", UCase(cctFacility.Text), "TypeHAlignLeft"
        Format_CellTypeEdit grdPrintForm, lngRow, 4, "2", "ROOM NUMBER", "TypeHAlignLeft", "", False, 0, "", True
        Format_CellTypeEdit grdPrintForm, lngRow, 6, "2", clsPatient.RoomNumber, "TypeHAlignLeft", "", False, 0, "", True
