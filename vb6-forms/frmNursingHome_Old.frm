Private Function Format_Previous_Visits()
Dim strSQL As String
Dim cnSpec As New ADODB.Connection
Dim rsSpec As New ADODB.Recordset
Dim lngRow As Long
Dim varCellValue
Dim lngFac As Long
Dim strFac As String
Dim strDate As String
Dim strCurDate As String

    Screen.MousePointer = vbHourglass
    grdFacility.GetText 1, grdFacility.ActiveRow, varCellValue
    If Trim(varCellValue) <> vbNullString Then strFac = Trim(varCellValue)
    lngFac = grdFacility.GetRowItemData(grdFacility.ActiveRow)
    If lngFac > 0 Then
        With grdVisitDate
            .ReDraw = False
            .ClearRange 0, SpreadHeader, grdVisitDate.MaxCols, grdVisitDate.MaxRows, False
            .ProcessTab = True
            .FontBold = True
            .ColHeaderRows = 2
            .ColHeadersShow = True
            .RowHeadersShow = False
            .MaxCols = 1
            .ColWidth(1) = 37.7
            Add_Spacer SpreadHeader + 1, grdVisitDate
            .MaxRows = 0
            Format_CellTypeEdit grdVisitDate, SpreadHeader, 1, "1", "VISIT DATES FOR" & vbNewLine & strFac, "TypeHAlignCenter", "", False, HeaderColor, ""
            grdVisitDate.SetCellBorder 1, SpreadHeader, 2, SpreadHeader, 16, &H80&, CellBorderStyleSolid
            Add_Spacer SpreadHeader + 1, grdVisitDate
            If cnSpec.State = adStateClosed Then cnSpec.open psConnect(0)
            strSQL = "SELECT DISTINCT ENCNTR_START_DATE FROM ENCOUNTER WHERE " _
                & "FACILITY_ID = " & lngFac & " AND  " _
                & "CONVERT(VARCHAR(10), ENCNTR_START_DATE, 101) > '02/01/2012' AND " _
                & "CURRENT_STATE = 'MD COMPLETED' AND PURGE = 0 ORDER BY ENCNTR_START_DATE DESC"
            Set rsSpec = cnSpec.Execute(strSQL)
            With rsSpec
                Do Until .EOF
                    If Not IsNull((!ENCNTR_START_DATE)) Then
                        strCurDate = Format((!ENCNTR_START_DATE), "mm/dd/yyyy")
                    End If
                    .MoveNext
                    If Trim(strCurDate) <> vbNullString And strDate <> strCurDate And Format(strCurDate, "mm/dd/yyyy") <> "01/01/1900" Then
                        lngRow = grdVisitDate.MaxRows + 1
                        grdVisitDate.MaxRows = lngRow
                        Format_CellTypeEdit grdVisitDate, lngRow, 1, "1", Format(strCurDate, "mm/dd/yyyy"), "TypeHAlignLeft"
                        grdVisitDate.SetCellBorder 1, lngRow, 1, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                    End If
                    strDate = strCurDate
                Loop
            End With
            .ReDraw = True
        End With
    End If
    Screen.MousePointer = vbDefault
    Exit Function
End Function

Private Function Get_Batch_CellTag_Row(vstrName As String) As String
Dim lngRow As Long
Dim lngCol As Long
Dim varCellValue
Dim booExit As Boolean

    On Error GoTo Error_Get_Batch_CellTag_Row
    Screen.MousePointer = vbHourglass
    With grdPrintForm
        .sheet = clsGridFormat.SheetNumber
        Get_Batch_CellTag_Row = vbNullString
        For lngRow = 1 To .MaxRows
            For lngCol = 1 To .MaxCols
                .Col = lngCol
                .Row = lngRow
                If .CellTag <> vbNullString Then
                    If Trim(IsProperCase(vstrName)) = Trim(IsProperCase(.CellTag)) Then
                        Get_Batch_CellTag_Row = lngCol & "|" & lngRow
                        booExit = True
                        Exit For
                    End If
                End If
            Next lngCol
            If booExit Then Exit For
        Next lngRow
    End With
    Screen.MousePointer = vbDefault
