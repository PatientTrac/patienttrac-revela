        Populate_Scales strActName
    End If
    Read_PANNS
    If Trim(clsPanns.Notes) <> vbNullString Then
        strActName = "PANNS"
        Populate_Scales strActName
    End If
    Read_Quids
    If Trim(clsQuids.Notes) <> vbNullString Then
        strActName = "QUIDS_SR"
        Populate_Scales strActName
    End If
    Read_BiPolar
    If Trim(clsBiPolar.Notes) <> vbNullString Then
        strActName = "BIPOLAR"
        Populate_Scales strActName
    End If
    Read_MMSE
    If Trim(clsMMSE.MMSE_Sentence) <> vbNullString Then
        strActName = "MMSE"
        Populate_Scales strActName
    End If
    Read_PTSD_MIL
    If Trim(clsPTSD_MIL.Notes) <> vbNullString Then
        strActName = "PTSD_MIL"
        Populate_Scales strActName
    End If
    Read_PTSD_CIV
    If Trim(clsPTSD_CIV.Notes) <> vbNullString Then
        strActName = "PTSD_CIV"
        Populate_Scales strActName
    End If
    Read_YMRS
    If Trim(clsYMRS.Notes) <> vbNullString Then
        strActName = "YMRS"
        Populate_Scales strActName
    End If
    Read_YBOCS
    If Trim(clsYBOCS.Notes) <> vbNullString Then
        strActName = "YBOCS"
        Populate_Scales strActName
    End If
    Read_MDQ
    If Trim(clsMDQ.Notes) <> vbNullString Then
        strActName = "MDQ"
        Populate_Scales strActName
    End If
    Read_Suicide
    If Trim(clsSuicide.Notes) <> vbNullString Then
        strActName = "SUICIDE"
        Populate_Scales strActName
    End If
    If clsPatient.Age <> vbNullString Then
        If Val(clsPatient.Age) <= 17 Then
            clsGridFormat.FormName = "CHILD ADHD"
            Read_Child_ADHD
        Else
            clsGridFormat.FormName = "ADULT ADHD"
            Read_Adult_ADHD
        End If
    End If
    If clsPatient.Age <> vbNullString Then
        If Val(clsPatient.Age) <= 17 Then
            Get_AdultDev piPatientID, clsEncounter.StartDate
            If Trim(udtAdultDevelop.General) <> vbNullString Or _
                Trim(udtAdultDevelop.ChildHood) <> vbNullString Or _
                Trim(udtAdultDevelop.Education) <> vbNullString Or _
                Trim(udtAdultDevelop.Sexual) <> vbNullString Or _
                Trim(udtAdultDevelop.Occupation) <> vbNullString Or _
                Trim(udtAdultDevelop.Father) <> vbNullString Or _
                Trim(udtAdultDevelop.Financial) <> vbNullString Or _
                Trim(udtAdultDevelop.Mother) <> vbNullString Or _
                Trim(udtAdultDevelop.Siblings) <> vbNullString Then
                    Format_AdultDevelopment
            End If
        Else
            Get_ChildDev piPatientID, clsEncounter.StartDate
            If Trim(udtChildDevelop.Pregnancy) <> vbNullString Or _
                Trim(udtChildDevelop.Activity) <> vbNullString Or _
                Trim(udtChildDevelop.Activity_Level) <> vbNullString Or _
                Trim(udtChildDevelop.Birth) <> vbNullString Or _
                Trim(udtChildDevelop.Develop) <> vbNullString Or _
                Trim(udtChildDevelop.Hist) <> vbNullString Or _
                Trim(udtChildDevelop.Education) <> vbNullString Or _
                Trim(udtChildDevelop.Auditory) <> vbNullString Or _
                Trim(udtChildDevelop.Feeding) <> vbNullString Or _
                Trim(udtChildDevelop.Movement) <> vbNullString Or _
                Trim(udtChildDevelop.Organize) <> vbNullString Or _
                Trim(udtChildDevelop.Sleeping) <> vbNullString Or _
                Trim(udtChildDevelop.Taste) <> vbNullString Or _
                Trim(udtChildDevelop.Touch) <> vbNullString Or _
                Trim(udtChildDevelop.Visual) <> vbNullString Or _
                Trim(udtChildDevelop.Emotional) <> vbNullString Then
                    Format_AdultDevelopment
            End If
        End If
    End If
    strData = vbNullString
    strData = Trim(clsADHD.Inattention) & vbNewLine & Trim(clsADHD.HyperActivity) & vbNewLine & Trim(clsADHD.Impulse) & vbNewLine & Trim(clsADHD.DSM)
    If Trim(clsADHD.Inattention) = vbNullString And Trim(clsADHD.DSM) = vbNullString And Trim(clsADHD.HyperActivity) = vbNullString Then strData = Replace(strData, vbNewLine, "")
    strData = Trim(strData)
    If Trim(strData) <> vbNullString Then
        strActName = "ADHD"
        Populate_Scales strActName
    End If
    strData = vbNullString
    strData = Get_ClinicalNotes("FN_PsyMse", "AIMS", "cctSummary", 1, piEncounterID)
    If Trim(strData) <> vbNullString Then
        strActName = "AIMS"
        Populate_Scales strActName
    End If
    Screen.MousePointer = vbDefault
    Exit Sub
Error_Read_Scales:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strActName, "Read_Scales", Me.Name
    Exit Sub
    Resume Next
End Sub
Private Function ReadDataGrid()
