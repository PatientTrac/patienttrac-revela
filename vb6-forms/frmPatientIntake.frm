Dim Fld As ADODB.Field
Dim strSQL As String
Dim lngPrimKey As Long
Dim strDate As String
Dim strEnctr As String
Dim lngDateDiff As Long
Dim Idx As Integer
Dim Arr
Dim strZip As String
Dim piPatientID As Long

    On Error GoTo Error_Read_Employer
    Screen.MousePointer = vbHourglass
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
    Else
        strDate = Format(Now, "mm/dd/yyyy")
    End If
    If cnEmploy.State = adStateClosed Then cnEmploy.open psConnect(0)
    strSQL = "Get_Patient_Employer_PTID " & piPatientID
    Set rsEmploy = cnEmploy.Execute(strSQL)
    With rsEmploy
        Do Until .EOF
            If (!INSERT_DATE) <> vbNullString Then strEnctr = Format((!INSERT_DATE), "mm/dd/yyyy")
            lngDateDiff = DateDiff("d", strDate, strEnctr)
            If lngDateDiff <= 0 Then
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "EMPLOYER_NAME"
                                    clsEmply.Name = Trim(Fld.Value)
                                Case "POSITION"
                                    clsEmply.Position = Trim(Fld.Value)
                                Case "ADDRESS1"
                                     clsEmply.Address = Trim(Fld.Value)
                                Case "ADDRESS2"
                                    clsEmply.Address2 = Trim(Fld.Value)
                                Case "CITY"
                                    clsEmply.City = Trim(Fld.Value)
                                Case "STATE"
                                    clsEmply.State = Trim(Fld.Value)
                                Case "ZIPCODE"
                                    clsEmply.Zip = Trim(Fld.Value)
                                Case "ZIP_EXT"
                                    clsEmply.Zip_Ext = Trim(Fld.Value)
                                Case "AREA_CODE"
                                    clsEmply.AreaCode = Trim(Fld.Value)
                                Case "PHONE_1"
                                    clsEmply.Phone1 = Trim(Fld.Value)
                                Case "PHONE_2"
                                    clsEmply.Phone2 = Trim(Fld.Value)
                                Case "PHONE_EXT"
                                    clsEmply.PhoneExt = Trim(Fld.Value)
                                Case "EMPLOYER_CONTACT"
                                    clsEmply.Contact = Trim(Fld.Value)
                                Case "CONTACT_TITLE"
                                    clsEmply.Title = Trim(Fld.Value)
                            End Select
                        End If
                    End If
                Next
            End If
            Exit Do
            .MoveNext
        Loop
    End With
    If cnEmploy.State = adStateOpen Then
        cnEmploy.Close
        Set cnEmploy = Nothing
        Set rsEmploy = Nothing
        Set Flds = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Employer:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_Employer", App.EXEName & "." & TypeName(Me)
    Exit Function
    Resume
End Function

