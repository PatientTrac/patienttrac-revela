Private Function Recalculate_MMSE()
Dim lngRow As Long
Dim lngData As Long
Dim strTag As String
Dim lngCol As Long
Dim Arr


    On Error Resume Next
    
    With grdReport
        Clear_MMSE_Score
        mbooLoad = True
        .sheet = 2
        .ActiveSheet = 2
        For lngRow = 1 To .MaxRows
            .Col = 1
            .Row = lngRow
            If .CellTag <> vbNullString Then
                strTag = Replace(.CellTag, "-", "")
                strTag = IsProperCase(strTag)
                strTag = Trim(strTag)
                lngData = 0
                Select Case Trim(IsProperCase(strTag))
                    Case "Time"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Time = clsMMSE_Score.Time + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Time > -1 Then
                            Arr = Split(Get_CellTag_Row("TIME_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(5/" & clsMMSE_Score.Time & ")", "TypeHAlignleft", "TIME_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Time
                    Case "Place"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Place = clsMMSE_Score.Place + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Place > -1 Then
                            Arr = Split(Get_CellTag_Row("PLACE_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(5/" & clsMMSE_Score.Place & ")", "TypeHAlignleft", "PLACE_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Place
                    Case "Immediate Recall", "Immediate_recall", "Immediate_Recall"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Immediate_Recall = clsMMSE_Score.Immediate_Recall + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Immediate_Recall > -1 Then
                            Arr = Split(Get_CellTag_Row("IMMEDIATE_RECALL_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(3/" & clsMMSE_Score.Immediate_Recall & ")", "TypeHAlignleft", "IMMEDIATE_RECALL_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Immediate_Recall
                    Case "Delayed Recall", "Delayed_recall", "Delayed_Recall"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Delayed_Recall = clsMMSE_Score.Delayed_Recall + Val(.Text)
                             End If
                        Next lngCol
                        If clsMMSE_Score.Immediate_Recall > -1 Then
                            Arr = Split(Get_CellTag_Row("DELAYED_RECALL_SCORE"), "|")
                            If UBound(Arr) > 0 Then
                                lngData = Val(Arr(1))
                            End If
                            If lngData > 0 Then
                                Format_CellTypeEdit grdReport, lngData, 2, "1", "(3/" & clsMMSE_Score.Delayed_Recall & ")", "TypeHAlignleft", "DELAYED_RECALL_SCORE", True
                            End If
                        End If
                        clsMMSE_Score.Total_MMSE = clsMMSE_Score.Total_MMSE + clsMMSE_Score.Delayed_Recall
                    Case "Calculation", "Serial 7 Calculation"
                        For lngCol = 1 To .MaxCols
                            .Col = lngCol
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                clsMMSE_Score.Serial_7 = clsMMSE_Score.Serial_7 + Val(.Text)
                             End If
                        Next lngCol
