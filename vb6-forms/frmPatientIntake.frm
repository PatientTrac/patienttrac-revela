Private Function Split_Row()
Dim Arr
Dim Idx As Long
Dim lngHist As Long
Dim lngRowHeight As Long
Dim lngPrintRow As Long
Dim lngRow As Long
Dim booPrint As Boolean
Dim lngCol As Long
Dim lngSplit As Long
Dim strFirData As String
Dim strSecData As String
Dim lngPageCnt As Long
Dim varCellValue
Dim lngPrint As Long
Dim CellNote As String

    On Error GoTo ERROR_Split_Row
    Screen.MousePointer = vbHourglass
    lngPageCnt = grdReport.PrintPageCount
    With grdReport
        .PrintType = PrintTypeAll
        .PrintColHeaders = False
        .PrintScalingMethod = PrintScalingMethodSmartPrint
        .PrintRowHeaders = False
        .PrintMarginLeft = 650
        .PrintMarginRight = 700
        .PrintMarginBottom = 900
        .PrintMarginTop = 900
        .PrintUseDataMax = True
        .PrintBorder = False
        .PrintColor = True
        .PrintOrientation = PrintOrientationPortrait
        .PrintShadows = False
        .PrintSmartPrint = True
        For lngPrint = 1 To .MaxRows
            lngPrintRow = .PrintNextPageBreakRow
            lngRow = lngPrintRow
            If lngPrintRow > 0 Then
                lngHist = lngRow
                With grdReport
                    .Col = 2
                    .Row = lngHist
                    lngRowHeight = .RowHeight(lngHist)
                    If lngRowHeight > 100 Then
                        .GetText 2, lngHist, varCellValue
                        .Text = Trim(varCellValue)
                        CellNote = .MaxTextCellHeight
                        If .RowHeight(lngHist) < CellNote Then
                          .RowHeight(lngHist) = CellNote + 15
                        ElseIf .RowHeight(lngHist) > CellNote + 10 Then
                            .RowHeight(lngHist) = CellNote + 15
                        End If
                    End If
                End With
                .Col = 2
                .Row = lngRow
                If .CellTag <> vbNullString Then
                    clsGridFormat.CellTag = .CellTag
                End If
                If lngRow > 0 Then
                    If lngRowHeight > 25 Then
                        grdReport.Col = 2
                        grdReport.Row = lngRow
                        clsGridFormat.CellTag = grdReport.CellTag
                       grdReport.GetText 2, lngRow, varCellValue
                       clsGridFormat.Text = varCellValue
                       If Not TextFound("*", clsGridFormat.Text, Len("*"), True) Then
                            Arr = Split(clsGridFormat.Text, vbNewLine)
                            If UBound(Arr) > 0 Then
                                 For Idx = LBound(Arr) To UBound(Arr)
                                     If Idx = 0 Then
                                         grdReport.RowHeight(lngRow) = 15
                                         clsGridFormat.Text = Arr(Idx)
                                         If grdReport.CellTag = "HPI" Then
                                            Format_CellTypeSplit grdReport, lngRow, 2, "maxcols", clsGridFormat.Text, "TypeHAlignLeft", clsGridFormat.CellTag
                                        Else
                                            Format_CellTypeEdit grdReport, lngRow, 2, "maxcols", clsGridFormat.Text, "TypeHAlignLeft", clsGridFormat.CellTag
                                        End If
                                     Else
                                         clsGridFormat.Text = Arr(Idx)
                                         If Trim(clsGridFormat.Text) <> vbNullString Then
                                             lngRow = lngRow + 1
                                             grdReport.MaxRows = grdReport.MaxRows + 1
                                             grdReport.InsertRows lngRow, 1
                                             If grdReport.CellTag = "HPI" Then
                                                Format_CellTypeSplit grdReport, lngRow, 2, "maxcols", clsGridFormat.Text, "TypeHAlignLeft", clsGridFormat.CellTag
                                            Else
                                                Format_CellTypeEdit grdReport, lngRow, 2, "maxcols", clsGridFormat.Text, "TypeHAlignLeft", clsGridFormat.CellTag
                                            End If
                                         End If
                                     End If
                                 Next Idx
                             End If
                        End If
                    End If
                End If
            End If
        Next lngPrint
    End With
    Screen.MousePointer = vbDefault
    Exit Function
ERROR_Split_Row:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Split_Row", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Terms_Grid(vstrSubDomain As String, Optional vstrExistData As String, Optional vstrType As String)
Dim strSQL As String
Dim rsTerms As New ADODB.Recordset
Dim cnTerms As New ADODB.Connection
Dim lngRow As Long
Dim strName As String
Dim cnStaff As New ADODB.Connection
Dim rsStaff As New ADODB.Recordset
Dim strStaff As String
Dim Arr
Dim Idx As Integer
Dim strData As String
Dim lngWidth As Long
Dim lngHeight As Long
Dim varCellValue
Dim lngx As Long
Dim lngY As Long
    
    On Error GoTo Error_Terms_Grid
    Format_GridTerms "TERMS"
    If vstrSubDomain <> "Load_Staff" Then
        mstrGridTerms = vstrSubDomain
        If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
        mstrList = vbNullString
        If vstrType = vbNullString Then
            strSQL = "Get_Attr_Valid_Value_SubDom_Sequence '" & vstrSubDomain & "'"
        Else
            strSQL = "Get_Attr_Valid_Value_SubDom_Alphabetic '" & vstrSubDomain & "'"
        End If
        Set rsTerms = cnTerms.Execute(strSQL)
        Do Until rsTerms.EOF
            With grdTerms
                .ColWidth(1) = 14
                lngRow = lngRow + 1
                .MaxRows = lngRow
                If rsTerms.Fields("ATTRBTE_VALID_VALUE") <> vbNullString Then
                    Format_CellTypeEdit grdTerms, lngRow, 1, "1", rsTerms.Fields("ATTRBTE_VALID_VALUE"), "TypeHAlignCenter"
                    .SetCellBorder 1, lngRow, 1, lngRow, CellBorderIndexOutline, &H800000, CellBorderStyleSolid
                End If
            End With
            rsTerms.MoveNext
        Loop
        If cnTerms.State = adStateOpen Then
            cnTerms.Close
            Set rsTerms = Nothing
            Set cnTerms = Nothing
        End If
        Screen.MousePointer = vbDefault
    Else
        If cnStaff.State = adStateClosed Then cnStaff.open psConnect(0)
        strSQL = "Load_Active_Providers"
        Set rsStaff = cnStaff.Execute(strSQL)
            Do Until rsStaff.EOF
                If rsStaff.Fields("FIRST_NAME") <> vbNullString Then strName = rsStaff.Fields("FIRST_NAME")
                If rsStaff.Fields("MIDDLE_NAME") <> vbNullString Then strName = Trim(strName) & " " & rsStaff.Fields("MIDDLE_NAME")
                If rsStaff.Fields("LAST_NAME") <> vbNullString Then strName = Trim(strName) & " " & rsStaff.Fields("LAST_NAME")
                If rsStaff.Fields("SUFFIX") <> vbNullString Then strName = Trim(strName) & ", " & rsStaff.Fields("SUFFIX")
                If rsStaff.Fields("TITLE") <> vbNullString Then strName = Trim(strName) & ", " & rsStaff.Fields("TITLE")
                If Trim(strName) <> vbNullString Then
                    With grdTerms
                        .ColWidth(1) = 14
                        lngRow = lngRow + 1
                        .MaxRows = lngRow
                        If rsStaff.Fields("PROVIDER_ID") > 0 Then grdTerms.SetRowItemData (lngRow), rsStaff.Fields("PROVIDER_ID")
                        Format_CellTypeEdit grdTerms, lngRow, 1, "1", Trim(strName), "TypeHAlignCenter"
                        grdTerms.SetCellBorder 1, lngRow, 1, lngRow, CellBorderIndexOutline, &H800000, CellBorderStyleSolid
                    End With
                End If
                rsStaff.MoveNext
            Loop
            If cnStaff.State = adStateOpen Then
                cnStaff.Close
                Set cnStaff = Nothing
                Set rsStaff = Nothing
            End If
    End If
    With grdTerms
        For lngRow = 1 To .MaxRows
            .GetText 1, lngRow, varCellValue
            Arr = Split(Trim(varCellValue), vbNewLine)
            If UBound(Arr) > 0 Then
                For Idx = LBound(Arr) To UBound(Arr)
                    If Trim(Arr(Idx)) <> vbNullString Then
                        strData = Trim(Arr(Idx))
                        If TextFound(strData, Trim(varCellValue), Len(strData), True) Then
                            .Col = 1
                            .Row = lngRow
                            .BackColor = &HFFC0FF
                        End If
                    End If
                Next Idx
            End If
        
        Next lngRow
    End With
