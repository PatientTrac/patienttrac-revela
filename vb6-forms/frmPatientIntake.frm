    Resume Next
End Sub
Private Function Read_Nurse_Referral_Grid()
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim lngGridPrim As Long
Dim strDate As String
Dim strTag As String
Dim strText As String
Dim varCellValue
Dim strCheck As String

    On Error GoTo Error_Read_Nurse_Referral_Grid
    Screen.MousePointer = vbHourglass
    grdReport.sheet = clsGridFormat.SheetNumber
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "SELECT * FROM INPATIENT_NOTES WHERE PATIENT_ID =  " & piPatientID & " AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND NOTE_TYPE like 'REFERRAL%' ORDER BY NOTE_TYPE "
    Set rsWrite = cnWrite.Execute(strSQL)
    With rsWrite
       Do Until .EOF
            strText = vbNullString
            strTag = vbNullString
            strCheck = vbNullString
            If Not IsNull((!NOTES_DESC)) Then
                strText = Trim((!NOTES_DESC))
            End If
            If Not IsNull((!Note_Type)) Then
                strTag = Trim((!Note_Type))
            End If
            .MoveNext
            strText = Replace(strText, "''", "'")
            Arr = Split(strText, "|")
            If UBound(Arr) > 0 Then
                strCheck = Arr(0)
                strText = Arr(1)
            End If
            If strCheck <> vbNullString Then
                Arr = Split(Get_CellTag_Row(strTag), "|")
                If UBound(Arr) > 0 Then
                    lngRow = Arr(1)
                End If
                If lngRow > 0 Then
                    grdReport.Col = 2
                    grdReport.Row = lngRow
                    If grdReport.CellType = CellTypeCheckBox Then
                        If grdReport.TypeCheckText = IsProperCase(Trim(strCheck)) Then
                            grdReport.Text = "1"
                            Format_CellTypeEdit grdReport, lngRow, 4, "maxcols", Trim(strText), "TypeHAlignLeft", strTag
                        End If
                    End If
                End If
            End If
        Loop
    End With
    
    Arr = Split(Get_CellTag_Row("REFERRAL_OTHER"), "|")
    If UBound(Arr) > 0 Then
        lngRow = Arr(1)
    End If
    If lngRow > 0 Then
        With grdReport
            .GetText 4, lngRow, varCellValue
            If Trim(varCellValue) = vbNullString Then
                 .BlockMode = True
                    .Col = 4
                    .Col2 = 4
                    .Row = lngRow
                    .Row2 = lngRow
                    .BackColor = grdYellow
                .BlockMode = False
            Else
                .BlockMode = True
                    .Col = 4
                    .Col2 = 4
                    .Row = lngRow
                    .Row2 = lngRow
                    .BackColor = grdYellow
                .BlockMode = False
            End If
        End With
    End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Nurse_Referral_Grid:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, mstrRowData, "Read_Nurse_Referral_Grid", Me.Name
    Exit Function
    Resume Next
End Function
