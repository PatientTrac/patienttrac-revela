    ElseIf vstrOCX = "CURRENT OTC MEDICATION" Then
        strOCX = "FN_PP_PS"
        strCtl = "AddMed"
        strType = "PROFILER"
    ElseIf vstrOCX = "CURRENT MEDICATIONS" Then
        strOCX = "PT_Medications"
        strCtl = "Prescription"
        strType = "PROFILER"
    ElseIf vstrOCX = "CURRENT RX MEDICATIONS" Then
         strOCX = "PT_Medications"
         strCtl = "Prescription"
        strType = "PATIENT"
    ElseIf vstrOCX = "MEDICATION ORDERS" Then
         strOCX = "PT_Medications"
         strCtl = "Prescription"
         strType = "PATIENT"
    ElseIf vstrOCX = "FERTILITY" Then
         strOCX = "FN_ObGyn"
         strCtl = "Infertility"
         strType = "PATIENT"
    ElseIf vstrOCX = "CURRENT MEDICATIONS" Then
         strOCX = "PT_Medications"
         strCtl = "Prescription"
         strType = "PROFILER"
    ElseIf vstrOCX = "MENSTRUAL DISORDER" Then
         strOCX = "FN_ObGyn"
         strCtl = "MensDisorder"
         strType = "PATIENT"
    ElseIf vstrOCX = "PAIN" Then
         strOCX = "FN_ObGyn"
         strCtl = "Pain"
         strType = "PATIENT"
    ElseIf vstrOCX = "INFECTION" Then
         strOCX = "FN_ObGyn"
         strCtl = "INFECTION"
         strType = "PATIENT"
    ElseIf vstrOCX = "BLEEDING" Then
         strOCX = "FN_ObGyn": strCtl = "BLEEDING"
         strType = "PATIENT"
    ElseIf vstrOCX = "FAMILY MEDICAL" Then
         strOCX = "FN_PP_PastMedHist"
         strCtl = "FamilyMedical"
         strType = "PROFILER"
    End If
    intActX_ID = Get_ComponentID(strOCX, strCtl)
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    If PsUserID = vbNullString Then Get_PsUserID (psConnect(0))
    strClinDesc = strOCX & "." & strCtl
