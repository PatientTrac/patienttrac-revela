            If UBound(Arr) > 0 Then
                For Idx = LBound(Arr) To UBound(Arr)
                    clsGridFormat.Text = vbNullString
                    If Idx = 0 Then
                        clsGridFormat.Text = Arr(0)
                        Format_CellTypeSplit grdReport, lngRow, 1, "1", "CLINICAL OPIATE WITHDRAWL SCALE", "TypeHAlignLeft", "SUBOXONE"
                        Format_CellTypeSplit grdReport, lngRow, 2, "maxcols", Trim(clsGridFormat.Text), "TypeHAlignLeft", "SUBOXONE"
                    Else
                        clsGridFormat.Text = Arr(Idx)
                        If Trim(clsGridFormat.Text) <> vbNullString Then
                            lngRow = lngRow + 1
                            grdReport.InsertRows lngRow, 1
                            grdReport.MaxRows = grdReport.MaxRows + 1
'                            mReportDataRow = mReportDataRow + 1
                            Format_CellTypeSplit grdReport, lngRow, 2, "maxcols", Trim(clsGridFormat.Text), "TypeHAlignLeft", "SUBOXONE"
                        End If
                    End If
                Next Idx
            Else
                Format_CellTypeEdit grdReport, lngRow, 2, "maxcols", Trim(clsSuboxone.Suboxone_Notes), "TypeHAlignLeft", "SUBOXONE", "TypeHAlignLeft", "CURRENT HISTORY"
            End If
    End If
    .Redraw = False
    End With
    Screen.MousePointer = vbDefault
    Exit Function
Error_Format_Suboxone:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Format_Suboxone", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Get_Add_Notes()
Dim lngRow As Long
Dim varCellValue
Dim strSQL As String
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim cnRead As New ADODB.Connection
Dim rsRead As New ADODB.Recordset
Dim Arr
Dim Idx As Integer

    On Error GoTo Error_Get_Add_Notes
    Screen.MousePointer = vbHourglass
    mbooByPass = True
    mbooHasChanged = True
    If cnRead.State = adStateClosed Then cnRead.open psConnect(0)
    strSQL = "Get_InPatient_Notes_PT_ID_ENCTR_ID_NOTE_TYPE 'ADDITIONAL NOTE%'," _
        & piPatientID & "," & piEncounterID
    Set rsRead = cnRead.Execute(strSQL)
    With rsRead
        If Not rsRead.EOF Then
            If Trim(!NOTES_DESC) <> vbNullString Then
                clsReport.AddNote = (!NOTES_DESC)
            End If
            grdReport.Redraw = False
        End If
    End With
    Screen.MousePointer = vbDefault
    If cnRead.State = adStateOpen Then
        cnRead.Close
        Set cnRead = Nothing
        Set Flds = Nothing
        Set rsRead = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Add_Notes:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Get_Add_Notes", Me.Name
    Exit Function
    Resume Next
End Function
