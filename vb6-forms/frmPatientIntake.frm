Private Function Add_Patient_Photo(vlngStart As Long, vObjGrid As Object)
Dim fso As New FileSystemObject
Dim lngStart As Long

    lngStart = vlngStart
    psImageFilePath = QueryValue(HKEY_LOCAL_MACHINE, psRegGeneral, "ImagePath")
    If psImageFilePath = vbNullString Then
       psImageFilePath = "C:\"
    End If
    If fso.FileExists(psImageFilePath & piPatientID & "\Photo.jpg") Then
        psPhoto = psImageFilePath & piPatientID & "\Photo.jpg"
        Add_Patient_Photo_Grid vObjGrid, lngStart, 6, psPhoto, vObjGrid.MaxRows, "PATIENT_PHOTO"
    End If
    Exit Function
End Function

Private Function Add_Patient_Photo_Grid(vGrid As Object, vlngRow As Long, vlngCol As Long, vstrPhotoPath As String, vlngSpan As Long, Optional vstrCellTag As String)
Dim CellNote As Long
Dim lngSpan As Long

    lngSpan = vlngSpan
    With vGrid
        .sheet = clsGridFormat.SheetNumber
        .ActiveSheet = .sheet
        .BlockMode = True
            .Col = vlngCol
            .Col2 = vlngCol
            .Row = vlngRow
            .Row2 = vlngRow
            .RowHeight(vlngRow) = 25
            .RowHeight(vlngRow + 1) = 25
            .CellType = CellTypePicture
            .TypePictCenter = True
            lngSpan = lngSpan - vlngRow
            .AddCellSpan vlngCol, vlngRow, 2, lngSpan
            If FileExists(vstrPhotoPath) Then
                .TypePictPicture = LoadPicture(vstrPhotoPath)
            End If
            If vstrCellTag <> vbNullString Then .CellTag = vstrCellTag
          .BlockMode = False
    End With
End Function





