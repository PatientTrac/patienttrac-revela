Private Function Fix_RowHeight()
Dim lngRow As Long
Dim lngCol As Long
Dim strTag As String
Dim strNote As String
Dim varCellValue
Dim Arr
Dim booSkip As Boolean

    If mbooByPass Then Exit Function
    If mstrPractice = "Plastic Surgery" Then Exit Function
    Screen.MousePointer = vbHourglass
    With grdReport
        For lngRow = 6 To .MaxRows
            booSkip = False
            .Col = 2
            .Row = lngRow
            .GetText 2, lngRow, varCellValue
            If .CellTag <> vbNullString Then strTag = Trim(.CellTag)
            If .CellNote <> vbNullString Then strNote = Trim(.CellNote)
            If Trim(varCellValue) <> vbNullString Then
                Select Case UCase(Trim(strTag))
                    Case "PEDIATRIC_ROW", "PEDIATRIC_GROWTH"
                        booSkip = True
                    Case "VITALS", "VITAL SIGNS", "VITAL", "MENTAL STATUS"
                        booSkip = True
                    Case "ADDITIONAL NOTES", "ADDITIONAL DATA", "ADDITIONAL NOTES/DATA"
                        booSkip = True
                End Select
                Select Case UCase(Trim(strNote))
                    Case "PEDIATRIC_ROW", "PEDIATRIC_GROWTH"
                        booSkip = True
                    Case "VITALS", "VITAL SIGNS", "VITAL"
                        booSkip = True
                End Select
                If Not booSkip Then
                    Format_CellTypeEdit grdReport, lngRow, 2, .MaxCols, CStr(Trim(varCellValue)), "TypeHAlignLeft", strTag, False, 0, strNote
                End If
            End If
        Next lngRow
        Arr = Split(LookUpRow("PLAN AND RECOMMENDATIONS"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
            .Col = 1
            .Row = lngRow
            If .CellTag <> vbNullString Then strTag = Trim(.CellTag)
            Format_CellTypeEdit grdReport, lngRow, 1, "maxcols", "PLAN AND RECOMMENDATIONS", "TypeHAlignCenter", strTag, True
        End If
    End With
    Screen.MousePointer = vbDefault
    Exit Function
End Function

