Private Function Calc_Prev_MSE_VALUE()
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngEnctr As Long
Dim strDate As String

    
    On Error GoTo Error_Calc_Prev_MSE_VALUE
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    If clsEncounter.StartDate = vbNullString Then
        Get_Encounter piEncounterID
        If clsEncounter.StartDate = vbNullString Then
            strDate = Format(Now, "mm/dd/yyyy")
        Else
            strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
        End If
    Else
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
    End If
    strSQL = "SELECT DISTINCT ENCOUNTER.ENCNTR_START_DATE, ENCOUNTER.ENCOUNTER_ID " _
        & "FROM  PATIENT_ADHD_SCALE " _
        & "INNER JOIN ENCOUNTER ON ENCOUNTER.ENCOUNTER_ID = PATIENT_ADHD_SCALE.ENCOUNTER_ID " _
        & "WHERE PATIENT_ADHD_SCALE.FORM_NAME = 'MMSE' AND " _
        & "PATIENT_ADHD_SCALE.PATIENT_ID = " & piPatientID & "  AND " _
        & "PATIENT_ADHD_SCALE.CLINICAL_VALUE <> '' AND " _
        & "CONVERT(DATETIME, ENCOUNTER.ENCNTR_START_DATE, 101)  < '" & Format(strDate, "mm/dd/yyyy") & "' AND FORM_NAME = 'MMSE' " _
        & "ORDER BY " _
        & "ENCOUNTER.ENCNTR_START_DATE DESC"
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            If Not .EOF Then
                strDate = vbNullString
                lngEnctr = (!Encounter_ID)
                strDate = Format((!ENCNTR_START_DATE), "mm/dd/yyyy")
            End If
        End With
    If lngEnctr > 0 Then
        strSQL = "SELECT SUM(CONVERT(DECIMAL(12,0), PATIENT_ADHD_SCALE.CLINICAL_VALUE, 0)) AS CALC " _
            & "FROM  PATIENT_ADHD_SCALE WHERE ENCOUNTER_ID = " & lngEnctr & "  AND PATIENT_ADHD_SCALE.CLINICAL_VALUE <> '' AND FORM_NAME = 'MMSE'"
            Set rsWrite = cnWrite.Execute(strSQL)
            With rsWrite
                If Not .EOF Then
                    Calc_Prev_MSE_VALUE = (!CALC) & "|" & strDate
                End If
            End With
    Else
        Calc_Prev_MSE_VALUE = vbNullString
    End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_Prev_MSE_VALUE:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Calc_Prev_MSE_VALUE", Me.Name
    Exit Function
    Resume Next
End Function

Private Function Read_Nursing_Medical()
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim lngGridPrim As Long
Dim strDate As String
Dim strTag As String
Dim strText As String
Dim varCellValue
Dim strCheck As String

    On Error GoTo Error_Read_Nursing_Medical
    Screen.MousePointer = vbHourglass
    mstrRowData = vbNullString
    grdReport.sheet = clsGridFormat.SheetNumber
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "SELECT * FROM INPATIENT_NOTES WHERE PATIENT_ID =  " & piPatientID & " AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND NOTE_TYPE like 'PRIOR%' ORDER BY NOTE_TYPE "
    Set rsWrite = cnWrite.Execute(strSQL)
    With rsWrite
       Do Until .EOF
            strText = vbNullString
            strTag = vbNullString
            strCheck = vbNullString
            If Not IsNull((!NOTES_DESC)) Then
                strText = Trim((!NOTES_DESC))
            End If
            If Not IsNull((!Note_Type)) Then
                strTag = Trim((!Note_Type))
            End If
            .MoveNext
            If strCheck <> vbNullString Then
                Arr = Split(Get_CellTag_Row(strTag), "|")
                If UBound(Arr) > 0 Then
                    lngRow = Arr(1)
                End If
                grdReport.sheet = clsGridFormat.SheetNumber
                If lngRow > 0 Then
                    grdReport.GetText 2, lngRow, varCellValue
                    If IsProperCase(Trim(varCellValue)) = IsProperCase(Trim(strCheck)) Then
                        grdReport.Col = 2
                        grdReport.Row = lngRow
                        Format_CellTypeEdit grdReport, lngRow, 3, "maxcols", Trim(strText), "TypeHAlignLeft", strTag
                    End If
                End If
            End If
        Loop
    End With
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_Nursing_Medical:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, mstrRowData, "Read_Nursing_Medical", Me.Name
    Exit Function
    Resume Next
End Function

