                                            If grdReport.CellType = CellTypeCheckBox Then
                                                If Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                                    grdReport.Text = "1"
                                                    bData = True
                                                    Exit For
                                                End If
                                            End If
                                        Next lngCol
                                    End If
                                Next Idx
                            Else
                                For lngCol = 2 To grdReport.MaxCols
                                    grdReport.Col = lngCol
                                    grdReport.Row = lngRow
                                    If grdReport.CellType = CellTypeCheckBox Then
                                        If Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                            grdReport.Text = "1"
                                            bData = True
                                            Exit For
                                        End If
                                    End If
                                Next lngCol
                            End If
                        End If
                    End If
                Else
                    If TextFound("RECEPTIVE LANGUAGE", udtNew_MSE.MSE_Data, Len("RECEPTIVE LANGUAGE"), True) Then
                        udtNew_MSE.MSE_Item = "Receptive Language"
                        udtNew_MSE.MSE_Data = Replace(udtNew_MSE.MSE_Data, "RECEPTIVE LANGUAGE is ", "")
                        udtNew_MSE.MSE_Data = Trim(udtNew_MSE.MSE_Data)
                    ElseIf TextFound("EXPRESSIVE LANGUAGE", udtNew_MSE.MSE_Data, Len("EXPRESSIVE LANGUAGE"), True) Then
                        udtNew_MSE.MSE_Item = "Expressive Language"
                        udtNew_MSE.MSE_Data = Replace(udtNew_MSE.MSE_Data, "EXPRESSIVE LANGUAGE is ", "")
                        udtNew_MSE.MSE_Data = Trim(udtNew_MSE.MSE_Data)
                    End If
                    Arr = Split(LookUpCellTag(udtNew_MSE.MSE_Item), "|")
                    If UBound(Arr) > 0 Then lngRow = Arr(1)
                    If lngRow > 0 Then
                        ArrTerms = Split(udtNew_MSE.MSE_Data, ",")
                        If UBound(ArrTerms) > 0 Then
                            For Idx = LBound(ArrTerms) To UBound(ArrTerms)
                                udtNew_MSE.MSE_Data = vbNullString
                                If Trim(ArrTerms(Idx)) <> vbNullString Then
                                    udtNew_MSE.MSE_Data = Trim(ArrTerms(Idx))
                                    For lngCol = 2 To grdReport.MaxCols
                                        grdReport.Col = lngCol
                                        grdReport.Row = lngRow
                                        If grdReport.CellType = CellTypeCheckBox Then
                                            If Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                                grdReport.Text = "1"
                                                bData = True
                                                Exit For
                                            End If
                                        End If
                                    Next lngCol
                                End If
                            Next Idx
                        Else
                            For lngCol = 2 To grdReport.MaxCols
                                grdReport.Col = lngCol
                                grdReport.Row = lngRow
                                If grdReport.CellType = CellTypeCheckBox Then
                                    If Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                        grdReport.Text = "1"
                                        bData = True
                                        Exit For
                                    End If
                                End If
                            Next lngCol
                        End If
                    End If
                End If
            Case "Appetite Change"
                Arr = Split(LookUpHeaderRow(udtNew_MSE.MSE_Item), "|")
                If UBound(Arr) > 0 Then lngRow = Arr(1)
                If lngRow > 0 Then
                    For lngCol = 2 To grdReport.MaxCols
                        grdReport.Col = lngCol
                        grdReport.Row = lngRow
                        If grdReport.CellType = CellTypeCheckBox Then
                            If Trim(IsProperCase(grdReport.TypeCheckText)) <> Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                grdReport.Text = "0"
                                bData = True
                            ElseIf Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                grdReport.Text = "1"
                                bData = True
                            End If
                        End If
                    Next lngCol
                End If
            'Perceptual Disturbance
            Case "Perceptual Disturbance"
                Arr = Split(LookUpHeaderRow(udtNew_MSE.MSE_Item), "|")
                If UBound(Arr) > 0 Then lngRow = Arr(1)
                If lngRow > 0 Then
                    For lngCol = 2 To grdReport.MaxCols
                        grdReport.Col = lngCol
                        grdReport.Row = lngRow
                        If grdReport.CellType = CellTypeCheckBox Then
                            If Trim(IsProperCase(grdReport.TypeCheckText)) = Trim(IsProperCase(udtNew_MSE.MSE_Data)) Then
                                grdReport.Text = "1"
                                bData = True
                                Exit For
                            End If
                        End If
                    Next lngCol
                End If
            Case "Physical Aids"
                lngCol = 2
                Arr = Split(LookUpHeaderRow(udtNew_MSE.MSE_Item), "|")
                If UBound(Arr) > 0 Then lngRow = Arr(1)
                If lngRow > 0 Then
                    bData = True
                    If Not TextFound(Chr(34), udtNew_MSE.MSE_Data, Len(Chr(34)), True) Then
                        Format_CellTypeEdit grdReport, lngRow, lngCol, "maxcols", Chr(34) & udtNew_MSE.MSE_Data & Chr(34), "TypeHAlignLeft", udtNew_MSE.MSE_Item
                    Else
                        Format_CellTypeEdit grdReport, lngRow, lngCol, "maxcols", udtNew_MSE.MSE_Data, "TypeHAlignLeft", udtNew_MSE.MSE_Item
                    End If
                End If
            Case "Suicidal", "Homicidal"
                If IsProperCase(udtNew_MSE.MSE_Item) = "Suicidal" Then
                    strSuicide = Trim(udtNew_MSE.MSE_Data)
                    If Trim(udtNew_MSE.MSE_Note) <> vbNullString Then strNote = Trim(udtNew_MSE.MSE_Note)
                End If
                If IsProperCase(udtNew_MSE.MSE_Item) = "Homicidal" Then
                    strHomical = Trim(udtNew_MSE.MSE_Data)
                    If Trim(udtNew_MSE.MSE_Note) <> vbNullString Then strNote = Trim(udtNew_MSE.MSE_Note)
                End If
                If strSuicide <> vbNullString Or strHomical <> vbNullString Or strNote <> vbNullString Then
                    lngCol = 2
                    Arr = Split(LookUpHeaderRow("IDEATION"), "|")
                    If UBound(Arr) > 0 Then lngRow = Arr(1)
                    If lngRow > 0 Then
                        bData = False
                        For lngCol = 2 To grdReport.MaxCols
                            grdReport.Col = lngCol
                            grdReport.Row = lngRow
                            If grdReport.CellType = CellTypeCheckBox Then
                                If Trim(IsProperCase(grdReport.TypeCheckText)) = "No" And strSuicide = "No" Then
                                    mbooLoad = True
                                    grdReport.Text = "1"
                                    bData = True
                                ElseIf Trim(IsProperCase(grdReport.TypeCheckText)) = "Suicidal" And strSuicide = "Yes" Then
                                    mbooLoad = True
                                    grdReport.Text = "1"
                                    bData = True
                                End If
                                If Trim(IsProperCase(grdReport.TypeCheckText)) = "No" And strHomical = "No" Then
                                    mbooLoad = True
                                    grdReport.Text = "1"
                                    bData = True
                                ElseIf Trim(IsProperCase(grdReport.TypeCheckText)) = "Homicidal" And strHomical = "Yes" Then
                                    mbooLoad = True
                                    grdReport.Text = "1"
                                    bData = True
                                End If
                            End If
                        Next lngCol
                        If Trim(strNote) <> vbNullString Then
                            mbooLoad = True
                            Format_CellTypeEdit grdReport, lngRow, 6, "maxcols", Chr(34) & strNote & Chr(34), "TypeHAlignLeft", "IDEATION"
                        End If
                    End If
                End If
        End Select
    End With
End Function
Private Function Get_Pentagon()
Dim strSQL As String
Dim cnLab As New ADODB.Connection
Dim rsLab As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim Arr
Dim lngRow As Long
Dim lngCol As Long
Dim strProvider As String
Dim i%
Dim strData As String
Dim lngEnctr As Long
Dim mStream
Dim fso As New FileSystemObject
Dim strInter As String
Dim strDate As String
Dim lngDate As Long
Dim strFile As String
Dim bData As Boolean


    On Error GoTo Error_Get_Pentagon
    Screen.MousePointer = vbHourglass
    
    udtTime.StartDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
    If udtTime.StartDate = vbNullString Then udtTime.StartDate = Format(Now, "mm/dd/yyyy")
    udtTime.EndDate = DateAdd("d", 1, udtTime.StartDate)
    If cnLab.State = adStateClosed Then cnLab.open psConnect(0)
    rsLab.open "Collect_Annotation_Image " & piPatientID & ",'InkPentagon','" & Format(udtTime.StartDate, "mm/dd/yyyy") & "','" & Format(udtTime.EndDate, "mm/dd/yyyy") & "'", cnLab, adOpenKeyset, adLockOptimistic
    With rsLab
        If Not .EOF Then
            bData = True
            Clear_ClockDraw
            strData = vbNullString
            strInter = vbNullString
            lngEnctr = (!Encounter_ID)
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "ANNOTATION"
                                clsClockDraw.Image = Fld.Value
                                Set mStream = New ADODB.Stream
                                mStream.Type = adTypeBinary
                                mStream.open
                                mStream.Write Fld.Value
                                clsClockDraw.Image = "c:\Clock_Test" & "_" & piPatientID & "_" & lngEnctr & ".bmp"
                                mStream.SaveToFile clsClockDraw.Image, adSaveCreateOverWrite
                                Set mStream = Nothing
                            Case "ENCOUNTER_ID"
                                lngEnctr = Fld.Value
                            Case "ENCNTR_START_DATE"
                                strDate = Fld.Value
                            Case "CLINICAL_DESC"
                                clsClockDraw.PhysFinding = Fld.Value
                            Case "ANNOTATION_IMAGE"
                                clsClockDraw.Comments = Fld.Value
                        End Select
                    End If
                End If
            Next
        End If
    End With
    If Not bData Then
        If rsLab.State = adStateOpen Then rsLab.Close
        If cnLab.State = adStateClosed Then cnLab.open psConnect(0)
        strSQL = "SELECT CLINICAL_DESC, ANNOTATION_IMAGE, RECALL_1, RECALL_2, RECALL_3 FROM " _
            & "ANNOTATIONS WHERE PATIENT_ID = " & piPatientID & " AND " _
            & "ENCOUNTER_ID = " & piEncounterID & " AND ANNOTATION_REF = 'InkPentagon'"
        Set rsLab = cnLab.Execute(strSQL)
        With rsLab
            If Not .EOF Then
                bData = True
                Clear_ClockDraw
                strData = vbNullString
                strInter = vbNullString
'                lngEnctr = 0
'                lngEnctr = (!Encounter_ID)
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "CLINICAL_DESC"
                                    clsClockDraw.PhysFinding = Fld.Value
                                Case "ANNOTATION_IMAGE"
                                    clsClockDraw.Comments = Fld.Value
                                Case "RECALL_1"
                                    If clsClockDraw.Recall1 = vbNullString Then clsClockDraw.Recall1 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Apple" & Chr(34)
                                Case "RECALL_2"
                                    If clsClockDraw.Recall2 = vbNullString Then clsClockDraw.Recall2 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Penny" & Chr(34)
                                Case "RECALL_3"
                                    If clsClockDraw.Recall3 = vbNullString Then clsClockDraw.Recall3 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Watch" & Chr(34)
                            End Select
                        End If
                    End If
                Next
            End If
        End With
    End If
    If cnLab.State = adStateOpen Then
        If rsLab.State = adStateOpen Then rsLab.Close
        Set cnLab = Nothing
        Set rsLab = Nothing
        Set Flds = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Pentagon:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, " Get_Pentagon", Me.Name
    Exit Function
End Function
