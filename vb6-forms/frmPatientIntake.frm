Private Function Calc_AIMS() As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngCal As Long

    
    On Error GoTo Error_Calc_AIMS
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "SELECT * FROM  PATIENT_ADHD_SCALE WHERE DEVELOPMENT_GROUP = '" & clsGridFormat.CellTag & "' AND " _
        & "FORM_NAME = 'AIMS' AND PATIENT_ID = " & piPatientID & "  AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND CLINICAL_VALUE <> ''"
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            If Not .EOF Then
                If Not IsNull((!CLINICAL_VALUE)) Then
                    If Trim((!CLINICAL_VALUE)) <> vbNullString Then
                        Select Case IsProperCase((!CLINICAL_VALUE))
                           Case "None"
                                Calc_AIMS = "0"
                            Case "Minimal"
                                 Calc_AIMS = "1"
                            Case "Mild"
                                Calc_AIMS = "2"
                            Case "Moderate"
                                Calc_AIMS = "3"
                            Case "Severe"
                                Calc_AIMS = "4"
                        End Select
                    End If
                End If
            End If
        End With
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    clsAIMS.RatingScore = Val(clsAIMS.RatingScore) + Val(Calc_AIMS)
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_AIMS:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Calc_AIMS", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Calc_Hamilton(vstrTag As String)
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngCal As Long
Dim Arr
Dim varCellValue
Dim lngCnt As Long
Dim lngCol As Long
Dim lngRow As Long
Dim strText As String

    
    On Error GoTo Error_Calc_Hamilton
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    clsGridFormat.CellTag = vstrTag
    strSQL = "SELECT * " _
        & "FROM  PATIENT_ADHD_SCALE WHERE DEVELOPMENT_GROUP = '" & clsGridFormat.CellTag & "' AND " _
        & "FORM_NAME = 'HAMILTON DEPRESSION' AND PATIENT_ID = " & piPatientID & "  AND " _
        & "ENCOUNTER_ID = " & piEncounterID
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            If Not .EOF Then
                If Not IsNull((!CLINICAL_VALUE)) Then
                    If Trim((!CLINICAL_VALUE)) <> vbNullString Then
                            Arr = Split(Get_CellTag_Row(Trim(clsGridFormat.CellTag)), "|")
                            If UBound(Arr) > 0 Then
                                lngRow = Arr(1)
                            End If
                            If lngRow > 0 Then
                                grdReport.sheet = clsGridFormat.SheetNumber
                                For lngRow = lngRow To lngRow + 4
                                    grdReport.Col = 2
                                    grdReport.Row = lngRow
                                    If grdReport.CellType = CellTypeCheckBox Then
                                        If grdReport.Text = "1" Then
                                            strText = grdReport.TypeCheckText
                                        End If
                                        lngCnt = lngCnt + 1
                                    End If
                                    If Trim(IsProperCase(strText)) = Trim(IsProperCase((!CLINICAL_VALUE))) Then
                                        Select Case lngCnt
                                            Case 1
                                                 Calc_Hamilton = "0"
                                             Case 2
                                                  Calc_Hamilton = "1"
                                             Case 3
                                                 Calc_Hamilton = "2"
                                             Case 4
                                                 Calc_Hamilton = "3"
                                             Case 5
                                                 Calc_Hamilton = "4"
                                        End Select
                                        Exit For
                                    End If
                                Next lngRow
                            End If
                        End If
                    End If
                End If
        End With
    clsHamilton.RatingScore = Val(clsHamilton.RatingScore) + Val(Calc_Hamilton)
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_Hamilton:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Calc_Hamilton", Me.Name
    Exit Function
    Resume Next
End Function


