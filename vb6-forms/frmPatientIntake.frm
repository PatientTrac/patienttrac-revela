Private Function Add_Check_OBRA()
Dim strSQL As String
Dim rsTerms As New ADODB.Recordset
Dim cnTerms As New ADODB.Connection
Dim lngRow As Long
Dim lngCol As Long
Dim strTerms As String
Dim lngFirst As Long
Dim Idx%
Dim booData As Boolean
Dim Arr
Dim lngCnt As Long


    On Error GoTo Error_Add_Check_OBRA
    clsGridFormat.List = vbNullString
    mbooLoad = True
    If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
    strSQL = "Get_Attr_Valid_Value_SubDom_Value_Def 'sd_PsyPlan_OBRA', 'NO REDUCT'"
    Set rsTerms = cnTerms.Execute(strSQL)
    With rsTerms
        Do Until .EOF
            lngCnt = lngCnt + 1
            If (!ATTRBTE_VALID_VALUE) <> vbNullString Then
                If Trim(clsGridFormat.List) = vbNullString Then
                    strTerms = Trim(!ATTRBTE_VALID_VALUE)
                End If
            End If
            .MoveNext
            If lngCnt = 1 Then
                lngCol = 2
                lngRow = grdReport.MaxRows
                Format_CellTypeEdit grdReport, lngRow, lngCol, "3", "Why a dose reduction is Contraindicated:", "TypeHAlignLeft", "OBRA"
            End If
            strTerms = Replace(strTerms, "''", "'")
            lngRow = grdReport.MaxRows + 1
            grdReport.MaxRows = lngRow
            If lngFirst = 0 Then lngFirst = lngRow
            lngCol = 2
            Format_CellTypeCheckBox grdReport, lngRow, lngCol, "1", "", "TypeHAlignLeft", "OBRA", False, 0, 0
            lngCol = 3
            Format_CellTypeEdit grdReport, lngRow, lngCol, "4", strTerms, "TypeHAlignLeft", "OBRA_TEXT"
        Loop
    End With
    lngCnt = 0
    strTerms = vbNullString
    strSQL = "Get_Attr_Valid_Value_SubDom_Value_Def 'sd_PsyPlan_OBRA', 'REDUCT'"
    Set rsTerms = cnTerms.Execute(strSQL)
    With rsTerms
        Do Until .EOF
            lngCnt = lngCnt + 1
            If (!ATTRBTE_VALID_VALUE) <> vbNullString Then
                If Trim(clsGridFormat.List) = vbNullString Then
                    strTerms = Trim(!ATTRBTE_VALID_VALUE)
                End If
            End If
            .MoveNext
            If lngCnt = 1 Then
                lngCol = 2
                lngRow = grdReport.MaxRows + 1
                grdReport.MaxRows = lngRow
                Format_CellTypeEdit grdReport, lngRow, lngCol, "3", "Titration Plan:", "TypeHAlignLeft", "OBRA"
            End If
            strTerms = Replace(strTerms, "''", "'")
            lngRow = grdReport.MaxRows + 1
            grdReport.MaxRows = lngRow
           ' If lngFirst = 0 Then lngFirst = lngRow
            lngCol = 2
            Format_CellTypeCheckBox grdReport, lngRow, lngCol, "1", "", "TypeHAlignLeft", "OBRA", False, 0, 0
            lngCol = 3
            Format_CellTypeEdit grdReport, lngRow, lngCol, "4", strTerms, "TypeHAlignLeft", "OBRA_TEXT"
        Loop
    End With
    strTerms = vbNullString
    strTerms = Read_OBRA
    With grdReport
        If Trim(strTerms) <> vbNullString Then
            Arr = Split(strTerms, vbNewLine)
            If UBound(Arr) > 0 Then
                For Idx = LBound(Arr) To UBound(Arr)
                    booData = False
                    If Arr(Idx) <> vbNullString And Len(Arr(Idx)) > 3 Then
                        For lngRow = lngFirst To .MaxRows
                            .Col = 2
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                If .TypeCheckText = Arr(Idx) Then
                                    booData = False
                                    .Text = "1"
                                    Exit For
                                End If
                            End If
                            If booData Then Exit For
                        Next lngRow
                    End If
                Next Idx
            Else
                booData = False
                For lngRow = lngFirst To .MaxRows
                    .Col = 2
                    .Row = lngRow
                    If .CellType = CellTypeCheckBox Then
                        If .TypeCheckText = Trim(strTerms) Then
                            booData = False
                            .Text = "1"
                            Exit For
                        End If
                    End If
                Next lngRow
            End If
        End If
    End With
    If cnTerms.State = adStateOpen Then
        cnTerms.Close
        Set rsTerms = Nothing
        Set cnTerms = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Add_Check_OBRA:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Add_Check_OBRA", Me.Name
    Exit Function
    Resume Next
End Function
