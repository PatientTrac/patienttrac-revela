Private Sub cmdSaveDr_Click()
Dim lngRow As Long
Dim lngCol As Long
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim lngGridPrim As Long
Dim strDate As String
Dim strTag As String


    On Error GoTo Error_Write_cmdSave
    Screen.MousePointer = vbHourglass
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        .Col = 2
        .Row = .ActiveRow
        If .CellTag <> vbNullString Then
            strTag = .CellTag
        End If
    End With
    If cctDoctor = vbNullString Then Exit Sub
    cctDoctor = Replace(cctDoctor, "'", "''")
    'Case this
    Select Case UCase(strTag)
        Case "MOOD", "PHYSICAL AIDS"
            If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
            strSQL = "Get_Patient_Mental_Status_Item " & piPatientID & "," & piEncounterID & ",'" & Trim(strTag) & "'"
            Set rsWrite = cnWrite.Execute(strSQL)
            With rsWrite
                If Not rsWrite.EOF Then
                    lngGridPrim = (!MSE_ID)
                End If
            End With
            If lngGridPrim = 0 Then
                strSQL = "Insert_Patient_Mental_Status " & piPatientID & "," & piEncounterID & "," _
                    & clsEncounter.ProviderID & "," & clsEncounter.FacilityID & ",'" _
                    & Trim(strTag) & "','" & Trim(cctDoctor) & "','" & Trim(udtNew_MSE.MSE_Note) & "','" & strDate & "'"
                    Set rsWrite = cnWrite.Execute(strSQL)
            Else
                strSQL = "UPDATE PATIENT_MENTAL_STATUS SET MSE_ITEM = '" & strTag & "', MSE_DATA = '" & Trim(cctDoctor) & "', " _
                    & "UPDATE_DATE = '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "' WHERE MSE_ID = " & lngGridPrim
                Set rsWrite = cnWrite.Execute(strSQL)
            End If
        Case "PATIENT WAS WEARING"
            If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
            If Not TextFound("Patient was wearing", cctDoctor, Len("Patient was wearing"), True) Then
                cctDoctor = "Patient was wearing" & " " & cctDoctor
            End If
            strSQL = "Get_Patient_Mental_Status_Item " & piPatientID & "," & piEncounterID & ",'General Appearance'"
            Set rsWrite = cnWrite.Execute(strSQL)
            With rsWrite
                If Not rsWrite.EOF Then
                    lngGridPrim = (!MSE_ID)
                End If
            End With
            If lngGridPrim = 0 Then
                strSQL = "INSERT INTO PATIENT_MENTAL_STATUS (PATIENT_ID,ENCOUNTER_ID, PROVIDER_ID, FACILITY_ID,  MSE_ITEM, " _
                    & "MSE_NOTES, INSERT_DATE) VALUES (" & piPatientID & "," & piEncounterID & "," _
                    & clsEncounter.ProviderID & "," & clsEncounter.FacilityID & ",'GENERAL APPEARANCE','" & Trim(cctDoctor) & "','" & strDate & "'"
                Set rsWrite = cnWrite.Execute(strSQL)
            Else
                strSQL = "UPDATE PATIENT_MENTAL_STATUS SET MSE_NOTES = '" & Trim(cctDoctor) & "', " _
                    & "UPDATE_DATE = '" & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "' WHERE MSE_ID = " & lngGridPrim
                Set rsWrite = cnWrite.Execute(strSQL)
            End If
        Case "SUBJECTIVE", "OBJECTIVE", "ASSESSMENT", "PLAN", "PRIOR_MEDICAL_NOTES", "PRIOR_SURGERY_NOTES", "PRIOR_HOSP_NOTES"
            If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
            strSQL = "Get_InPatient_Notes_PT_ID_ENCTR_ID_NOTE_TYPE '" & strTag & "%'," & piPatientID & "," & piEncounterID
            Set rsWrite = cnWrite.Execute(strSQL)
            With rsWrite
                If Not rsWrite.EOF Then
                    lngGridPrim = (!Note_ID)
                End If
            End With
            If lngGridPrim = 0 Then
                strSQL = "Insert_InPatient_Notes " & piPatientID & "," & piEncounterID & "," _
                    & clsEncounter.ProviderID & "," & clsEncounter.FacilityID & ",'" & clsEncounter.EncounterType & "','" _
                    & Trim(cctDoctor) & "', '" & strTag & "%','" & strDate & "'"
                    Set rsWrite = cnWrite.Execute(strSQL)
            Else
                strSQL = "Update_InPatient_Notes '" & Trim(cctDoctor) & "'," & lngGridPrim
                    Set rsWrite = cnWrite.Execute(strSQL)
            End If
        Case "OTHER_SOCIAL"
            cctDoctor = Replace(cctDoctor, "Other relevant social factors:", "")
            Write_Other_Social
        Case "TOBACCO_USE"
            Write_Tobacco_Details
        Case "ALCOHOL_TYPE", "DRUG_TYPE"
             Write_Alcohol_Drug_Comments
    End Select
    grdReport.sheet = clsGridFormat.SheetNumber
    grdReport.ActiveSheet = clsGridFormat.SheetNumber
    If strTag = "MOOD" Then
        lngCol = 2
        Format_CellTypeEdit grdReport, grdReport.ActiveRow, lngCol, "5", Chr(34) & cctDoctor & Chr(34), "TypeHAlignLeft", strTag
    ElseIf strTag = "PHYSICAL AIDS" Then
         lngCol = 3
        Format_CellTypeEdit grdReport, grdReport.ActiveRow, lngCol, "4", cctDoctor, "TypeHAlignLeft", strTag
    ElseIf strTag = "PATIENT WAS WEARING" Then
         lngCol = 2
         If Not TextFound("Patient was wearing", Trim(cctDoctor), Len("Patient was wearing"), True) Then
            cctDoctor = "Patient was wearing" & " " & Trim(cctDoctor)
         End If
        Format_CellTypeEdit grdReport, grdReport.ActiveRow, lngCol, "4", cctDoctor, "TypeHAlignLeft", strTag
    ElseIf strTag = "OTHER_SOCIAL" Then
         lngCol = 3
        Format_CellTypeEdit grdReport, grdReport.ActiveRow, lngCol, "4", cctDoctor, "TypeHAlignLeft", strTag
    ElseIf strTag = "DRUG_TYPE" Or strTag = "ALCOHOL_TYPE" Or strTag = "TOBACCO_USE" Then
         lngCol = 6
        Format_CellTypeEdit grdReport, grdReport.ActiveRow, lngCol, "2", cctDoctor, "TypeHAlignLeft", strTag
    Else
        lngCol = 2
        Format_CellTypeEdit grdReport, grdReport.ActiveRow, lngCol, "5", cctDoctor, "TypeHAlignLeft", strTag
    End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    
    fraDoctor.Visible = False
    Screen.MousePointer = vbDefault
    Exit Sub
Error_Write_cmdSave:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, mstrRowData, "Write_cmdSave", Me.Name
    Exit Sub
    Resume Next
End Sub

