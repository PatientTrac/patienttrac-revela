Function Get_SocialHist()
Dim strSQL As String
Dim cnTreatPlan As New ADODB.Connection
Dim rsTreatPlan As New ADODB.Recordset
Dim strBullet As String
Dim strMilitary As String
Dim lngDateDiff As Long
Dim strData As String
Dim strEnctrDate As String
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field


        On Error GoTo Error_Get_SocialHist
        strBullet = "*    "
        strEnctrDate = Get_Enctr_Date(piEncounterID)
        If cnTreatPlan.State = adStateClosed Then cnTreatPlan.open psConnect(0)
        strSQL = "Get_Medical_Social_History_PT_ID " & piPatientID
        Set rsTreatPlan = cnTreatPlan.Execute(strSQL)
        With rsTreatPlan
            Do Until .EOF
                Set Flds = .Fields
                Clear_SocialString
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "INSERT_DATE"
                                    strData = Format(Fld.Value, "mm/dd/yyyy")
                                Case "MARITAL_STATUS"
                                    clsSocialHist.MaritalStat = Trim(Fld.Value)
                                Case "PREGNANCY"
                                    clsSocialHist.Pregnancy = Trim(Fld.Value)
                                Case "EDUCATION"
                                    clsSocialHist.Education = Trim(Fld.Value)
                                Case "RELIGION"
                                    clsSocialHist.Religion = Trim(Fld.Value)
                                Case "MILITARY_SERVICE"
                                    clsSocialHist.Military = Trim(Fld.Value)
                                Case "MIL_RANK"
                                    clsSocialHist.MilDetail = Trim(Fld.Value)
                                Case "EMPLOYMENT"
                                    clsSocialHist.Employment = Trim(Fld.Value)
                                Case "SMOKE"
                                    clsSocialHist.Smoker = Trim(Fld.Value)
                                Case "DRINK"
                                    clsSocialHist.Drink = Trim(Fld.Value)
                                Case "SUB_ABUSE"
                                    clsSocialHist.SubAbuse = Trim(Fld.Value)
                                Case "COFFEE"
                                    clsSocialHist.Coffee = Trim(Fld.Value)
                                Case "EXERCISE"
                                    clsSocialHist.Exercise = Trim(Fld.Value)
                                Case "DIET"
                                    clsSocialHist.Diet = Trim(Fld.Value)
                            End Select
                        End If
                    End If
                Next
                .MoveNext
                lngDateDiff = DateDiff("d", strEnctrDate, strData)
                If lngDateDiff <= 0 Then
                    If Trim(clsSocialHist.MaritalStat) <> vbNullString Then
                        clsReport.SocialHist = clsPatient.Person & " " & "reports being" & " " & LCase(clsSocialHist.MaritalStat) & "."
                        clsPatient.CurMarStatus = clsSocialHist.MaritalStat
                    End If
                    
                    If clsPatient.Gender = "F" Then
                        If clsSocialHist.Pregnancy <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist & vbNewLine & strBullet & " " & clsSocialHist.Pregnancy
                        If TextFound("1 children", clsReport.SocialHist, Len("1 children"), True) Then
                            clsReport.SocialHist = Replace(clsReport.SocialHist, "children", "child")
                        End If
                    End If
                    If clsSocialHist.Education <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist & _
                        vbNewLine & strBullet & " " & clsPatient.Person & " " & "reports having completed" & " " & UCase(clsSocialHist.Education) & "."
                    If clsSocialHist.Religion <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist & _
                        vbNewLine & strBullet & " " & clsPatient.Possessive & " " & "religious preference is" & " " & IsProperCase(clsSocialHist.Religion) & "."
                    If Trim(clsSocialHist.Military) <> vbNullString Then
                        If TextFound("none", clsSocialHist.Military, Len("none"), True) Then
                            strMilitary = clsPatient.Person & " " & "reports no military service."
                        Else
                            strMilitary = clsPatient.Person & " " & "reports serving in the" & " " & clsSocialHist.Military
                        End If
                        If clsSocialHist.MilDetail <> vbNullString Then strMilitary = Trim(strMilitary) & " " _
                            & clsPatient.Possessive & " " & "highest reported rank was" & " " & clsSocialHist.MilDetail & ". "
                        If Trim(strMilitary) <> vbNullString Then
                             clsReport.SocialHist = clsReport.SocialHist & vbNewLine & strBullet & " " & strMilitary
                        End If
                    End If
                     If clsSocialHist.Employment <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist _
                        & vbNewLine & strBullet & " " & clsPatient.Possessive & " " & "employment:" & " " & clsSocialHist.Employment
                     If clsSocialHist.Smoker <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist _
                        & vbNewLine & strBullet & " " & clsSocialHist.Smoker
                     If clsSocialHist.Drink <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist _
                        & vbNewLine & strBullet & " " & clsSocialHist.Drink
                     If clsSocialHist.SubAbuse <> vbNullString Then
                        If Not TextFound(clsSocialHist.SubAbuse, clsReport.SocialHist, Len(clsSocialHist.SubAbuse), True) Then
                            clsReport.SocialHist = clsReport.SocialHist & vbNewLine & strBullet & " " & clsSocialHist.SubAbuse
                        End If
                     End If
                     If clsSocialHist.Coffee <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist & vbNewLine & strBullet & " " & clsSocialHist.Coffee
                     If clsSocialHist.Exercise <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist & vbNewLine & strBullet & " " & clsSocialHist.Exercise
                     If clsSocialHist.Diet <> vbNullString Then clsReport.SocialHist = clsReport.SocialHist & vbNewLine & strBullet & " " & clsSocialHist.Diet
                     Exit Do
                End If
            .MoveNext
            Loop
        End With
        If cnTreatPlan.State = adStateOpen Then
            cnTreatPlan.Close
            Set cnTreatPlan = Nothing
            Set rsTreatPlan = Nothing
        End If
    Exit Function
Error_Get_SocialHist:
    Write_Error Err.Description, Err.Number, strSQL, "Get_SocialHist", App.EXEName & "." & "ModReports"
    Exit Function
    Resume Next
End Function

Private Function Format_CellTypeCheckBox(vGrid As Object, vlngRow As Long, vlngCol As Long, vstrSpan As String, vstrText As String, vstrHAligh As String, _
Optional vstrCellTag As String, Optional vbooUnderLine As Boolean, Optional vlngBackColor As Long, Optional vstrValue As Long, _
Optional vstrCellNote As String, Optional vlngFontSize As Long, Optional vstrCheckAligh As String)
Dim CellNote As Long
Dim lngSpan As Long

    With vGrid
        .sheet = clsGridFormat.SheetNumber
        .BlockMode = True
            .Col = vlngCol
            .Col2 = vlngCol
            .Row = vlngRow
            .Row2 = vlngRow
            .CellType = CellTypeCheckBox
            .FontName = "Albertus Bold"
            If vlngFontSize > 0 Then
                .FontSize = vlngFontSize
            Else
                .FontSize = 11
            End If
            .FontBold = True
            .TypeCheckType = TypeCheckTypeNormal
            If vbooUnderLine Then .FontUnderline = True
            If vstrCellNote <> vbNullString Then .CellNote = vstrCellNote
            If vstrCellTag <> vbNullString Then .CellTag = vstrCellTag
            .TypeVAlign = TypeVAlignTop
            If vstrHAligh = "TypeHAlignCenter" Then
              .TypeHAlign = TypeHAlignCenter
            Else
              .TypeHAlign = TypeHAlignLeft
            End If
            If TextFound("maxcols", vstrSpan, Len("maxcols"), True) Then
                .AddCellSpan vlngCol, vlngRow, .MaxCols, 1
            ElseIf Trim(vstrSpan) <> vbNullString Then
                lngSpan = vstrSpan
                If lngSpan > 0 Then .AddCellSpan vlngCol, vlngRow, lngSpan, 1
            End If
            If vstrCheckAligh <> vbNullString Then
                .TypeCheckTextAlign = vstrCheckAligh
            End If
            .CellType = CellTypeCheckBox
            .TypeCheckText = Trim(vstrText)
            .Text = vstrValue
          .BlockMode = False
    End With
End Function


