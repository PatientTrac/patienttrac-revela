    udtEM_Value.Staff_Discuss = vbNullString
    udtEM_Value.Medication_Evaluation = vbNullString
    udtEM_Value.System_Review = vbNullString
    udtEM_Value.RecRev = vbNullString
    If cnPlan.State = adStateClosed Then cnPlan.open psConnect(0)
    strSQL = "Get_Evaluation_Management " & piPatientID & "," & piEncounterID
    Set rsPlan = cnPlan.Execute(strSQL)
        With rsPlan
            If Not .EOF Then
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "RECORD_REVIEW"
                                    udtEM_Value.RecRev = Fld.Value
                                Case "INPATIENT_STAFF_DISCUSS"
                                    udtEM_Value.Staff_Discuss = Fld.Value
                                Case "PHARMACOLOGY_EVALUATION"
                                    udtEM_Value.Medication_Evaluation = Fld.Value
                                Case "SYSTEM_REVIEW"
                                    udtEM_Value.System_Review = Fld.Value
                            End Select
                        End If
                    End If
                Next
            End If
        End With
    Arr = Split(LookUpCellTag("RECORD REVIEW"), "|")
    If UBound(Arr) > 0 Then
        lngRow = Arr(1)
    End If
    With grdReport
          For lngCol = 2 To .MaxCols
            .Col = lngCol
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If UCase(.CellTag) = "RECORD REVIEW" Then
                    If .CellType = CellTypeCheckBox Then
                        Select Case IsProperCase(.TypeCheckText)
                            Case "Chart Reviewed"
                                If Trim(udtEM_Value.RecRev) <> vbNullString Then
                                    .Text = "1"
                                End If
                            Case "Case Discussed With Staff"
                                If Trim(udtEM_Value.Staff_Discuss) <> vbNullString Then
                                    .Text = "1"
                                End If
                            Case "Medication Evaluation Rendered"
                                If Trim(udtEM_Value.Medication_Evaluation) <> vbNullString Then
                                    .Text = "1"
                                End If
                            Case "Systems Review"
                                If Trim(udtEM_Value.System_Review) <> vbNullString Then
                                    .Text = "1"
                                End If
                        End Select
                    End If
                End If
            End If
          Next lngCol
    End With
    mbooLoad = False
    If cnPlan.State = adStateOpen Then
        cnPlan.Close
        Set cnPlan = Nothing
        Set rsPlan = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
