Private Function Get_GridTerms(vstrSubDom As String, Optional vstrType As String)
Dim strSQL As String
Dim rsTerms As New ADODB.Recordset
Dim cnTerms As New ADODB.Connection

    On Error GoTo Error_Get_GridTerms
    clsGridFormat.List = vbNullString
    If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
    mstrList = vbNullString
    If vstrType = vbNullString Then
        strSQL = "Get_Attr_Valid_Value_SubDom_Sequence '" & vstrSubDom & "'"
    Else
        strSQL = "Get_Attr_Valid_Value_SubDom_Alphabetic '" & vstrSubDom & "'"
    End If
    Set rsTerms = cnTerms.Execute(strSQL)
    With rsTerms
        Do Until .EOF
            If (!ATTRBTE_VALID_VALUE) <> vbNullString Then
                If Trim(clsGridFormat.List) = vbNullString Then
                    clsGridFormat.List = Trim(!ATTRBTE_VALID_VALUE)
                Else
                    clsGridFormat.List = clsGridFormat.List & Chr(9) & Trim(!ATTRBTE_VALID_VALUE)
                End If
            End If
            .MoveNext
        Loop
    End With
    If cnTerms.State = adStateOpen Then
        cnTerms.Close
        Set rsTerms = Nothing
        Set cnTerms = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_GridTerms:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Get_Terms", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Get_MSE_GridTerms(vstrSubDom As String)
Dim strSQL As String
Dim rsTerms As New ADODB.Recordset
Dim cnTerms As New ADODB.Connection
Dim lngRow As Long
Dim varCellValue
Dim Arr
Dim Idx As Integer
Dim strValue As String
Dim bSkip As Boolean

    On Error GoTo Error_Get_MSE_GridTerms
    If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
    grdSpecLoc.ClearRange 1, 1, 1, grdSpecLoc.MaxRows, False
    If clsGridFormat.CellTag = "Verbal Abilities" Then
        Get_Verbal_Terms
    Else
        strSQL = "Get_Attr_Valid_Value_SubDom_Sequence '" & vstrSubDom & "'"
        Set rsTerms = cnTerms.Execute(strSQL)
        With rsTerms
            Do Until .EOF
                If (!ATTRBTE_VALID_VALUE) <> vbNullString Then
                    strValue = (!ATTRBTE_VALID_VALUE)
                End If
                .MoveNext
                bSkip = False
                If strValue <> vbNullString Then
                    For lngRow = 1 To grdSpecLoc.MaxRows
                        grdSpecLoc.GetText 1, lngRow, varCellValue
                        If varCellValue = strValue Then
                            bSkip = True
                        End If
                    Next lngRow
                    If Not bSkip Then
                        lngRow = grdSpecLoc.MaxRows + 1
                        grdSpecLoc.MaxRows = lngRow
                        Format_CellTypeEdit grdSpecLoc, lngRow, 1, "1", Trim(strValue), "TypeHAlignLeft"
                        grdSpecLoc.SetCellBorder 1, lngRow, 2, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                    End If
                End If
            Loop
        End With
        mstrGridTerms = Trim(vstrSubDom)
        If cnTerms.State = adStateOpen Then
            cnTerms.Close
            Set rsTerms = Nothing
            Set cnTerms = Nothing
        End If
        strValue = vbNullString
        If clsGridFormat.Text <> vbNullString Then
            Arr = Split(clsGridFormat.Text, "; ")
            If UBound(Arr) > 0 Then
                For Idx = LBound(Arr) To UBound(Arr)
                    For lngRow = 1 To grdSpecLoc.MaxRows
                        grdSpecLoc.GetText 1, lngRow, varCellValue
                        If TextFound("Oriented to", CStr(varCellValue), Len("Oriented to"), True) And Trim(varCellValue) <> vbNullString Then
                            strValue = Trim(Arr(Idx))
                            strValue = Replace(strValue, "oriented to", "")
                            strValue = Replace(strValue, "Oriented to", "")
                            strValue = Replace(strValue, "Not", "No")
                            strValue = Replace(strValue, "not", "No")
                            strValue = Replace(strValue, "-", "")
                            strValue = Replace(strValue, "  ", "")
                            varCellValue = Replace(varCellValue, "oriented to", "")
                            varCellValue = Replace(varCellValue, "Oriented to", "")
                            varCellValue = Replace(varCellValue, "  ", "")
                            varCellValue = Replace(varCellValue, "-", "")
                            varCellValue = Replace(varCellValue, "Not", "No")
                            varCellValue = Replace(varCellValue, "not", "No")
                            varCellValue = Trim(varCellValue)
                            If IsProperCase(strValue) = IsProperCase(varCellValue) Then
                                grdSpecLoc.Col = 1
                                grdSpecLoc.Row = lngRow
                                grdSpecLoc.BackColor = grdCurItem
                            End If
                        ElseIf Trim(varCellValue) <> vbNullString Then
                            If TextFound(Trim(Arr(Idx)), Trim(varCellValue), Len(Trim(Arr(Idx))), True) Then
                                grdSpecLoc.Col = 1
                                grdSpecLoc.Row = lngRow
                                grdSpecLoc.BackColor = grdCurItem
                            End If
                        End If
                    Next lngRow
                Next Idx
            Else
                For lngRow = 1 To grdSpecLoc.MaxRows
                    grdSpecLoc.GetText 1, lngRow, varCellValue
                    If TextFound("Oriented", CStr(varCellValue), Len("Oriented"), True) And Trim(varCellValue) <> vbNullString Then
                            If TextFound(Trim(clsGridFormat.Text), Trim(varCellValue), Len(Trim(clsGridFormat.Text)), True) Then
                                grdSpecLoc.Col = 1
                                grdSpecLoc.Row = lngRow
                                grdSpecLoc.BackColor = grdCurItem
                            End If
                    ElseIf Trim(varCellValue) <> vbNullString Then
                        If clsGridFormat.Text = Trim(varCellValue) Then
                               grdSpecLoc.Col = 1
                               grdSpecLoc.Row = lngRow
                               mbooByPass = True
                               grdSpecLoc.BackColor = grdCurItem
                               mbooByPass = False
                               Exit For
                        End If
                    End If
                Next lngRow
            End If
        End If
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_MSE_GridTerms:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Get_GridTerms", Me.Name
    Exit Function
    Resume Next
End Function
