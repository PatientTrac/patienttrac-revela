Private Function Get_Clock_History()
Dim strSQL As String
Dim cnLab As New ADODB.Connection
Dim rsLab As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim Arr
Dim lngRow As Long
Dim lngCol As Long
Dim strProvider As String
Dim i%
Dim strData As String
Dim lngEnctr As Long
Dim mStream
Dim fso As New FileSystemObject
Dim strInter As String
Dim strDate As String
Dim lngDate As Long
Dim strFile As String
Dim bData As Boolean


    On Error GoTo Error_Get_Clock_History
    Screen.MousePointer = vbHourglass
    Get_Encounter piEncounterID
    If clsEncounter.StartDate = vbNullString Then
        udtTime.StartDate = Format(Now, "mm/dd/yyyy")
    Else
        udtTime.StartDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
    End If
    Clear_ClockDraw
    udtTime.EndDate = DateAdd("d", 1, udtTime.StartDate)
    If cnLab.State = adStateClosed Then cnLab.open psConnect(0)
    rsLab.open "Collect_Annotation_Image " & piPatientID & ",'InkClock','" & Format(udtTime.StartDate, "mm/dd/yyyy") & "','" & Format(udtTime.EndDate, "mm/dd/yyyy") & "'", cnLab, adOpenKeyset, adLockOptimistic
    With rsLab
        If Not .EOF Then
            bData = True
            Clear_ClockDraw
            strData = vbNullString
            strInter = vbNullString
            lngEnctr = 0
            lngEnctr = (!Encounter_ID)
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "ANNOTATION"
                                clsClockDraw.Image = Fld.Value
                                Set mStream = New ADODB.Stream
                                mStream.Type = adTypeBinary
                                mStream.open
                                mStream.Write Fld.Value
                                clsClockDraw.Image = "c:\Clock_Test" & "_" & piPatientID & "_" & lngEnctr & ".bmp"
                                mStream.SaveToFile clsClockDraw.Image, adSaveCreateOverWrite
                                Set mStream = Nothing
                            Case "ENCOUNTER_ID"
                                lngEnctr = Fld.Value
                            Case "ENCNTR_START_DATE"
                                strDate = Fld.Value
                            Case "CLINICAL_DESC"
                                clsClockDraw.PhysFinding = Fld.Value
                            Case "ANNOTATION_IMAGE"
                                clsClockDraw.Comments = Fld.Value
                            Case "RECALL_1"
                                If clsClockDraw.Recall1 = vbNullString Then clsClockDraw.Recall1 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Apple" & Chr(34)
                            Case "RECALL_2"
                                If clsClockDraw.Recall2 = vbNullString Then clsClockDraw.Recall2 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Penny" & Chr(34)
                            Case "RECALL_3"
                                If clsClockDraw.Recall3 = vbNullString Then clsClockDraw.Recall3 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Watch" & Chr(34)
                        End Select
                    End If
                End If
            Next
        End If
    End With
    If Not bData Then
        If rsLab.State = adStateOpen Then rsLab.Close
        If cnLab.State = adStateClosed Then cnLab.open psConnect(0)
        strSQL = "SELECT CLINICAL_DESC, ANNOTATION_IMAGE, RECALL_1, RECALL_2, RECALL_3 FROM " _
            & "ANNOTATIONS WHERE PATIENT_ID = " & piPatientID & " AND " _
            & "ENCOUNTER_ID = " & piEncounterID & " AND ANNOTATION_REF = 'InkClock'"
        Set rsLab = cnLab.Execute(strSQL)
        With rsLab
            If Not .EOF Then
                bData = True
                Clear_ClockDraw
                strData = vbNullString
                strInter = vbNullString
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "CLINICAL_DESC"
                                    clsClockDraw.PhysFinding = Fld.Value
                                Case "ANNOTATION_IMAGE"
                                    clsClockDraw.Comments = Fld.Value
                                Case "RECALL_1"
                                    If clsClockDraw.Recall1 = vbNullString Then clsClockDraw.Recall1 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Apple" & Chr(34)
                                Case "RECALL_2"
                                    If clsClockDraw.Recall2 = vbNullString Then clsClockDraw.Recall2 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Penny" & Chr(34)
                                Case "RECALL_3"
                                    If clsClockDraw.Recall3 = vbNullString Then clsClockDraw.Recall3 = Trim(Fld.Value) & " " & "term" & Chr(34) & "Watch" & Chr(34)
                            End Select
                        End If
                    End If
                Next
            End If
        End With
    End If
    If TextFound("Unable to complete", clsClockDraw.Comments, Len("Unable to complete"), True) Then
        clsClockDraw.Comments = Replace(clsClockDraw.Comments, "Calculated Results", vbNullString)
        clsClockDraw.Comments = Trim(clsClockDraw.Comments)
    ElseIf Trim(clsClockDraw.Comments) = vbNewLine & "Calculated Results" Then
        clsClockDraw.Comments = vbNullString
    End If
    strData = vbNullString
    strData = Replace(clsClockDraw.Comments, "Calculated Results", "")
    strData = Replace(strData, ":", "")
    Arr = Split(strData, vbNewLine)
    If UBound(Arr) > 0 Then
        If Arr(0) <> vbNullString Then
            strData = Trim(Arr(0))
        ElseIf Arr(1) <> vbNullString Then
             strData = Trim(Arr(1))
        End If
    Else
        strData = Trim(strData)
    End If
    If strData <> vbNullString Then
        If IsNumeric(strData) Then
            If Val(strData) <= 3 Then
                clsClockDraw.Comments = "Calculated Results:" & " " & strData & " " & "Results less than 4 indicates Impairment."
            ElseIf Val(strData) > 3 Then
                clsClockDraw.Comments = "Calculated Results:" & " " & strData & " " & "Results greater than 4 indicates no Impairment."
            End If
        End If
    End If
    If cnLab.State = adStateOpen Then
        If rsLab.State = adStateOpen Then rsLab.Close
        Set cnLab = Nothing
        Set rsLab = Nothing
        Set Flds = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_Clock_History:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, " Get_Clock_History", Me.Name
    Exit Function
    Resume Next
End Function




