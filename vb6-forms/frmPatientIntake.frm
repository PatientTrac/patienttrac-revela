Private Function Get_PsyMMSE()
Dim strSQL As String
Dim cnDevelop As New ADODB.Connection
Dim rsDevelop As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim lngRow As Long
Dim lngCol As Long
Dim strBullet As String
Dim lngDateDiff As Long
Dim strData As String
Dim strEnctrDate As String
Dim lngAttention As Long
Dim lngCalculation As Long
Dim booData As Boolean
Dim Arr
Dim Idx%
Dim lngValue As Long
Dim varCellValue

    On Error GoTo Error_Get_PsyMMSE
    Clear_MMSE
    grdReport.sheet = 2
    grdReport.ActiveSheet = 2
    If cnDevelop.State = adStateClosed Then cnDevelop.open psConnect(0)
    strSQL = "Get_Patient_Scale_PT_Enct_Form_Name " & piPatientID & "," & piEncounterID & ",'MMSE'"
    Set rsDevelop = cnDevelop.Execute(strSQL)
    With rsDevelop
        Do Until .EOF
            Clear_GridFormat
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "DEVELOPMENT_GROUP"
                                clsGridFormat.CellTag = UCase(Fld.Value)
                            Case "ROW_NAME"
                                clsGridFormat.RowName = UCase(Fld.Value)
                            Case "CLINICAL_VALUE"
                                clsGridFormat.Text = UCase(Fld.Value)
                            Case "CLINICAL_NOTE"
                                clsGridFormat.TextNote = UCase(Fld.Value)
                        End Select
                    End If
                End If
            Next
            booData = True
            .MoveNext
            Arr = Split(LookUpCellTag(clsGridFormat.CellTag), "|")
            If UBound(Arr) > 0 Then
                lngRow = Val(Arr(1))
            End If
            If lngRow > 0 Then
                For lngCol = 1 To grdReport.MaxCols
                    grdReport.Row = lngRow
                    grdReport.GetText lngCol, lngRow, varCellValue
                    If IsProperCase(Trim(varCellValue)) = IsProperCase(clsGridFormat.RowName) Then
                        If clsGridFormat.Text = "1" Then
                            Format_CellTypeCheckBox grdReport, lngRow, 3, "1", clsGridFormat.RowName, "TypeHAlignCenter", clsGridFormat.CellTag, False, 0, 1
                        Else
                            Format_CellTypeCheckBox grdReport, lngRow, 3, "1", clsGridFormat.RowName, "TypeHAlignCenter", clsGridFormat.CellTag, False, 0, 0
                        End If
                        Exit For
                    End If
                Next lngCol
                lngRow = 0
                Arr = Split(LookUpCellTag(clsGridFormat.CellTag & "_SCORE"), "|")
                If UBound(Arr) > 0 Then
                    lngRow = Val(Arr(1))
                End If
                If lngRow = 0 Then
                    Select Case clsGridFormat.CellTag
                        Case "TIME"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "5/" & Calc_MSE_Value & ")", "TypeHAlignleft", "TIME_SCORE", True
                        Case "PLACE"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "5/" & Calc_MSE_Value & ")", "TypeHAlignleft", "PLACE_SCORE", True
                        Case "IMMEDIATE_RECALL"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "3/" & Calc_MSE_Value & ")", "TypeHAlignleft", "IMMEDIATE_RECALL_SCORE", True
                        Case "CALCULATION"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "5/" & Calc_MSE_Value & ")", "TypeHAlignleft", "CALCULATION_SCORE", True
                        Case "ATTENTION"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "5/" & Calc_MSE_Value & ")", "TypeHAlignleft", "ATTENTION_SCORE", True
                        Case "DELAYED_RECALL"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "3/" & Calc_MSE_Value & ")", "TypeHAlignleft", "DELAYED_RECALL_RECALL", True
                        Case "NAMING"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "2/" & Calc_MSE_Value & ")", "TypeHAlignleft", "NAMING_RECALL", True
                        Case "REPETITION"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "1/" & Calc_MSE_Value & ")", "TypeHAlignleft", "REPETITION_RECALL", True
                        Case "3 STAGE_COMMAND"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "3/" & Calc_MSE_Value & ")", "TypeHAlignleft", "3 STAGE_COMMAND_RECALL", True
                        Case "READING"
                            Format_CellTypeEdit grdReport, lngRow, 2, "1", "(" & "1/" & Calc_MSE_Value & ")", "TypeHAlignleft", "READING_RECALL", True
                    End Select
                End If
            End If
        Loop
    End With
    If cnDevelop.State = adStateOpen Then
        cnDevelop.Close
        Set cnDevelop = Nothing
        Set rsDevelop = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Get_PsyMMSE:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Get_PsyMMSE", Me.Name
    Exit Function
    Resume Next
End Function

