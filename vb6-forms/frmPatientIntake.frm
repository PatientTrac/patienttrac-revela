Function Read_School()
Dim cnEmploy As New ADODB.Connection
Dim rsEmploy As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim strSQL As String
Dim lngPrimKey As Long
Dim strDate As String
Dim strEnctr As String
Dim lngDateDiff As Long
Dim Idx As Integer
Dim Arr
Dim strZip As String
Dim piPatientID As Long
Dim strStatus As String

    On Error GoTo Error_Read_School
    Screen.MousePointer = vbHourglass
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy")
    Else
        strDate = Format(Now, "mm/dd/yyyy")
    End If
    Clear_Student
    If cnEmploy.State = adStateClosed Then cnEmploy.open psConnect(0)
    strSQL = "Get_Patient_School_PTID " & piPatientID
    Set rsEmploy = cnEmploy.Execute(strSQL)
    With rsEmploy
        Do Until .EOF
            If (!INSERT_DATE) <> vbNullString Then strEnctr = Format((!INSERT_DATE), "mm/dd/yyyy")
            lngDateDiff = DateDiff("d", strDate, strEnctr)
            If lngDateDiff <= 0 Then
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "SCHOOL_NAME"
                                    clsSchool.Name = Trim(Fld.Value)
                                Case "GRADE"
                                    clsSchool.Position = Trim(Fld.Value)
                                Case "ADDRESS1"
                                     clsSchool.Address = Trim(Fld.Value)
                                Case "ADDRESS2"
                                    clsSchool.Address2 = Trim(Fld.Value)
                                Case "CITY"
                                    clsSchool.City = Trim(Fld.Value)
                                Case "STATE"
                                    clsSchool.State = Trim(Fld.Value)
                                Case "ZIPCODE"
                                    clsSchool.Zip = Trim(Fld.Value)
                                Case "ZIP_EXT"
                                    clsSchool.Zip_Ext = Trim(Fld.Value)
                                Case "AREA_CODE"
                                    clsSchool.AreaCode = Trim(Fld.Value)
                                Case "PHONE_1"
                                    clsSchool.Phone1 = Trim(Fld.Value)
                                Case "PHONE_2"
                                    clsSchool.Phone2 = Trim(Fld.Value)
                                Case "PHONE_EXT"
                                    clsSchool.PhoneExt = Trim(Fld.Value)
                                Case "STATUS"
                                    clsSchool.Status = Trim(Fld.Value)
                            End Select
                        End If
                    End If
                Next
            End If
            Exit Do
            .MoveNext
        Loop
    End With
    If cnEmploy.State = adStateOpen Then
        cnEmploy.Close
        Set cnEmploy = Nothing
        Set rsEmploy = Nothing
        Set Flds = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_School:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_School", App.EXEName & "." & "ModReports"
    Exit Function
    Resume
End Function

