Private Function PrinterIndex(ByVal PrinterName As String) As Integer
    Dim i As Integer
    Dim hdc
    
    For i = 0 To Printers.Count - 1
        If LCase(Printers(i).DeviceName) Like LCase(PrinterName) Then
            PrinterIndex = i
            Printer_HDC = Printers(i).hdc
            Exit Function
        End If
    Next
    PrinterIndex = -1
End Function

Private Sub grdSpecLoc_DblClick(ByVal Col As Long, ByVal Row As Long)
Dim lngRow As Long
Dim lngCol As Long
Dim bFound As Boolean
Dim strTag As String
Dim lngSheet As Long

    On Error GoTo Error_Rating_Scale
    With grdSpec
        lngRow = Row
        lngCol = Col
        .Col = lngCol
        .Row = lngRow
        If .CellTag <> vbNullString Then
            strTag = UCase(.CellTag)
            For lngSheet = 1 To grdReport.SheetCount
                grdReport.sheet = lngSheet
                If strTag = "HAMILTON RATING" And grdReport.SheetName = "HAMILTON DEPRESSION RATING" Then
                    bFound = True
                    grdReport.ActiveSheet = lngSheet
                    grdReport.sheet = lngSheet
                    Exit For
                ElseIf strTag = "AIMS" And grdReport.SheetName = "AIMS" Then
                    bFound = True
                    grdReport.ActiveSheet = lngSheet
                    grdReport.sheet = lngSheet
                    Exit For
'                ElseIf strTag = "CLINICAL DEMENTIA" And grdReport.SheetName = "AIMS" Then
'                    bFound = True
'                    grdReport.ActiveSheet = lngSheet
'                    grdReport.sheet = lngSheet
'                    Exit For
                End If
            Next lngSheet
            If Not bFound Then
                Select Case strTag
                    Case "HAMILTON RATING"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "HAMILTON DEPRESSION RATING"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Add_Psychiatry_Test_Page
                        Add_Hamilton
                    Case "CLINICAL DEMENTIA"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "CLINICAL DEMENESIA"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Load_CDR
                    Case "GERIATRIC PAIN MEASURE"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "GPM"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Add_GPM
                    Case "KATZ ADL"
                        clsGridFormat.SheetNumber = grdReport.SheetCount + 1
                        grdReport.SheetCount = clsGridFormat.SheetNumber
                        grdReport.sheet = clsGridFormat.SheetNumber
                        clsGridFormat.SheetName = "KATZ"
                        grdReport.SheetName = clsGridFormat.SheetName
                        Add_Katz
                End Select
            End If
        End If
    End With
    Exit Sub
Error_Rating_Scale:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Load", Me.Name
    Resume Next
    Exit Sub
End Sub


