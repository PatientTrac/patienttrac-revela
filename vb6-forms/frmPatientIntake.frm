            If Trim(clsGridFormat.CellTag) <> vbNullString Then
                clsGridFormat.Text = vbNullString
                If .CellType = CellTypeCheckBox Then
                    If .Text = "1" Then
                        If Col = 6 Then
                            .GetText 1, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "Yes"
                            mbooLoad = True
                            .Col = 7
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        ElseIf Col = 7 Then
                            .GetText 1, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "No"
                            mbooLoad = True
                            .Col = 6
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        End If
                        If Trim(clsGridFormat.Text) <> vbNullString Then Write_GPM
                    End If
                End If
                Calc_GPM
            End If
        End If
    End With
    Exit Function
End Function

Private Function Run_Katz(Col As Long, Row As Long)
Dim strText As String
Dim strTag As String
Dim strTextNote As String
Dim lngCol As Long
Dim lngRow As Long
Dim bFound As Boolean
Dim strAllergy As String
Dim varCellValue
Dim Arr

    If mbooLoad Then Exit Function
    With grdReport
        .sheet = clsGridFormat.SheetNumber
        .ActiveSheet = clsGridFormat.SheetNumber
        .SheetName = clsGridFormat.SheetName
        Clear_GridFormat
        .Col = Col
        .Row = Row
        If .CellTag <> vbNullString Then
            clsGridFormat.RowType = .CellTag
            .GetText 1, Row - 1, varCellValue
            clsGridFormat.CellTag = varCellValue
            If Trim(clsGridFormat.CellTag) <> vbNullString Then
                clsGridFormat.Text = vbNullString
                If .CellType = CellTypeCheckBox Then
                    If .Text = "1" Then
                        If Col = 2 Then
                            .GetText 3, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "Yes"
                            mbooLoad = True
                            .Col = 5
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        ElseIf Col = 5 Then
                            .GetText 6, Row, varCellValue
                            clsGridFormat.Text = varCellValue
                            clsGridFormat.TextNote = "No"
                            mbooLoad = True
                            .Col = 2
                            .Row = Row
                            .Text = "0"
                            mbooLoad = False
                        End If
                        If Trim(clsGridFormat.Text) <> vbNullString Then Write_Katz
                        Arr = Split(LookUpCellTag(clsGridFormat.CellTag & "_SCORE"), "|")
                        If UBound(Arr) > 0 Then
                            lngRow = Arr(1)
                            If lngRow >= 1 Then
                                lngCol = 3
                                If clsGridFormat.TextNote = "Yes" Then
                                    Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "(1,1)", "TypeHAlignLeft", clsGridFormat.CellTag & "_SCORE"
                                ElseIf clsGridFormat.TextNote = "No" Then
                                    Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "(0,1)", "TypeHAlignLeft", clsGridFormat.CellTag & "_SCORE"
                                End If
                            End If
                        End If
                    End If
                End If
                Calc_Katz
            End If
        End If
    End With
    Exit Function
End Function
Private Function Add_Check_Instructions()
Dim strSQL As String
Dim rsTerms As New ADODB.Recordset
Dim cnTerms As New ADODB.Connection
Dim lngRow As Long
Dim lngCol As Long
Dim strTerms As String
Dim lngFirst As Long
Dim Idx%
Dim booData As Boolean
Dim Arr


    On Error GoTo Error_Add_Check_Instructions
    clsGridFormat.List = vbNullString
    mbooLoad = True
    If cnTerms.State = adStateClosed Then cnTerms.open psConnect(1)
    strSQL = "Get_Attr_Valid_Value_SubDom_Alphabetic 'sd_PsyPlan_Instruct'"
    Set rsTerms = cnTerms.Execute(strSQL)
    With rsTerms
        Do Until .EOF
            If (!ATTRBTE_VALID_VALUE) <> vbNullString Then
                If Trim(clsGridFormat.List) = vbNullString Then
                    strTerms = Trim(!ATTRBTE_VALID_VALUE)
                End If
            End If
            .MoveNext
            strTerms = Replace(strTerms, "''", "'")
            lngRow = grdReport.MaxRows + 1
            grdReport.MaxRows = lngRow
            If lngFirst = 0 Then lngFirst = lngRow
            lngCol = 2
            Format_CellTypeCheckBox grdReport, lngRow, lngCol, "1", "", "TypeHAlignLeft", "INSTRUCTIONS", False, 0, 0
            lngCol = 3
            Format_CellTypeEdit grdReport, lngRow, lngCol, "4", strTerms, "TypeHAlignLeft", "INSTRUCTION_TEXT"
        Loop
    End With
    Read_Instruction
    With grdReport
        If Trim(clsReport.Instructions) <> vbNullString Then
            Arr = Split(clsReport.Instructions, vbNewLine)
            If UBound(Arr) > 0 Then
                For Idx = LBound(Arr) To UBound(Arr)
                    booData = False
                    If Arr(Idx) <> vbNullString And Len(Arr(Idx)) > 3 Then
                        For lngRow = lngFirst To .MaxRows
                            .Col = 2
                            .Row = lngRow
                            If .CellType = CellTypeCheckBox Then
                                If .TypeCheckText = Arr(Idx) Then
                                    booData = False
                                    .Text = "1"
                                    Exit For
                                End If
                            End If
                            If booData Then Exit For
                        Next lngRow
                    End If
                Next Idx
            Else
                booData = False
                For lngRow = lngFirst To .MaxRows
                    .Col = 2
                    .Row = lngRow
                    If .CellType = CellTypeCheckBox Then
                        If .TypeCheckText = Trim(clsReport.Instructions) Then
                            booData = False
                            .Text = "1"
                            Exit For
                        End If
                    End If
                Next lngRow
            End If
        End If
    End With
    If cnTerms.State = adStateOpen Then
        cnTerms.Close
        Set rsTerms = Nothing
        Set cnTerms = Nothing
    End If
    mbooLoad = False
    Screen.MousePointer = vbDefault
    Exit Function
Error_Add_Check_Instructions:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, "", "Add_Check_Instructions", Me.Name
    Exit Function
    Resume Next
End Function
