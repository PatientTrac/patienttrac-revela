                            'SavePicture picSignature.Image, App.Path & "\Images\SignNote.bmp"
'                            If FileExists(App.Path & "\Images\SignNote.bmp") Then
'                                SavePicture picSignature.Image, App.Path & "\Images\SignNote.bmp"
'                                strPhoto = App.Path & "\Images\SignNote.bmp"
'                            End If
