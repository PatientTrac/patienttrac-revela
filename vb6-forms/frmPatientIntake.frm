    End With
    If LookUpHeaderRow = vbNullString Then
        Arr = Split(LookUpHeaderRow, "|")
        If UBound(Arr) <= 0 And vstrName = "CURRENT HISTORY" Then
            If mstrPractice = "Psychiatry" Then lngRow = 7 Else lngRow = 12
            With grdReport
                LookUpHeaderRow = vbNullString
                    For lngRow = lngRow To .MaxRows
                        .Col = 1
                        .Row = lngRow
                        .GetText 1, lngRow, varCellValue
                        If Trim(varCellValue) = "HISTORY" Then
                            LookUpHeaderRow = 1 & "|" & lngRow
                            booExit = True
                            Exit For
                        End If
                    Next lngRow
            End With
        End If
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_LookUpHeaderRow:
    Screen.MousePointer = vbDefault
   Exit Function
    Resume Next
End Function
Private Function LookUpRemove(vstrName As String)
Dim lngRow As Long
Dim lngCol As Long
Dim varCellValue
Dim booExit As Boolean

    On Error GoTo Error
    
    With grdReport
        For lngRow = 7 To .MaxRows
            .Col = 2
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If TextFound(vstrName, .CellTag, Len(vstrName), True) And lngRow <> mlngGridRow Then
                    .ClearRange 2, lngRow, .MaxCols, lngRow, True
                    .DeleteRows lngRow, 1
                    .MaxRows = .MaxRows - 1
                End If
            End If
        Next lngRow
    End With
    Exit Function
Error:
    Exit Function
End Function
Private Function LookUpRow(vstrName As String) As String
Dim lngRow As Long
Dim lngCol As Long
Dim varCellValue
Dim booExit As Boolean

    On Error GoTo Error_LookUpRow
    Screen.MousePointer = vbHourglass
    With grdReport
        LookUpRow = vbNullString
        For lngCol = 1 To .MaxCols
            For lngRow = 12 To .MaxRows
                .Col = lngCol
                .Row = lngRow
                .GetText lngCol, lngRow, varCellValue
                If Trim(varCellValue) <> vbNullString And TextFound(vstrName, varCellValue, Len(vstrName), True) Then
                     LookUpRow = lngCol & "|" & lngRow
                     booExit = True
                     Exit For
                End If
            Next lngRow
            If booExit Then Exit For
        Next lngCol
    End With
    Screen.MousePointer = vbDefault
    Exit Function
Error_LookUpRow:
    Screen.MousePointer = vbDefault
   Exit Function
   Resume Next
End Function
