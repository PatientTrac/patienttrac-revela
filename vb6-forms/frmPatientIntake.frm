    On Error GoTo Error_Read_Scales
    Screen.MousePointer = vbHourglass
    strActName = vbNullString
    Read_MechScale
    If Trim(clsMechScale.Notes) <> vbNullString Then
        strActName = "MECH INVENTORY"
