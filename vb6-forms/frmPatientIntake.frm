Dim strProcedure As String
Dim Arr
Dim i%
Dim strInform As String
Dim iRow%
Dim iCol%
Dim CellNote As Long
Dim varColName
Dim lngCntProc As Long
Dim strBullet As String
Dim lngProcID As Long
Dim Idx As Integer
Dim lngPrimKey As Long
Dim strLongInform As String
Dim lngInsertRow As Long
Dim lngRow As Long
Dim lngStart As Long
Dim lngEnd As Long
Dim ArrNum
Dim strTermInform As String
Dim strEducation As String

    On Error GoTo Error_Set_Patient_Education
    Screen.MousePointer = vbHourglass
    If clsRowCount.PatientEducation <> vbNullString Then
        Arr = Split(clsRowCount.PatientEducation, "|")
        If UBound(Arr) > 0 Then
            lngStart = Arr(0)
            lngEnd = Arr(1)
        End If
    End If
    With grdReport
        If Trim(clsReport.INFORM) <> vbNullString Or clsPreSurgOder.Education <> vbNullString Then
            If clsReport.INFORM = vbNullString Then clsReport.INFORM = Trim(clsPreSurgOder.Education)
            For iRow = mlngGridRow To .MaxRows
                .GetText 1, iRow, varColName
                lngRow = iRow
                If TextFound("PATIENT EDUCATION", varColName, Len("PATIENT EDUCATION"), True) Then
                    clsRowCount.PatientEducation = lngRow
                    Exit For
                End If
            Next iRow
                    lngCntProc = 0
                    strBullet = vbNullString
                    strEducation = Trim(clsPreSurgOder.Education)
                    strEducation = Replace(strEducation, vbNewLine, "|")
                    Arr = Split(strEducation, "|")
                    If UBound(Arr) > 0 Then
                        For i = LBound(Arr) To UBound(Arr)
                            strTermInform = Trim(Arr(i))
                            lngInsertRow = lngRow + 1
                            lngCntProc = lngCntProc + 1
                            strBullet = "*     "
                            If Len(strTermInform) > 2 Then
                                strInform = "     " & strBullet & strTermInform
                                .MaxRows = .MaxRows + 1
                                .InsertRows lngInsertRow, 1
                                Format_CellTypeEdit grdReport, lngInsertRow, 2, "maxcols", strInform, "TypeHAlignLeft", "PATIENT EDUCATION"
                            End If
                        Next i
                    ElseIf strEducation <> vbNullString Then
                        .MaxRows = .MaxRows + 1
                        lngInsertRow = lngRow + 1
                        .InsertRows lngInsertRow, 1
                        Format_CellTypeEdit grdReport, lngInsertRow, 2, "maxcols", clsPreSurgOder.Education, "TypeHAlignLeft", "PATIENT EDUCATION"
                    End If
                    .MaxRows = .MaxRows + 1
                    If clsPreSurgOder.Education = vbNullString Then clsPreSurgOder.Education = Trim(clsReport.INFORM)
                    clsRowCount.PatientEducation = lngRow & "|" & lngInsertRow
        End If
    Write_Education strEducation
    End With
    If cnTerms.State = adStateOpen Then
        cnTerms.Close
        Set cnTerms = Nothing
        Set rsTerms = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Sub
