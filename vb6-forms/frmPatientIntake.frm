        clsGridFormat.SheetName = "HAMILTON DEPRESSION RATING"
        clsGridFormat.CellTag = "HAMILTON DEPRESSION"
        Add_Psychiatry_Test_Page
    End If
    Read_Suboxone
    If Trim(clsSuboxone.Suboxone_Notes) <> vbNullString Then
