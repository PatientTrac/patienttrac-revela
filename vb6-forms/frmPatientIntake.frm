    On Error GoTo Error_Write_Medication_Titration
    Screen.MousePointer = vbHourglass
    Get_Encounter piEncounterID
     mbooLoad = True
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    Arr = Split(LookUpHeaderRow("OBRA"), "|")
    If UBound(Arr) > 0 Then
        lngRow = Arr(1)
    End If
    With grdReport
          For lngRow = lngRow To .MaxRows
            .Col = 2
            .Row = lngRow
            If .CellTag <> vbNullString Then
                If UCase(.CellTag) = "OBRA" Then
                    If .CellType = CellTypeCheckBox Then
                        If .Text = "1" Then
                            .GetText 3, lngRow, varCellValue
                            If Trim(varCellValue) <> vbNullString Then
                                If Trim(strNotes) = vbNullString Then
                                    strNotes = Trim(varCellValue)
