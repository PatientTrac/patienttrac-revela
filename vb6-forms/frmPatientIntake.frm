        Populate_Scales strActName
    End If
    Read_PHQ
    If Trim(clsPHQ.Notes) <> vbNullString Then
        strActName = "PHQ-9"
        Populate_Scales strActName
    End If
    Read_BPRS
    If Trim(clsBPRS.Notes) <> vbNullString Then
