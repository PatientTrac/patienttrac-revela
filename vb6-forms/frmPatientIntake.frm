        If strType = "PATIENT" Then
            strSQL = "Write_Patient_Clinical " & piPatientID & ", " & piEncounterID & ", " & clsEncounter.ProviderID & "," _
                & intActX_ID & ",'cctSummary', 1, trim(vstrValue), '" & strClinDesc & "',1, '" _
                & Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM") & "', '" & PsUserID & "'"
            Set rsWrite = cnWrite.Execute(strSQL)
        ElseIf strType = "PROFILER" Then
           If vstrOCX = "CURRENT MEDICATIONS" Then
