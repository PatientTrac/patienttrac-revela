Private Function Calc_GPM()
Dim lngRow As Long
Dim lngCol As Long
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim strOCX As String
Dim strSQL As String
Dim lngCal As Long
Dim Arr

    
    On Error GoTo Error_Calc_GPM
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "SELECT DISTINCT ROW_NAME, CLINICAL_NOTE FROM  PATIENT_ADHD_SCALE WHERE FORM_NAME = 'GPM' AND " _
        & "PATIENT_ID = " & piPatientID & "  AND " _
        & "ENCOUNTER_ID = " & piEncounterID & " AND CLINICAL_VALUE <> ''"
        Set rsWrite = cnWrite.Execute(strSQL)
        With rsWrite
            Do Until .EOF
                clsGridFormat.CellTag = vbNullString
                If Not IsNull((!ROW_NAME)) Then
                    clsGridFormat.CellTag = UCase((!ROW_NAME))
                End If
                If Not IsNull((!CLINICAL_NOTE)) Then
                    clsGridFormat.TextNote = UCase((!CLINICAL_NOTE))
                End If
                .MoveNext
                Arr = Split(clsGridFormat.CellTag, "_")
                If UBound(Arr) > 0 Then
                    clsGridFormat.CellTag = vbNullString
                    clsGridFormat.CellTag = Trim(Arr(1))
                Else
                    clsGridFormat.CellTag = vbNullString
                End If
                If UCase(clsGridFormat.CellTag) = "YES" Then
                    lngCal = lngCal + 1
                ElseIf UCase(clsGridFormat.CellTag) = "COMBO" Then
                    lngCal = lngCal + Val(clsGridFormat.TextNote)
                End If
            Loop
        End With
        lngCal = lngCal * 2.38
        If lngCal < 30 Then
            clsGridFormat.CellNote = "indicates Mild Pain."
        ElseIf lngCal > 30 And lngCal <= 70 Then
            clsGridFormat.CellNote = "indicates Moderate Pain."
        ElseIf lngCal > 70 Then
            clsGridFormat.CellNote = "indicates Severe Pain."
        End If
        grdReport.sheet = clsGridFormat.SheetNumber
        grdReport.ActiveSheet = clsGridFormat.SheetNumber
        grdReport.SheetName = clsGridFormat.SheetName
        Arr = Split(LookUpCellTag("GPM_SCORE"), "|")
        If UBound(Arr) > 0 Then
            lngRow = Arr(1)
            If lngRow > 1 Then
                lngCol = 3
                Format_CellTypeEdit grdReport, lngRow, lngCol, "1", "(" & CStr(lngCal) & ",100)", "TypeHAlignLeft", "GPM_SCORE", False, HeaderColor
                lngCol = 4
                Format_CellTypeEdit grdReport, lngRow, lngCol, "4", clsGridFormat.CellNote, "TypeHAlignLeft", "GPM_INTERPRETATION", False, HeaderColor
            End If
        End If
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set rsWrite = Nothing
        Set cnWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Calc_GPM:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Calc_GPM", TypeName(Me)
    Exit Function
    Resume Next
End Function
