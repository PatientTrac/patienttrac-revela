    On Error GoTo Error_Get_PlanCollection
    
    
    With grdReport
        For lngRow = 7 To .MaxRows
        .GetText 1, lngRow, varCellValue
            If TextFound("MEDICATION ORDERS", varCellValue, Len("MEDICATION ORDERS"), True) Then
                If mstrPractice = "Psychiatry" Then Values_Psychiatry "MEDICATION ORDERS"
                If mstrPractice = "Plastic Surgery" Then Values_Surgery "MEDICATION ORDERS"
