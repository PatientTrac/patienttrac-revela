Private Function Read_GridNotes()
Dim Idx As Integer
Dim Arr
Dim ArrSplit
Dim lngRow As Long
Dim lngCol As Long
Dim i%
Dim strPhoto As String
Dim lngPicRow As Long

    On Error GoTo Error_Read_GridNotes
    Screen.MousePointer = vbHourglass
    
    With grdReport
    If mstrGridNote <> vbNullString Then
        ArrSplit = Split(mstrGridNote, "|")
        If UBound(ArrSplit) > 0 Then
            For Idx = LBound(ArrSplit) To UBound(ArrSplit)
                Arr = Split(ArrSplit(Idx), "~")
                If UBound(Arr) > 0 Then
                    For i = LBound(Arr) To UBound(Arr)
                        If (i) = 1 Then lngRow = Arr(i)
                        If (i) = 2 Then lngCol = Arr(i)
                        If (i) = 3 Then strPhoto = Arr(i)
                    Next i
                        If lngRow > 0 And strPhoto <> vbNullString Then
                        If Not mbooImage And lngRow <> lngPicRow Then
                            .MaxRows = .MaxRows + 1
                            .InsertRows Val(lngRow), 1
                            .RemoveCellSpan lngCol, lngRow
                             mbooImage = True
                             lngPicRow = lngRow
                        End If
                             .BlockMode = True
                                .Col = lngCol
                                .Col2 = lngCol
                                .Row = lngRow
                                .Row2 = lngRow
                                .CellType = CellTypePicture
                                If FileExists(strPhoto) Then
                                    .AddCellSpan lngCol, lngRow, 3, 1
                                    .TypePictPicture = LoadPicture(strPhoto)
                                    .TypePictStretch = True
                                    .TypePictMaintainScale = True
                                    .TypePictCenter = True
                                    .RowHeight(lngRow) = 100
                                End If
                                .TypePictCenter = True
                            .BlockMode = False
                        End If
                        lngRow = 0
                        lngCol = 0
                        strPhoto = vbNullString
                End If
            Next Idx
        Else
            Arr = Split(mstrGridNote, "~")
            If UBound(Arr) > 0 Then
                For i = LBound(Arr) To UBound(Arr)
                    If i = 1 Then lngRow = Arr(i)
                    If i = 2 Then lngCol = Arr(i)
                    If i = 3 Then strPhoto = Arr(i)
                Next i
                    If lngRow > 0 And strPhoto <> vbNullString Then
                        .MaxRows = .MaxRows + 1
                        .InsertRows Val(lngRow), 1
                        .RemoveCellSpan lngCol, lngRow
                         .BlockMode = True
                            .Col = lngCol
                            .Col2 = lngCol
                            .Row = lngRow
                            .Row2 = lngRow
                            .CellType = CellTypePicture
                            If FileExists(strPhoto) Then
                                .AddCellSpan lngCol, lngRow, 3, 1
                                .TypePictPicture = .LoadPicture(strPhoto, PictureTypeUnknown)
                                .TypePictStretch = True
                                .TypePictCenter = True
                                .RowHeight(lngRow) = 100
                            End If
                            .TypePictCenter = True
                            If mstrGridNote <> vbNullString Then
                                mstrGridNote = mstrGridNote & "|" & "Inserted Patient Photo" & "~" & lngRow & "~" & lngCol & "~" & fstrImageFile
                            Else
                                mstrGridNote = "Inserted Patient Photo" & "~" & lngRow & "~" & lngCol & "~" & fstrImageFile
                            End If
                        .BlockMode = False
                    End If
                    lngRow = 0
                    lngCol = 0
                    strPhoto = vbNullString
               ' Next i
            End If
        End If
    End If
    End With
    Screen.MousePointer = vbDefault
    
    Exit Function
Error_Read_GridNotes:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strPhoto, "Read_GridNotes", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Read_MSE()
Dim lngRow As Long
Dim lngCol As Long
Dim strRow As String
Dim Arr
Dim strSQL As String
Dim cnWrite As New ADODB.Connection
Dim rsWrite As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim varCellValue
Dim strDate As String

    On Error GoTo Error_Read_MSE
    Screen.MousePointer = vbHourglass
    If clsEncounter.EncounterType = vbNullString Then
        Get_Encounter piEncounterID
    End If
    If clsEncounter.StartDate <> vbNullString Then
        strDate = Format(clsEncounter.StartDate, "mm/dd/yyyy hh:mm:ss AM/PM")
    Else
        strDate = Format(Now, "mm/dd/yyyy hh:mm:ss AM/PM")
    End If
    If cnWrite.State = adStateClosed Then cnWrite.open psConnect(0)
    strSQL = "Read_Mental_Status_New " & piPatientID & "," & piEncounterID
    Set rsWrite = cnWrite.Execute(strSQL)
    With rsWrite
        Do Until .EOF
            Clear_New_MSE
            Set Flds = .Fields
            For Each Fld In Flds
                If Not IsNull(Fld.Value) Then
                    If Trim(Fld.Value) <> vbNullString Then
                        Select Case UCase(Fld.Name)
                            Case "MSE_ITEM"
                                udtNew_MSE.MSE_Item = Trim(Fld.Value)
                            Case "MSE_DATA"
                                udtNew_MSE.MSE_Data = Trim(Fld.Value)
                            Case "MSE_NOTES"
                                udtNew_MSE.MSE_Note = Trim(Fld.Value)
                        End Select
                    End If
                End If
            Next
            .MoveNext
            For lngRow = 1 To grdInstruct.MaxRows
                grdInstruct.GetText 1, lngRow, varCellValue
                If Trim(varCellValue) = Trim(udtNew_MSE.MSE_Item) Then
                    lngCol = 2
                    Format_CellTypeEdit grdInstruct, lngRow, lngCol, "1", udtNew_MSE.MSE_Data, "TypeHAlignLeft", udtNew_MSE.MSE_Item
                    grdInstruct.SetCellBorder lngCol, lngRow, lngCol, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                    lngCol = 3
                    Format_CellTypeEdit grdInstruct, lngRow, lngCol, "1", udtNew_MSE.MSE_Note, "TypeHAlignLeft", udtNew_MSE.MSE_Item
                    grdInstruct.SetCellBorder lngCol, lngRow, lngCol, lngRow, CellBorderIndexOutline, GridBlue, CellBorderStyleSolid
                    Exit For
                End If
            Next lngRow
        Loop
    End With
    If cnWrite.State = adStateOpen Then
        cnWrite.Close
        Set cnWrite = Nothing
        Set rsWrite = Nothing
    End If
    Screen.MousePointer = vbDefault
    Exit Function
Error_Read_MSE:
    Screen.MousePointer = vbDefault
    Write_Error Err.Description, Err.Number, strSQL, "Read_MSE", Me.Name
    Exit Function
    Resume Next
End Function
Private Sub Read_Scales()
Dim strActName As String
