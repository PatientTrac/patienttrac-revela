Private Function Get_ReferPhys(vstName As String) As String
Dim strSQL As String
Dim sStr1 As String
Dim sStr2 As String
Dim lID As Long
Dim strSpecialty As String
Dim cnRef As New ADODB.Connection
Dim rsRef As New ADODB.Recordset
Dim Flds As ADODB.Fields
Dim Fld As ADODB.Field
Dim strName As String
Dim lngRefID As Long
Dim Arr
Dim Idx As Integer
Dim strFirstName As String
Dim strMiddle As String
Dim strLastName As String
Dim strReason As String
Dim strTitle As String
Dim ArrTitle

    On Error GoTo Error_Get_ReferPhys
    If cnRef.State = adStateClosed Then cnRef.open psConnect(0)
    Get_ReferPhys = vbNullString
    ArrTitle = Split(vstName, ", ")
    If UBound(ArrTitle) > 0 Then
        strName = ArrTitle(0)
    End If
    Arr = Split(strName, " ")
    If UBound(Arr) > 0 Then
        If UBound(Arr) = 2 Then ' We have a two part name
            strFirstName = Arr(0)
            strLastName = Arr(1) & " " & Arr(2)
        ElseIf UBound(Arr) = 1 Then ' No Middle Name
            strFirstName = Arr(0)
            strLastName = Arr(1)
        End If
    Else
        Exit Function
    End If
    strSQL = "Search_Referral_Last_Name_First_Name '" & strFirstName & "','" & strLastName & "'"
    Set rsRef = cnRef.Execute(strSQL)
    With rsRef
        If Not .EOF Then
                Set Flds = .Fields
                For Each Fld In Flds
                    If Not IsNull(Fld.Value) Then
                        If Trim(Fld.Value) <> vbNullString Then
                            Select Case UCase(Fld.Name)
                                Case "FIRST_NAME"
                                    strFirstName = Fix_Name(Fld.Value)
                                Case "MIDDLE_NAME"
                                    strMiddle = Fix_Name(Fld.Value)
                                Case "LAST_NAME"
                                    strLastName = Fix_Name(Fld.Value)
                                Case "TITLE"
                                    strTitle = Fix_Title(Fld.Value)
                                Case "CONSULT_REASON"
                                   strReason = Fld.Value
                                Case "REFERRER_ID"
                                   lngRefID = Fld.Value
                            End Select
                        End If
                    End If
                Next
                strName = strFirstName
                If strMiddle <> vbNullString Then strName = Trim(strName) & " " & strMiddle
                If strLastName <> vbNullString Then strName = Trim(strName) & " " & strLastName
                If strTitle <> vbNullString Then strName = Trim(strName) & " " & strTitle
        End If
        If strName <> vbNullString Then Get_ReferPhys = Trim(strName) & "|" & strReason & "|" & lngRefID
    End With
    If cnRef.State = adStateOpen Then
        cnRef.Close
        Set cnRef = Nothing
        Set rsRef = Nothing
    End If
    Exit Function
Error_Get_ReferPhys:
    Write_Error Err.Description, Err.Number, strSQL, "Get_ReferPhys", Me.Name
    Exit Function
    Resume Next
End Function
Private Function Get_SigData(vstrPhoto As String)
Dim strSQL As String
Dim cnReport As New ADODB.Connection
Dim rsReport As New ADODB.Recordset

    On Error GoTo Error_Get_Signature
    If cnReport.State = adStateClosed Then cnReport.open psConnect(1)
    strSQL = "Get_Report_Config_Row_Name_Report_ID '" & vstrPhoto & "', " & mlngReportID
    Set rsReport = cnReport.Execute(strSQL)
    If Not rsReport.EOF Then
        If Not IsNull(rsReport.Fields("START_COLUMN_NUMBER")) Then
            mlngSigCol = rsReport.Fields("START_COLUMN_NUMBER")
            mlngSigRow = rsReport.Fields("ROW_NUMBER")
        End If
    End If
    If cnReport.State = adStateOpen Then
        cnReport.Close
        Set cnReport = Nothing
        If rsReport.State = adStateOpen Then rsReport.Close
        Set rsReport = Nothing
    End If
    Exit Function
Error_Get_Signature:
    Write_Error Err.Description, Err.Number, strSQL, "Get_Signature", Me.Name
    Exit Function
    Resume Next
End Function
Private Sub Add_Spacer_Instruct(vlngRow As Long, vObjGrid As Object)
    With vObjGrid
        vlngRow = vlngRow
       If .MaxRows < vlngRow Then .MaxRows = vlngRow
        .BlockMode = True
            .Col = 1
            .Col2 = 1
            .Row = vlngRow
            .Row2 = vlngRow
            .RowHeight(vlngRow) = 3
            .BackColor = 12632256
            .AddCellSpan 1, vlngRow, .MaxCols, 1
            .SetCellBorder 1, vlngRow, .MaxCols, vlngRow, 16, &H80&, CellBorderStyleSolid
        .BlockMode = False
    End With
    Exit Sub
End Sub


