# ============================================================
# PatientTrac Revela — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Anthropic AI ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Supabase (Database + Auth) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT Authentication ---
# Must be at least 64 characters
JWT_SECRET=change-this-to-a-long-random-string-at-least-64-chars
JWT_REFRESH_SECRET=change-this-to-another-long-random-string-at-least-64-chars
SESSION_TIMEOUT_MINUTES=15

# --- Frontend (Vite public vars — will be exposed to browser) ---
VITE_APP_NAME=PatientTrac Revela
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:8888/.netlify/functions
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Email / SMTP (for MFA codes, notifications) ---
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=noreply@patienttracrevela.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=PatientTrac Revela

# --- Netlify (for GitHub Actions deploy — set in GitHub Secrets, not here) ---
# NETLIFY_AUTH_TOKEN=...
# NETLIFY_SITE_ID=...

# --- Feature Flags ---
VITE_ENABLE_VOICE_DICTATION=false
VITE_ENABLE_3D_VIEWER=false
VITE_ENABLE_DARK_MODE=true
